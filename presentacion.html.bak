<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SGDEA · Contextualización de Requisitos por Módulo</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
:root{
  /* LinkTIC Control Panel · tema oscuro (azul profundo) por defecto */
  --bg:#2C3F53; --bg2:#2C3F53;
  --bg-grad:#2C3F53;
  --glass:rgba(34,48,63,.72); --glass-hover:rgba(46,64,84,.85); --glass-thick:rgba(34,48,63,.9); --glass-ultra:rgba(34,48,63,.94);
  --ink:rgba(255,255,255,.92); --muted:rgba(255,255,255,.62); --faint:rgba(255,255,255,.5);
  --brand:#0A84FF; --brand2:#32ADE6; --accent:#32ADE6;
  --green:#30D158; --red:#FF453A; --amber:#FF9F0A;
  --border:rgba(255,255,255,.1); --border2:rgba(255,255,255,.16);
  --hairline:rgba(255,255,255,.12);
  --track:rgba(255,255,255,.1); --track2:rgba(255,255,255,.08);
  --row-hover:rgba(255,255,255,.03);
  --chip:rgba(255,255,255,.06); --kbd:rgba(255,255,255,.08);
  --scroll:rgba(255,255,255,.18); --dotbg:rgba(255,255,255,.22);
  --shimmer:rgba(255,255,255,.55);
  --sep:rgba(255,255,255,.2); --sep2:rgba(255,255,255,.25);
  --metric-grad-start:#ffffff;
  --aurora-opacity:.22;
  --shadow:0 8px 30px rgba(0,0,0,.5); --shadow-hover:0 16px 44px rgba(0,0,0,.6);
  --ui:'Inter',-apple-system,BlinkMacSystemFont,'SF Pro Display',system-ui,sans-serif;
  --mono:'JetBrains Mono',ui-monospace,SFMono-Regular,Menlo,monospace;
  --ease:cubic-bezier(.25,.1,.25,1); --ease-spring:cubic-bezier(.175,.885,.32,1.1);
  --r-xs:8px; --r-sm:12px; --r-md:16px; --r:20px;
}
:root[data-theme="light"]{
  /* tema claro · fondo azul claro */
  --bg:#EDF0FF; --bg2:#EDF0FF;
  --bg-grad:#EDF0FF;
  --glass:rgba(255,255,255,.74); --glass-hover:rgba(255,255,255,.92); --glass-thick:rgba(255,255,255,.84); --glass-ultra:rgba(255,255,255,.93);
  --ink:rgba(28,40,62,.94); --muted:rgba(28,40,62,.66); --faint:rgba(28,40,62,.5);
  --border:rgba(44,63,83,.16); --border2:rgba(44,63,83,.24);
  --hairline:rgba(44,63,83,.1);
  --track:rgba(44,63,83,.12); --track2:rgba(44,63,83,.1);
  --row-hover:rgba(44,63,83,.04);
  --chip:rgba(44,63,83,.06); --kbd:rgba(44,63,83,.08);
  --scroll:rgba(44,63,83,.22); --dotbg:rgba(44,63,83,.22);
  --shimmer:rgba(255,255,255,.7);
  --sep:rgba(44,63,83,.2); --sep2:rgba(44,63,83,.3);
  --metric-grad-start:#0A84FF;
  --aurora-opacity:.12;
  --shadow:0 8px 30px rgba(44,63,83,.12); --shadow-hover:0 16px 44px rgba(44,63,83,.18);
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%}
body{
  font-family:var(--ui); color:var(--ink);
  overflow:hidden; -webkit-font-smoothing:antialiased;
  background:var(--bg-grad);
  transition:background .4s var(--ease), color .4s var(--ease);
}
/* ---- Aurora animada de fondo ---- */
.aurora{position:fixed;inset:0;z-index:0;overflow:hidden;pointer-events:none}
.aurora .orb,
.aurora .sphere{position:absolute;border-radius:50%;will-change:transform;transition:opacity .4s var(--ease)}
.aurora .orb{filter:blur(90px);opacity:var(--aurora-opacity)}
/* Esferas de marca · círculos definidos con aspecto 3D en las esquinas */
.aurora .sphere{opacity:.92;box-shadow:0 36px 90px rgba(0,0,0,.4)}
.aurora .o1{width:62vw;height:62vw;left:-14%;top:-18%;
  background:radial-gradient(circle,#0A84FF 0%,transparent 62%);animation:float1 20s ease-in-out infinite}
.aurora .o2{width:55vw;height:55vw;right:-12%;bottom:-20%;
  background:radial-gradient(circle,#0050E0 0%,transparent 62%);animation:float2 26s ease-in-out infinite}
.aurora .o3{width:42vw;height:42vw;left:38%;top:42%;
  background:radial-gradient(circle,#32ADE6 0%,transparent 62%);animation:float3 30s ease-in-out infinite}
/* Esfera azul grande · esquina superior izquierda */
.aurora .s1{width:30vw;height:30vw;left:-13%;top:-14%;
  background:radial-gradient(circle at 36% 30%, #3A8FFF 0%, #0A6BEF 50%, #003FAE 100%);
  animation:float4 34s ease-in-out infinite}
/* Esfera azul · esquina inferior derecha */
.aurora .s2{width:26vw;height:26vw;right:-12%;bottom:-12%;
  background:radial-gradient(circle at 34% 28%, #3A8FFF 0%, #0A6BEF 52%, #003FAE 100%);
  animation:float5 38s ease-in-out infinite}
/* Modo claro · esferas mucho más sutiles */
:root[data-theme="light"] .aurora .sphere{opacity:.16;box-shadow:none}
:root[data-theme="light"] .aurora .s2{box-shadow:none}
@keyframes float1{0%,100%{transform:translate(0,0) scale(1)}50%{transform:translate(12%,16%) scale(1.18)}}
@keyframes float2{0%,100%{transform:translate(0,0) scale(1)}50%{transform:translate(-14%,-12%) scale(1.12)}}
@keyframes float3{0%,100%{transform:translate(0,0) scale(1)}50%{transform:translate(-10%,8%) scale(1.25)}}
@keyframes float4{0%,100%{transform:translate(0,0) scale(1)}50%{transform:translate(6%,8%) scale(1.08)}}
@keyframes float5{0%,100%{transform:translate(0,0) scale(1)}50%{transform:translate(-8%,10%) scale(1.12)}}
@keyframes float6{0%,100%{transform:translate(0,0) scale(1)}50%{transform:translate(-4%,-6%) scale(1.1)}}
.deck{position:fixed;inset:0;overflow:hidden;z-index:1}
.slide{
  position:absolute;inset:0;display:none;flex-direction:column;
  padding:clamp(28px,5vw,72px); opacity:0; transform:translateY(18px);
  transition:opacity .5s var(--ease), transform .5s var(--ease);
  background:transparent;
}
.slide.active{display:flex;opacity:1;transform:none}
.slide.scroll{overflow-y:auto}
h1,h2,h3{font-family:var(--ui);letter-spacing:-.01em}
.mono,.tnum{font-family:var(--mono);font-feature-settings:'tnum'}

.kicker{display:inline-flex;align-items:center;gap:9px;font-size:11px;letter-spacing:.14em;
  text-transform:uppercase;color:var(--brand);font-weight:700;margin-bottom:14px}
.kicker .dot{width:8px;height:8px;border-radius:50%;background:var(--brand);
  box-shadow:0 0 0 0 rgba(10,132,255,.6);animation:pulse 2.4s var(--ease) infinite}
@keyframes pulse{0%{box-shadow:0 0 0 0 rgba(10,132,255,.55)}70%{box-shadow:0 0 0 10px rgba(10,132,255,0)}100%{box-shadow:0 0 0 0 rgba(10,132,255,0)}}

.cover{justify-content:center}
.cover-logos{display:flex;align-items:center;gap:22px;margin-bottom:34px;align-self:flex-start;padding:0}
.cover-logo{height:clamp(36px,4.4vw,50px);width:auto}
.cover-logo.linktic{height:clamp(44px,5.2vw,62px)}
.logo-sep{width:1px;height:clamp(30px,3.6vw,42px);background:var(--sep)}
.cover h1{font-size:clamp(42px,7.4vw,88px);line-height:1.03;font-weight:800;letter-spacing:-.03em;max-width:none;white-space:nowrap;color:var(--ink)}
.cover h1 .grad{background:linear-gradient(100deg,#0A84FF,#0050E0 45%,#32ADE6 70%,#0A84FF);
  background-size:220% auto;-webkit-background-clip:text;background-clip:text;color:transparent;
  animation:gradShift 7s linear infinite;filter:drop-shadow(0 4px 30px rgba(10,132,255,.45))}
@keyframes gradShift{to{background-position:220% center}}
.cover p.sub{margin-top:26px;font-size:clamp(16px,2vw,21px);color:var(--muted);max-width:none;white-space:nowrap;line-height:1.55;font-weight:400}
.cover .meta{margin-top:46px;display:flex;gap:18px;flex-wrap:wrap;align-self:flex-start}
.cover .meta>div{position:relative;display:flex;flex-direction:column;gap:8px;min-width:170px;
  padding:20px 28px;border-radius:var(--r-md);overflow:hidden;
  background:var(--glass);backdrop-filter:saturate(180%) blur(20px);-webkit-backdrop-filter:saturate(180%) blur(20px);
  border:.5px solid var(--border);box-shadow:var(--shadow)}
.cover .meta>div::before{content:"";position:absolute;left:0;top:0;bottom:0;width:3px;
  background:linear-gradient(var(--brand),var(--brand2))}
.cover .meta>div::after{content:"";position:absolute;inset:0;pointer-events:none;
  background:radial-gradient(130% 100% at 0% 0%, color-mix(in srgb,var(--brand) 16%,transparent), transparent 62%)}
.cover .meta div .n{font-family:var(--mono);font-feature-settings:'tnum';font-size:clamp(34px,4.6vw,52px);font-weight:700;
  line-height:1;background:linear-gradient(120deg,var(--metric-grad-start),var(--brand2));-webkit-background-clip:text;background-clip:text;color:transparent}
.cover .meta div .l{font-size:11px;color:var(--faint);letter-spacing:.12em;text-transform:uppercase;font-weight:600}
.cover-foot{position:absolute;left:clamp(28px,5vw,72px);right:clamp(28px,5vw,72px);bottom:clamp(24px,3.4vw,40px);
  display:flex;align-items:center;justify-content:space-between;gap:18px;
  padding-top:18px;border-top:.5px solid var(--border);
  font-size:12px;color:var(--faint);letter-spacing:.04em;font-weight:500}
.cover-foot .sep{color:var(--sep2)}

.shead{display:flex;align-items:flex-end;justify-content:space-between;gap:24px;margin-bottom:26px;
  padding-bottom:20px;border-bottom:.5px solid var(--border)}
.backbtn{align-self:flex-start;display:inline-flex;align-items:center;gap:8px;margin-bottom:18px;
  padding:8px 16px;border:.5px solid var(--border);border-radius:9999px;
  background:var(--glass);backdrop-filter:saturate(180%) blur(20px);-webkit-backdrop-filter:saturate(180%) blur(20px);
  color:var(--muted);font-family:var(--ui);font-size:13px;font-weight:600;cursor:pointer;
  box-shadow:var(--shadow);transition:all .2s var(--ease)}
.backbtn:hover{color:var(--brand);background:var(--glass-hover);transform:translateY(-1px);box-shadow:var(--shadow-hover)}
.backbtn .bb-arrow{font-size:15px;transition:transform .2s var(--ease)}
.backbtn:hover .bb-arrow{transform:translateX(-3px)}
.shead-l{display:flex;align-items:center;gap:18px}
.mod-icon{flex:0 0 auto;display:grid;place-items:center;width:clamp(52px,5vw,68px);height:clamp(52px,5vw,68px);
  border-radius:18px;font-size:clamp(26px,2.8vw,34px);line-height:1;
  background:linear-gradient(160deg, color-mix(in srgb,var(--mc) 28%,transparent), color-mix(in srgb,var(--mc) 10%,transparent));
  border:.5px solid color-mix(in srgb,var(--mc) 40%,transparent);
  box-shadow:0 0 26px color-mix(in srgb,var(--mc) 30%,transparent)}
.shead h2{font-size:clamp(24px,3.4vw,40px);font-weight:800;letter-spacing:-.02em;line-height:1.1;color:var(--ink)}
.shead .rt{text-align:right;color:var(--faint);font-size:12px;letter-spacing:.02em}
.shead .rt b{display:block;color:var(--muted);font-size:14px;font-weight:700;letter-spacing:0;font-family:var(--mono);font-feature-settings:'tnum'}

.mgrid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:28px}
.mcard{background:var(--glass);backdrop-filter:saturate(180%) blur(20px);-webkit-backdrop-filter:saturate(180%) blur(20px);
  border:.5px solid var(--border);border-radius:var(--r);padding:24px;position:relative;overflow:hidden;box-shadow:var(--shadow)}
.mcard::before{content:"";position:absolute;left:0;right:0;top:0;height:1px;background:var(--hairline)}
.mcard .ic{font-size:22px;margin-bottom:14px}
.mcard .n{font-family:var(--mono);font-feature-settings:'tnum';font-size:clamp(30px,4.2vw,44px);font-weight:700;line-height:1;color:var(--ink)}
.mcard .l{color:var(--muted);font-size:13px;margin-top:8px;font-weight:500}
.mcard.brand .n{color:var(--brand)} .mcard.cyan .n{color:var(--brand2)}
.mcard.violet .n{color:var(--brand2)} .mcard.amber .n{color:var(--amber)}

.note{margin-top:24px;background:var(--glass);backdrop-filter:saturate(180%) blur(20px);-webkit-backdrop-filter:saturate(180%) blur(20px);
  border:.5px solid var(--border);border-left:3px solid var(--brand);
  border-radius:var(--r-sm);padding:18px 22px;color:var(--muted);font-size:16px;line-height:1.6;box-shadow:var(--shadow)}
.note b{color:var(--ink);font-weight:600}

.gprog{flex:none;position:relative;margin-bottom:22px;padding:18px 22px;border-radius:var(--r-md);overflow:hidden;
  background:var(--glass);backdrop-filter:saturate(180%) blur(20px);-webkit-backdrop-filter:saturate(180%) blur(20px);
  border:.5px solid var(--border);box-shadow:var(--shadow)}
.gprog::after{content:"";position:absolute;inset:0;pointer-events:none;
  background:radial-gradient(130% 100% at 0% 0%, color-mix(in srgb,var(--brand) 14%,transparent), transparent 60%)}
.gprog-top{position:relative;display:flex;align-items:baseline;justify-content:space-between;gap:14px;margin-bottom:12px}
.gprog-label{font-size:12px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);font-weight:700}
.gprog-count{font-family:var(--mono);font-feature-settings:'tnum';font-size:14px;color:var(--faint)}
.gprog-count b{color:var(--ink);font-weight:700}
.gprog-track{position:relative;height:10px;border-radius:9999px;overflow:hidden;background:var(--track2)}
.gprog-track i{display:block;height:100%;width:0%;border-radius:9999px;
  background:linear-gradient(90deg,var(--brand),var(--brand2));
  box-shadow:0 0 18px color-mix(in srgb,var(--brand) 55%,transparent);
  transition:width .55s var(--ease-spring)}
.modgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:16px}
.modtile{--mc:var(--brand);background:var(--glass);backdrop-filter:saturate(180%) blur(20px);-webkit-backdrop-filter:saturate(180%) blur(20px);
  border:.5px solid var(--border);border-radius:var(--r);padding:20px 20px 16px;cursor:pointer;
  transition:transform .3s var(--ease-spring), box-shadow .3s var(--ease), border-color .3s var(--ease);
  position:relative;overflow:hidden;display:flex;flex-direction:column;min-height:172px;box-shadow:var(--shadow)}
.modtile::before{content:"";position:absolute;left:0;right:0;top:0;height:1px;background:var(--hairline)}
.modtile::after{content:"";position:absolute;width:150px;height:150px;border-radius:50%;right:-55px;top:-55px;
  background:radial-gradient(circle, color-mix(in srgb, var(--mc) 18%, transparent), transparent 70%);
  opacity:.6;transition:.3s;pointer-events:none}
.modtile:hover{transform:translateY(-6px) scale(1.015);border-color:color-mix(in srgb, var(--mc) 55%, transparent);
  box-shadow:var(--shadow-hover), 0 0 36px color-mix(in srgb, var(--mc) 32%, transparent)}
.modtile:hover::after{opacity:1;transform:scale(1.25)}
.mt-bar{position:absolute;left:0;top:0;bottom:0;width:4px;background:linear-gradient(var(--mc),color-mix(in srgb,var(--mc) 50%,transparent))}
.mt-head{display:flex;align-items:center;justify-content:space-between;gap:10px}
.mt-badge{display:grid;place-items:center;min-width:38px;height:38px;padding:0 10px;border-radius:11px;
  font-family:var(--mono);font-feature-settings:'tnum';font-size:15px;font-weight:700;color:var(--mc);
  background:color-mix(in srgb, var(--mc) 12%, transparent);border:.5px solid color-mix(in srgb, var(--mc) 30%, transparent)}
.mt-ic{font-size:22px;line-height:1;margin-left:auto;margin-right:10px;filter:drop-shadow(0 0 10px color-mix(in srgb,var(--mc) 35%,transparent))}
.mod-svg{display:block;object-fit:contain;width:60%;height:60%;transition:filter .3s var(--ease)}
.mt-ic .mod-svg{width:24px;height:24px}
/* En modo claro los iconos son blancos → se recolorean a azul oscuro para que se vean */
:root[data-theme="light"] .mod-svg{
  filter:brightness(0) saturate(100%) invert(18%) sepia(28%) saturate(900%) hue-rotate(176deg) brightness(94%) contrast(92%);
}
.mt-count{font-size:12px;color:var(--muted)}
.mt-count b{font-family:var(--mono);font-feature-settings:'tnum';font-size:18px;font-weight:700;color:var(--ink);margin-right:3px}
.modtile h3{font-size:16px;font-weight:600;margin-top:15px;line-height:1.28;flex:1;color:var(--ink)}
.mt-track{height:6px;border-radius:9999px;background:var(--track);overflow:hidden;margin-top:12px}
.mt-track i{display:block;height:100%;width:0;border-radius:9999px;
  background:linear-gradient(90deg,var(--mc),color-mix(in srgb,var(--mc) 55%,var(--brand2)));
  transition:width .45s var(--ease-spring)}
.mt-foot{display:flex;align-items:center;justify-content:space-between;margin-top:11px;
  font-size:11px;font-weight:600;letter-spacing:.02em;color:var(--faint);transition:.25s}
.modtile:hover .mt-foot{color:var(--mc)}
.mt-arrow{transition:transform .25s var(--ease)}
.modtile:hover .mt-arrow{transform:translateX(4px)}
/* Estado: módulo totalmente revisado */
.modtile.done{border-color:color-mix(in srgb,var(--green) 45%,transparent)}
.modtile.done .mt-track i{background:linear-gradient(90deg,var(--green),#30D158)}
.modtile.done .mt-badge{color:var(--green);background:color-mix(in srgb,var(--green) 18%,transparent);border-color:color-mix(in srgb,var(--green) 45%,transparent)}
.modtile.done .mt-bar{background:var(--green)}
.modtile.done .mt-prog{color:var(--green)}
.modtile.done .mt-prog::after{content:" ✓";font-weight:700}

.mod-body{display:grid;grid-template-columns:minmax(380px,1.15fr) 1fr;gap:24px;flex:1;min-height:0}
.mod-side{display:flex;flex-direction:column;gap:16px;min-height:0}
.ctx{background:var(--glass);backdrop-filter:saturate(180%) blur(20px);-webkit-backdrop-filter:saturate(180%) blur(20px);
  border:.5px solid var(--border);border-radius:var(--r);padding:24px;position:relative;overflow:hidden;box-shadow:var(--shadow)}
.ctx::before{content:"";position:absolute;left:0;right:0;top:0;height:1px;background:var(--hairline)}
.ctx .lbl{font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--brand);font-weight:600;margin-bottom:12px}
.ctx p{font-size:16px;line-height:1.62;color:var(--muted)}
.mini{display:flex;gap:12px}
.mini .b{flex:1;background:var(--glass-thick);border:.5px solid var(--border);border-radius:var(--r-sm);padding:16px;text-align:center}
.mini .b .n{font-family:var(--mono);font-feature-settings:'tnum';font-size:26px;font-weight:700}
.mini .b .l{font-size:10px;color:var(--faint);text-transform:uppercase;letter-spacing:.08em;margin-top:4px;font-weight:600}
.mini .b.c .n{color:var(--brand)} .mini .b.a .n{color:var(--brand2)}

.tablewrap{background:var(--glass);border:.5px solid var(--border);border-radius:var(--r);overflow:auto;min-height:0;box-shadow:var(--shadow)}
table{width:100%;border-collapse:collapse;font-size:13px}
thead th{position:sticky;top:0;background:var(--glass-ultra);backdrop-filter:blur(20px);color:var(--muted);text-align:left;
  padding:13px 16px;font-weight:600;font-size:11px;letter-spacing:.06em;text-transform:uppercase;
  border-bottom:.5px solid var(--border2);z-index:2;white-space:nowrap}
tbody td{padding:12px 16px;border-bottom:.5px solid var(--border);color:var(--ink);vertical-align:top;line-height:1.45}
tbody tr:hover{background:var(--row-hover)}
.req-code{font-family:var(--mono);font-weight:600;color:var(--brand);white-space:nowrap}
.qtext{max-width:680px}
.sub{color:var(--faint);font-size:12px}

/* ---------- Req tabs + card ---------- */
.reqpanel{display:flex;flex-direction:column;gap:14px;min-height:0;
  background:var(--glass);backdrop-filter:saturate(180%) blur(20px);-webkit-backdrop-filter:saturate(180%) blur(20px);
  border:.5px solid var(--border);border-radius:var(--r);padding:20px;box-shadow:var(--shadow);position:relative}
.reqpanel::before{content:"";position:absolute;left:0;right:0;top:0;height:1px;background:var(--hairline)}
.reqpanel-h{flex:0 0 auto;display:flex;flex-direction:column;gap:12px}
.rp-title{font-size:11px;letter-spacing:.06em;text-transform:uppercase;color:var(--muted);font-weight:600}
.rp-prog-lbl{display:flex;justify-content:space-between;font-size:11px;color:var(--muted);margin-bottom:6px;font-weight:500}
.rp-prog-lbl span:last-child{font-family:var(--mono);font-feature-settings:'tnum';font-weight:700;color:var(--ink)}
.rp-track{height:6px;border-radius:9999px;background:var(--track);overflow:hidden}
.rp-track i{display:block;height:100%;width:0;border-radius:9999px;
  background:linear-gradient(90deg,var(--brand),var(--brand2));transition:width .45s var(--ease-spring)}
.reqpanel.done .rp-track i{background:linear-gradient(90deg,var(--green),#30D158)}
.reqpanel.done .rp-prog-lbl span:last-child{color:var(--green)}
.reqtabs{display:flex;flex-direction:column;gap:16px;flex:1;overflow-y:auto;padding-right:6px}
.reqtabs::-webkit-scrollbar{width:7px}
.reqgroup{display:flex;flex-direction:column;gap:9px}
.reqgroup-h{display:flex;align-items:center;gap:9px;font-size:11px;font-weight:600;letter-spacing:.06em;
  text-transform:uppercase;color:var(--muted)}
.reqgroup-h .rg-n{display:grid;place-items:center;width:20px;height:20px;border-radius:6px;font-family:var(--mono);
  font-size:11px;font-weight:700;color:var(--brand);background:color-mix(in srgb,var(--brand) 12%,transparent);border:.5px solid color-mix(in srgb,var(--brand) 30%,transparent)}
.reqgroup-h .rg-c{margin-left:auto;color:var(--muted);background:var(--chip);border:.5px solid var(--border);
  border-radius:9999px;padding:2px 10px;font-size:10px;letter-spacing:.5px;font-family:var(--mono);font-weight:600}
.reqgroup-b{display:flex;flex-wrap:wrap;gap:9px;padding-left:29px}
.reqtab{flex:0 0 auto;display:inline-flex;align-items:center;gap:8px;font-family:var(--ui);font-weight:600;font-size:13px;color:var(--muted);
  padding:9px 16px;border:.5px solid var(--border2);border-radius:9999px;background:var(--glass-thick);
  cursor:pointer;white-space:nowrap;transition:all .2s var(--ease)}
.reqtab:hover{color:var(--ink);border-color:color-mix(in srgb,var(--brand) 55%,transparent);background:var(--glass-hover);transform:translateY(-1px);box-shadow:var(--shadow)}
.reqtab.viewed{color:var(--ink);border-color:color-mix(in srgb,var(--green) 45%,transparent)}
.reqtab.active,.reqtab.active.viewed{color:#fff;background:linear-gradient(135deg,#0064d6,var(--brand2));
  border-color:transparent;box-shadow:0 6px 18px rgba(0,122,255,.35)}
.reqcheck{width:17px;height:17px;flex:0 0 auto;border-radius:5px;border:1.5px solid var(--faint);
  display:grid;place-items:center;font-size:11px;line-height:1;color:transparent;transition:.15s var(--ease)}
.reqcheck::before{content:"✓"}
.reqtab.viewed .reqcheck{background:var(--green);border-color:var(--green);color:#fff}
.reqtab.active .reqcheck{background:transparent;border-color:rgba(255,255,255,.85);color:transparent}
.reqtab.active.viewed .reqcheck{background:#fff;border-color:#fff;color:#0064d6}

.reqcard{background:var(--glass);backdrop-filter:saturate(180%) blur(20px);-webkit-backdrop-filter:saturate(180%) blur(20px);
  border:.5px solid var(--border);border-radius:var(--r);padding:clamp(26px,3vw,40px);overflow:auto;min-height:0;flex:1;
  display:flex;flex-direction:column;justify-content:center;box-shadow:var(--shadow);position:relative}
.reqcard::before{content:"";position:absolute;left:0;right:0;top:0;height:1px;background:var(--hairline)}
.reqcard-empty{text-align:center;color:var(--faint);margin:auto;max-width:38ch}
.reqcard-empty .ce-ic{font-size:38px;margin-bottom:14px;opacity:.7}
.reqcard-empty p{font-size:15px;line-height:1.6}
.reqcard-empty b{color:var(--muted)}
.reqcard-body{display:flex;flex-direction:column;justify-content:flex-start}
.rc-tag{display:inline-block;font-size:10px;letter-spacing:.5px;text-transform:uppercase;color:var(--brand);
  font-family:var(--mono);font-weight:600;margin-bottom:14px;width:fit-content;
  padding:3px 10px;border-radius:9999px;background:color-mix(in srgb,var(--brand) 10%,transparent);border:.5px solid color-mix(in srgb,var(--brand) 28%,transparent)}
.rc-code{font-family:var(--mono);font-feature-settings:'tnum';font-size:clamp(20px,2.4vw,30px);font-weight:700;color:var(--brand);margin-bottom:18px}
.rc-desc{font-size:clamp(15px,1.6vw,19px);line-height:1.6;color:var(--ink);font-weight:400}
.rc-meta{margin-top:24px;display:flex;flex-direction:column;gap:10px}
.rc-meta .row{display:flex;gap:10px;align-items:baseline;font-size:14px}
.rc-meta .k{color:var(--faint);text-transform:uppercase;letter-spacing:.06em;font-size:10px;min-width:130px;font-weight:600}
.rc-meta .v{color:var(--muted);line-height:1.5}

.close{justify-content:center;align-items:flex-start}
.close h2{font-size:clamp(32px,5vw,56px);font-weight:800;letter-spacing:-.02em;max-width:18ch;color:var(--ink)}
.close .grad{background:linear-gradient(100deg,var(--brand),var(--brand2));-webkit-background-clip:text;background-clip:text;color:transparent}
.close p{margin-top:22px;font-size:18px;color:var(--muted);max-width:60ch;line-height:1.6;font-weight:400}
.close .tags{margin-top:36px;display:flex;gap:12px;flex-wrap:wrap}
.close .tag{padding:9px 18px;border:.5px solid var(--border);border-radius:9999px;color:var(--muted);font-size:13px;font-weight:500;
  background:var(--glass);backdrop-filter:saturate(180%) blur(20px);box-shadow:var(--shadow)}

.chrome{position:fixed;left:0;right:0;bottom:0;display:flex;align-items:center;justify-content:flex-end;
  padding:16px clamp(20px,4vw,48px);z-index:50;pointer-events:none}
.chrome>*{pointer-events:auto}
.nav{display:flex;align-items:center;gap:12px}
.nav button{width:40px;height:40px;border-radius:12px;border:.5px solid var(--border);
  background:var(--glass);backdrop-filter:saturate(180%) blur(20px);-webkit-backdrop-filter:saturate(180%) blur(20px);
  color:var(--ink);font-size:18px;cursor:pointer;transition:transform .2s var(--ease),background .2s;display:grid;place-items:center;box-shadow:var(--shadow)}
.nav button:hover{background:var(--glass-hover);transform:scale(1.08)}
.nav button:active{transform:scale(.97)}
.nav .count{font-family:var(--mono);font-feature-settings:'tnum';font-size:13px;color:var(--muted);min-width:62px;text-align:center}
.progress{position:fixed;top:0;left:0;height:3px;background:linear-gradient(90deg,var(--brand),var(--brand2));z-index:60;transition:width .4s var(--ease)}

.dots{position:fixed;right:18px;top:50%;transform:translateY(-50%);display:flex;flex-direction:column;gap:9px;z-index:50}
.dots button{width:9px;height:9px;border-radius:50%;border:none;background:var(--dotbg);cursor:pointer;transition:.2s var(--ease);padding:0}
.dots button.on{background:var(--brand);transform:scale(1.4)}
.dots button:hover{background:var(--muted)}

.hint{position:fixed;bottom:70px;left:50%;transform:translateX(-50%);color:var(--faint);font-size:12px;
  letter-spacing:.02em;z-index:40;opacity:.85;transition:opacity .6s}
.hint.hide{opacity:0}
kbd{background:var(--kbd);border:.5px solid var(--border2);border-radius:5px;padding:2px 7px;font-family:var(--mono);font-size:11px;color:var(--muted)}

::-webkit-scrollbar{width:10px;height:10px}
::-webkit-scrollbar-thumb{background:var(--scroll);border-radius:10px}
::-webkit-scrollbar-track{background:transparent}

@media(max-width:900px){
  .mgrid{grid-template-columns:repeat(2,1fr)}
  .mod-body{grid-template-columns:1fr;overflow-y:auto}
  .dots{display:none}
}
/* ---- Animaciones de entrada del contenido ---- */
@keyframes rise{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:none}}
.slide.active>*{animation:rise .55s var(--ease) both}
.slide.active>*:nth-child(1){animation-delay:.04s}
.slide.active>*:nth-child(2){animation-delay:.12s}
.slide.active>*:nth-child(3){animation-delay:.20s}
.slide.active>*:nth-child(4){animation-delay:.28s}
.slide.active>*:nth-child(5){animation-delay:.36s}
.slide.active>*:nth-child(6){animation-delay:.44s}
.modgrid .modtile{animation:rise .5s var(--ease) both}
.slide.active .modgrid .modtile:nth-child(n){animation-delay:calc(.04s * var(--idx, 0))}

/* ---- Shimmer en barras de progreso ---- */
.rp-track i,.mt-track i{position:relative;overflow:hidden}
.rp-track i::after,.mt-track i::after{content:"";position:absolute;inset:0;
  background:linear-gradient(90deg,transparent,var(--shimmer),transparent);
  transform:translateX(-120%);animation:shimmer 2.6s var(--ease) infinite}
@keyframes shimmer{0%{transform:translateX(-120%)}60%,100%{transform:translateX(120%)}}

/* ---- Glow del tab seleccionado ---- */
.reqtab.active,.reqtab.active.viewed{box-shadow:0 6px 20px rgba(10,132,255,.5), 0 0 24px rgba(94,92,230,.4)}
/* ---- Glow en métricas de portada ---- */
.cover .meta div .n{text-shadow:0 0 26px rgba(10,132,255,.45)}
.mcard:hover{border-color:color-mix(in srgb,var(--brand) 40%,transparent);box-shadow:var(--shadow-hover),0 0 30px rgba(10,132,255,.18);transition:.3s var(--ease)}

@media(prefers-reduced-motion:reduce){*{animation-duration:.01ms!important;transition-duration:.01ms!important}
  .aurora .orb{animation:none}.cover h1 .grad{animation:none}}
</style>
</head>
<body>
<div class="aurora"><span class="orb o1"></span><span class="orb o2"></span><span class="orb o3"></span><span class="sphere s1"></span><span class="sphere s2"></span></div>
<div class="progress" id="progress"></div>
<div class="deck" id="deck"></div>
<div class="dots" id="dots"></div>
<div class="hint" id="hint">Usa <kbd>←</kbd> <kbd>→</kbd> o las flechas · <kbd>F</kbd> pantalla completa</div>
<div class="chrome">
  <div class="nav">
    <button id="theme" aria-label="Cambiar tema" title="Modo claro / oscuro">🌙</button>
    <button id="prev" aria-label="Anterior">‹</button>
    <span class="count" id="count">1 / 1</span>
    <button id="next" aria-label="Siguiente">›</button>
  </div>
</div>

<script>
const DATA = {"resumen": [{"modulo": "01. Login", "total": 2, "contexto": "El acceso inicial queda cubierto mediante controles de autenticación que permiten validar el ingreso de los usuarios y asegurar que la sesión se habilite bajo condiciones controladas. Con esta capacidad se refuerza la seguridad de entrada y se atienden los requerimientos asociados a identificación, validación y acceso al SGDEA. En esta versión se incluyen 2 requerimiento(s), contemplados para la cobertura integral del módulo sin aplicar filtro por estado.", "incluidos": "4.5 – Módulo de Administración – REQ 16: ¿Permiten los usuarios del sistema sincronizarse con el directorio activo de la entidad?\n4.5 – Módulo de Administración – REQ 19: ¿Permite bloquear el sistema a un usuario tras tres intentos fallidos simultáneos de contraseña?", "agrupacion": "4.5 – Módulo de Administración\nREQ 16, 19"}, {"modulo": "02. Roles", "total": 18, "contexto": "La administración de roles permite estructurar perfiles, permisos y niveles de acceso de acuerdo con las responsabilidades de cada usuario. Desde esta capacidad se soporta la segregación funcional, la asignación controlada de autorizaciones y la trazabilidad de acciones sensibles dentro de la operación. En esta versión se incluyen 18 requerimiento(s), contemplados para la cobertura integral del módulo sin aplicar filtro por estado.", "incluidos": "4.7 – Tablas De Control De Acceso – REQ 9: ¿Permite a un usuario autorizado explorar y examinar los roles y sus metadatos?\n4.5 – Módulo de Administración – REQ 12: ¿Permite que solo un usuario autorizado modifique metadatos y valores de grupos de usuarios, limitándose a los especificados en el modelo de metadatos como variables?\n4.7 – Tablas De Control De Acceso – REQ 4: ¿Permite crear grupos de roles y perfiles parametrizables a los metadatos de los grupos?\n4.6 – Módulo Flujo de Trabajo – REQ 17: ¿Permite a un usuario autorizado configurar roles que tengan acceso a documentos en fase de elaboración, conforme a los controles de acceso?\n4.7 – Tablas De Control De Acceso – REQ 12: ¿Permite listar las acciones permitidas a un usuario según su rol y la tabla de control de accesos?\n4.7 – Tablas De Control De Acceso – REQ 11: ¿Permite a un usuario autorizado listar las distintas listas de control de acceso, junto con los roles asociados a cada una?\n4.6 – Módulo Flujo de Trabajo – REQ 64: ¿Permite garantizar que todos los controles de acceso se mantengan en todo momento?\n4.7 – Tablas De Control De Acceso – REQ 6: ¿Permite la creación de nuevos roles, incluyendo la configuración de sus metadatos?\n4.7 – Tablas De Control De Acceso – REQ 7: ¿La modificación de metadatos y valores de un rol solo debe llevarse a cabo por un usuario autorizado, limitándose a los metadatos definidos como variables en el modelo correspondiente?\n4.7 – Tablas De Control De Acceso – REQ 13: ¿Permite generar permisos para el acceso a la información a los usuarios de la entidad y configurar los niveles de permisos?\n4.7 – Tablas De Control De Acceso – REQ 10: ¿Permite la creación y ajuste de listas de control de acceso que especifiquen los roles autorizados para un servicio determinado?\n4.8 – Prestamos – REQ 3: ¿Permite asignar los permisos para el préstamo de expedientes o documentos electrónicos?\n4.5 – Módulo de Administración – REQ 10: ¿Permite a un usuario autorizado listar los usuarios pertenecientes a un grupo?\n4.7 – Tablas De Control De Acceso – REQ 14: ¿Permite generar Tablas de Control de Acceso de cada entidad según los roles y permisos asignados?\n4.5 – Módulo de Administración – REQ 11: ¿Permite la adición de metadatos a los grupos de usuarios?\n4.5 – Módulo de Administración – REQ 13: ¿Permite la eliminación de grupos, acción que solo puede realizar un usuario autorizado?\n4.7 – Tablas De Control De Acceso – REQ 8: Aunque forme parte de una lista de control de acceso, ¿permite la eliminación de roles?\n4.5 – Módulo de Administración – REQ 9: ¿Permite la conformación de grupos de usuarios, registrando esta acción en el historial de eventos?", "agrupacion": "4.7 – Tablas De Control De Acceso\nREQ 9, 4, 12, 11, 6, 7, 13, 10, 14, 8\n\n4.5 – Módulo de Administración\nREQ 12, 10, 11, 13, 9\n\n4.6 – Módulo Flujo de Trabajo\nREQ 17, 64\n\n4.8 – Prestamos\nREQ 3"}, {"modulo": "03. Usuarios", "total": 7, "contexto": "La gestión de usuarios centraliza la creación, administración y control de las cuentas que interactúan con la plataforma. Esto permite mantener usuarios identificables, con permisos acordes a su rol, historial de acciones y condiciones de uso alineadas con los procesos de administración del sistema. En esta versión se incluyen 7 requerimiento(s), contemplados para la cobertura integral del módulo sin aplicar filtro por estado.", "incluidos": "4.5 – Módulo de Administración – REQ 14: ¿Permite a un usuario autorizado consultar y navegar los usuarios y grupos, junto con sus respectivos metadatos?\n4.5 – Módulo de Administración – REQ 6: ¿Permite la creación de nuevos usuarios, así como la configuración de sus metadatos?\n4.5 – Módulo de Administración – REQ 17: ¿Permite a un usuario autorizado inactivar a otros usuarios por motivos de vacaciones, estableciendo fechas de inicio y finalización?\n4.5 – Módulo de Administración – REQ 18: ¿Permite asignar roles temporales con la etiqueta \"encargo\", configurando fechas de inicio y finalización?\n4.5 – Módulo de Administración – REQ 8: ¿Permite la eliminación de usuarios que nunca hayan utilizado el sistema?\n4.11 – Búsqueda y Reportes – REQ 9: ¿Permite que los informes generados por un usuario queden registrados en el Historial de eventos de la entidad de usuario?\n4.5 – Módulo de Administración – REQ 4: ¿Permite mantener pistas de auditoría de las acciones realizadas por cada uno de los usuarios que ingresan al sistema?", "agrupacion": "4.5 – Módulo de Administración\nREQ 14, 6, 17, 18, 8, 4\n\n4.11 – Búsqueda y Reportes\nREQ 9"}, {"modulo": "04. Historial de Eventos", "total": 16, "contexto": "La trazabilidad operativa se fortalece mediante el registro y consulta de eventos generados durante el uso del sistema. Esta funcionalidad facilita el seguimiento de acciones, consultas, cambios y actividades relevantes, aportando evidencia para auditoría, control interno y revisión histórica. En esta versión se incluyen 16 requerimiento(s), contemplados para la cobertura integral del módulo sin aplicar filtro por estado.", "incluidos": "4.12 – Otros – REQ 11: Permite la parametrización y/o configuración en la auditoría, deberá mínimo registrar y presentar los siguientes campos:\n\nFecha/Hora  (hh:mm:ss): Describe día y hora de entrada.\nID Sesión: Número automático interno del ID del inicio de sesión.\nNombre de usuario: Usuario que inicio login en aplicativo.\nUnidad: Nombre de la unidad predeterminada.\nAcción: Modificación, Adición o Eliminación.\nRegistro ID: Nombre de quien realizo la acción.\nTipo de documento: Nombre del documento que se le realizo la acción.\nCampo/Proceso referenciado: Nombre del proceso y el campo afectado.\nValor anterior: Valor del antiguo del campo.\nValor nuevo: Valor nuevo afectado en el tipo de documento.\nObservaciones: nombre de quien ejecutó la acción\n4.12 – Otros – REQ 10: ¿Permite la parametrización y/o configuración al administrador del sistema para consultar las sesiones de usuario. Deberá mínimo registrar y presentar los siguientes campos:\n\nNúmero de sesión.\nFecha/Hora (hh:mm:ss). (Ingreso y Salida)\nID Sesión (identificador inequívoco o único)\nUsuario: Nombre del usuario que inició y finalizó sesión en el aplicativo.\n4.12 – Otros – REQ 12: ¿Permite la parametrización y/o configuración al administrador del sistema consultar la información de la auditoría de uso de la aplicación?\n4.12 – Otros – REQ 9: ¿Permite la parametrización y/o configuración para registrar logs de las interacciones de los usuarios con el sistema de administración, para temas de auditoría?\n4.12 – Otros – REQ 8: ¿Permite configurar la trazabilidad y pista de auditoría interna de documentos (correspondencia y aquellos de creación nativo digital)?\n4.12 – Otros – REQ 7: ¿Permite registrar la trazabilidad de distribución y gestión de cada documento según sus particularidades: p.e. para documentos internos: Enviado, Recibido por dependencia, etc. y para documentos con destino externo: Enviado físico / Enviado electrónico y la data correspondiente?\n4.12 – Otros – REQ 13: ¿Permite ver el detalle del registro de la auditoría seleccionada?\n4.12 – Otros – REQ 18: ¿Permite la parametrización y/o configuración para la consulta de logs de auditoría facilitando establecer criterios de búsqueda basado en los campos de la base de datos?\n4.5 – Módulo de Administración – REQ 46: ¿Permite mantener una historia inalterable de modificaciones (pistas de auditoría) que se realizan en los tiempos de retención y disposición, incluida la fecha del cambio o eliminación y el usuario que lo registra?\n4.9 – Metadatos – REQ 13: ¿Permite mantener los metadatos de objetos digitales eliminados, a menos que el usuario opte por eliminarlos, quedando dicha acción registrada en el historial de eventos?\n4.12 – Otros – REQ 14: ¿Permite la parametrización y/o configuración para consultar la trazabilidad de los documentos electrónicos en el cuadro de clasificación documental mostrando información como mínimo de qué, quién, cuándo y cómo realizó acciones en el mismo?\n4.12 – Otros – REQ 15: ¿Permite registrar en la pista de auditoría, cuando se realice la reubicación de una carpeta (o conjunto de carpetas) o documento?\n4.12 – Otros – REQ 16: ¿Permite generar un log de manera que todas las acciones efectuadas sobre el expediente queden registradas en un historial de eventos que puede ser consultado por usuarios que tengan acceso al expediente electrónico?\n4.12 – Otros – REQ 17: ¿Permite la parametrización y/o configuración para generar un reporte del estado de la transferencia o exportación realizada y guardar datos de la acción realizada en las pistas de auditoría?\n4.6 – Módulo Flujo de Trabajo – REQ 45: ¿Permite registrar toda la creación y cambios en los flujos de trabajo en el Historial de eventos?\n4.12 – Otros – REQ 19: ¿Permite la parametrización y/o configuración para permitir la descarga del log de auditoría facilitando establecer criterios de búsqueda basado en los campos de la base de datos?", "agrupacion": "4.12 – Otros\nREQ 11, 10, 12, 9, 8, 7, 13, 18, 14, 15, 16, 17, 19\n\n4.5 – Módulo de Administración\nREQ 46\n\n4.9 – Metadatos\nREQ 13\n\n4.6 – Módulo Flujo de Trabajo\nREQ 45"}, {"modulo": "05. Configuración", "total": 31, "contexto": "La parametrización funcional habilita la adaptación de reglas, catálogos, calendarios, estados, servicios y valores maestros requeridos por la operación. A través de estas configuraciones se soporta que los procesos del SGDEA respondan a criterios administrables, ajustables y consistentes con las necesidades de negocio. En esta versión se incluyen 31 requerimiento(s), contemplados para la cobertura integral del módulo sin aplicar filtro por estado.", "incluidos": "4.1 – Administración de Expedientes – REQ 14: ¿Permite que un usuario autorizado realice modificaciones en cualquiera de sus \"Metadatos contextuales\"?\n4.9 – Metadatos – REQ 5: ¿Permite establecer elementos mínimos requeridos para cada metadato parametrizable y agregar u ocultar elementos?\n4.9 – Metadatos – REQ 1: ¿Permite configurar el esquema de metadatos propio de la entidad?\n4.9 – Metadatos – REQ 7: ¿Permite la parametrización de los metadatos y sus elementos, incluyendo la adición de descripciones?\n4.9 – Metadatos – REQ 11: ¿Permite ofrecer a usuarios autorizados la capacidad de crear nuevos metadatos contextuales según sea necesario?\n4.9 – Metadatos – REQ 12: ¿Permite la asociación de metadatos a un objeto digital específico?\n4.9 – Metadatos – REQ 17: ¿Permite garantizar que los metadatos tengan un tipo de dato configurado (numérico, texto, booleano, carácter, etc.), mostrando un mensaje de error orientado al usuario en caso de ingreso de datos inválidos?\n4.9 – Metadatos – REQ 2: ¿Permite la parametrización de varios niveles de metadatos asociados a una entidad?\n4.10 – Módulo de Manejo Físico de Documentos – REQ 10: ¿Permite crear, capturar y gestionar metadatos específicos para documentos físicos, como dimensiones de un plano o formato de una cinta de video?\n4.9 – Metadatos – REQ 15: ¿Permite la desactivación de un metadato contextual, impidiendo su uso en nuevos objetos, pero manteniendo la información en aquellos objetos previamente asociados?\n4.9 – Metadatos – REQ 14: ¿Permite la eliminación de metadatos contextuales que nunca hayan sido utilizados?\n4.9 – Metadatos – REQ 4: ¿Cuenta con un diccionario o servicio de metadatos?\n4.5 – Módulo de Administración – REQ 20: ¿Permite la parametrización y configuración del registro de días festivos por anualidad?\n4.12 – Otros – REQ 5: ¿Permite la creación, modificación, carga masiva e individual de registros DANE de departamentos, municipios y centros poblados\n4.9 – Metadatos – REQ 8: ¿Permite aplicar manual o automáticamente plantillas activas a las entidades del sistema?\n4.4 – Radicación – REQ 22: ¿Permite a un usuario autorizado parametrizar la estructura del código para cada tipo de comunicación?\n4.4 – Radicación – REQ 4: ¿Permite estructurar el número consecutivo para la radicación de las comunicaciones oficiales (externas e internas)?\n\nNota: El número de radicado debe ser único para cada tipo de comunicación y documento, un consecutivo propio\n4.4 – Radicación – REQ 21: ¿Permite asignar un código único y consecutivo a cada documento radicado, con la posibilidad de reiniciarse al iniciar una nueva vigencia?\n4.4 – Radicación – REQ 20: ¿Permite el reinicio automático de los consecutivos cada año nuevo?\n4.4 – Radicación – REQ 33: ¿Genera alertas vía plataforma y correo electrónico días antes del vencimiento de términos para las comunicaciones en gestión?\n4.5 – Módulo de Administración – REQ 33: ¿Permite configurar alertas de vencimiento próximo a los roles indicados por el Banco:\n\n* Responsable del trámite\n* jefe inmediato\n* Designado por Atención al cliente, etc.\n4.5 – Módulo de Administración – REQ 15: ¿Permite a un usuario autorizado configurar los tiempos de espera de inactividad para desconexión (time-out) de los usuarios?\n4.5 – Módulo de Administración – REQ 21: ¿Permite la parametrización y configuración de Estados de trámite de comunicaciones oficiales y otros documentos?\n4.8 – Prestamos – REQ 4: ¿Permite la configuración de los tiempos de vencimiento, la aceptación, rechazo o renovación de los préstamos y las consultas?\n4.1 – Administración de Expedientes – REQ 12: ¿Permite la gestión y administración de los metadatos establecidos en el esquema correspondiente a los documentos de archivo?\n4.5 – Módulo de Administración – REQ 27: ¿Permite configurar servicios de gestión prioritaria o diferencial (Derechos de petición, tutelas y los demás indicados por el Banco)?\n4.9 – Metadatos – REQ 3: ¿Permite que los metadatos y entidades sean predeterminados por el sistema?\n4.5 – Módulo de Administración – REQ 29: ¿Permite la configuración para el cargue de documentos digitales anexos a radicaciones - contemplar grandes tamaños de fichero?\n4.1 – Administración de Expedientes – REQ 13: ¿Permite crear tomos por expedientes, utilizando parámetros de tamaño configurados por un usuario autorizado?\n4.5 – Módulo de Administración – REQ 23: ¿Permite configurar los servicios de mensajería externa y Courier?\n4.5 – Módulo de Administración – REQ 25: ¿Permite configurar servicios de prueba de entrega en correo electrónico certificado?", "agrupacion": "4.1 – Administración de Expedientes\nREQ 14, 12, 13\n\n4.9 – Metadatos\nREQ 5, 1, 7, 11, 12, 17, 2, 15, 14, 4, 8, 3\n\n4.10 – Módulo de Manejo Físico de Documentos\nREQ 10\n\n4.5 – Módulo de Administración\nREQ 20, 33, 15, 21, 27, 29, 23, 25\n\n4.12 – Otros\nREQ 5\n\n4.4 – Radicación\nREQ 22, 4, 21, 20, 33\n\n4.8 – Prestamos\nREQ 4"}, {"modulo": "06. Alertas", "total": 3, "contexto": "La gestión de alertas permite advertir eventos, vencimientos o condiciones que requieren atención dentro de los flujos definidos. Esta capacidad contribuye al seguimiento oportuno de trámites y tareas, apoyando la continuidad operativa y la reacción frente a situaciones críticas o pendientes. En esta versión se incluyen 3 requerimiento(s), contemplados para la cobertura integral del módulo sin aplicar filtro por estado.", "incluidos": "4.2 – Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación – REQ 17: ¿Genera alertas cuando un expediente esté próximo a cumplir los tiempos de retención?\n4.6 – Módulo Flujo de Trabajo – REQ 60: ¿Permite notificar a un usuario participante cuando un archivo o registro ha sido recibido en su bandeja de entrada y está pendiente de atención?\n4.6 – Módulo Flujo de Trabajo – REQ 62: None", "agrupacion": "4.2 – Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación\nREQ 17\n\n4.6 – Módulo Flujo de Trabajo\nREQ 60, 62"}, {"modulo": "07. Clasificación Documental", "total": 21, "contexto": "El componente de clasificación documental soporta la organización de la información conforme a instrumentos archivísticos, series, subseries, tipos documentales y metadatos. Con ello se facilita la administración estructurada de documentos y expedientes bajo criterios de clasificación, búsqueda, control y conservación. En esta versión se incluyen 21 requerimiento(s), contemplados para la cobertura integral del módulo sin aplicar filtro por estado.", "incluidos": "4.12 – Otros – REQ 2: ¿Permite la caracterización de tipos documentales por agrupación?\n4.2 – Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación – REQ 6: ¿Permite la inclusión de múltiples versiones del cuadro de clasificación documental?\n4.2 – Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación – REQ 14: ¿Permite a un usuario autorizado explorar las versiones de TRD o TVD en el servicio de retención y disposición, así como examinar sus metadatos?\n4.2 – Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación – REQ 15: ¿Permite a usuarios autorizados reemplazar una versión de TRD o TVD únicamente para expedientes activos, sin eliminar ni destruir la versión anterior?\n4.2 – Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación – REQ 16: ¿Verifica cambios en los tiempos de retención y actualiza automáticamente los expedientes y metadatos si es necesario al cargar una nueva versión de la TRD o la TVD?\n4.9 – Metadatos – REQ 9: ¿Permite asegurar que los datos agregados a una serie, subserie, expediente, documento o cualquier otra entidad del sistema nunca se eliminen mientras la entidad esté activa?\n4.5 – Módulo de Administración – REQ 36: ¿Permite configurar los formularios de descripción de cada una de las agrupaciones documentales vigentes según TRD, de acuerdo con las características o metadatos descriptivos particulares para cada agrupación. Al generarse la creación de un nuevo expediente de cada agrupación, el SGDEA deberá exponer al usuario que adelanta la creación, el formulario específico para diligenciar los campos aplicables a la misma?\n4.2 – Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación – REQ 3: ¿Permite realizar la creación, importación, exportación, parametrización, automatización, administración y versionamiento de TRD?\n4.2 – Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación – REQ 8: ¿Permite a un usuario autorizado añadir nuevos niveles a la estructura del cuadro de clasificación documental?\n4.2 – Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación – REQ 9: ¿Permite a usuarios autorizados eliminar niveles que nunca hayan sido utilizados en la estructura del cuadro de clasificación documental?\n4.2 – Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación – REQ 5: ¿Permite garantizar la herencia de atributos de clases?\n4.2 – Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación – REQ 7: ¿Permite la herencia de metadatos y atributos desde elementos padres hacia elementos hijos?\n4.2 – Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación – REQ 26: ¿Permite a un usuario autorizado modificar la disposición final de una serie y/o subserie?\n4.2 – Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación – REQ 4: ¿Permite garantizar que los documentos producidos y asociados a una TRD mantendrán los criterios de tiempos y de disposición final de la versión correspondiente?\n4.1 – Administración de Expedientes – REQ 45: ¿Permite configurar la creación automática de expedientes por anualidad según disposiciones del BAC en aplicación de TRD\n4.1 – Administración de Expedientes – REQ 42: ¿Permite parametrizar y configurar los servicios de acceso controlado a expediente y documentos en aplicación de las disposiciones definidas en TCA e IICR, así como las excepciones indicadas por el productor de cada expediente / documento?\n4.7 – Tablas De Control De Acceso – REQ 2: ¿Permite crear automáticamente una “Lista de control de acceso” para cada servicio o conjunto de servicios y para cada entidad?\n4.1 – Administración de Expedientes – REQ 17: ¿Permite la inactivación de series y/o subseries, siempre y cuando los expedientes asociados estén cerrados?\n4.1 – Administración de Expedientes – REQ 27: ¿Permite a un usuario autorizado personalizar los criterios de ordenación para cada serie documental?\n4.1 – Administración de Expedientes – REQ 28: ¿Organiza los expedientes según el criterio de ordenación establecido para cada serie?\n4.1 – Administración de Expedientes – REQ 44: ¿Permite configurar los servicios de ordenación y paginación automática de documentos al interior de cada expediente según disposición del rol administrador (por fecha de documento, por fecha de indexación en expediente, por foliación manual u otra)?", "agrupacion": "4.12 – Otros\nREQ 2\n\n4.2 – Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación\nREQ 6, 14, 15, 16, 3, 8, 9, 5, 7, 26, 4\n\n4.9 – Metadatos\nREQ 9\n\n4.5 – Módulo de Administración\nREQ 36\n\n4.1 – Administración de Expedientes\nREQ 45, 42, 17, 27, 28, 44\n\n4.7 – Tablas De Control De Acceso\nREQ 2"}, {"modulo": "08. Flujos de Trabajo", "total": 58, "contexto": "Los flujos de trabajo permiten modelar, ejecutar y controlar rutas operativas, tareas, responsables, formularios, estados y reglas de negocio. Esta cobertura habilita la automatización de procesos documentales, el seguimiento de actividades y la coordinación de interacciones entre usuarios y dependencias. En esta versión se incluyen 58 requerimiento(s), contemplados para la cobertura integral del módulo sin aplicar filtro por estado.", "incluidos": "4.9 – Metadatos – REQ 19: ¿Permite asegurar que los campos de tipo fecha desplieguen un calendario para facilitar y normalizar el ingreso de datos?\n4.9 – Metadatos – REQ 20: ¿Permite la incorporación de diferentes esquemas de metadatos?\n4.4 – Radicación – REQ 32: ¿Permite la configuración de calendarios y contadores de tiempos en días hábiles, horas y minutos laborales, así como días calendario, horas y minutos calendario?\n4.3 – Producción – REQ 12: ¿Permite asociar cada formato y formulario a un proceso, procedimiento y/o trámite?\n4.3 – Producción – REQ 15: ¿Permite la configuración de listas de control de acceso para los formatos y formularios en el sistema?\n4.6 – Módulo Flujo de Trabajo – REQ 1: ¿Permite el sistema mecanismos de simulación para analizar los flujos de trabajo modelados?\n4.6 – Módulo Flujo de Trabajo – REQ 2: ¿Permite parametrizar los accesos, la creación, modificación o control total para usuarios o grupos de usuarios en los flujos de trabajo electrónicos?\n4.6 – Módulo Flujo de Trabajo – REQ 3: ¿Permite garantizar que todos los documentos conserven los vínculos con el flujo de trabajo correspondiente?\n4.6 – Módulo Flujo de Trabajo – REQ 5: ¿Permite contener múltiples versiones de un mismo proceso y/o procedimiento, y así seleccionar la última versión?\n4.6 – Módulo Flujo de Trabajo – REQ 10: ¿Permite la asignación automática de tareas entre los integrantes de un equipo?\n4.6 – Módulo Flujo de Trabajo – REQ 23: ¿Permite que el esquema de numeración de versiones se configure durante la instalación?\n4.6 – Módulo Flujo de Trabajo – REQ 51: ¿Permite la inclusión automática de un documento como archivo en una actividad específica dentro del flujo de trabajo?\n4.3 – Producción – REQ 2: ¿Permite modificar o crear plantillas o formularios dependiendo del trámite requerido?\n4.3 – Producción – REQ 3: ¿Permite y cuenta con la autonomía para la actualización de las plantillas o formularios una vez se haya terminado la implementación?\n4.3 – Producción – REQ 8: ¿Permite la asignación de las Series y Subseries por medio de los flujogramas o diagramas de flujo?\n4.3 – Producción – REQ 10: ¿Permite a un usuario autorizado agregar nuevos formatos y formularios, con validaciones de entrada en los campos según sea necesario?\n4.3 – Producción – REQ 11: ¿Permite la edición de formatos y formularios por parte de usuarios autorizados?\n4.3 – Producción – REQ 13: ¿Permite y dispone de la opción de incorporar listas de control de acceso para los formatos y formularios?\n4.3 – Producción – REQ 14: ¿Permite la parametrización de formatos y/o formularios, con validaciones de entrada en los campos según sea necesario?\n4.4 – Radicación – REQ 2: ¿Permite y contiene campos obligatorios en el sistema que se pueden parametrizar?\n4.5 – Módulo de Administración – REQ 30: ¿Permite el diseño, configuración e implementación de formularios especializados para radicación de PQRSD?\n4.5 – Módulo de Administración – REQ 31: ¿Permite el diseño, configuración e implementación de formularios especializados para el seguimiento al trámite de PQRSD?\n4.6 – Módulo Flujo de Trabajo – REQ 25: ¿Permite alertar al usuario ante conflictos de metadatos entre el servicio de documentos archivados y el servicio colaborativo?\n4.6 – Módulo Flujo de Trabajo – REQ 39: ¿Permite la integración de flujos de trabajo predefinidos según funciones institucionales, asignando automáticamente tareas como la derivación de una tutela al área jurídica?\n4.6 – Módulo Flujo de Trabajo – REQ 40: ¿Permite que los roles de usuarios autorizados definan, utilicen y guarden flujos de trabajo nuevos para casos especiales?\n4.6 – Módulo Flujo de Trabajo – REQ 42: ¿Permite restringir la modificación de flujos de trabajo preprogramados a funciones administrativas o usuarios autorizados?\n4.6 – Módulo Flujo de Trabajo – REQ 43: ¿Permite guardar una copia del flujo de trabajo antes de efectuar cambios y asignar automáticamente un nuevo número de versión?\n4.6 – Módulo Flujo de Trabajo – REQ 44: ¿Impone límites al número de flujos de trabajo que puedan ser definidos y almacenados?\n4.6 – Módulo Flujo de Trabajo – REQ 46: ¿Incluye una interfaz gráfica para que los usuarios administren las funciones relacionadas con la definición, mantenimiento y edición de flujos de trabajo?\n4.6 – Módulo Flujo de Trabajo – REQ 52: ¿Limita el número de actividades (pasos) en cada flujo de trabajo?\n4.6 – Módulo Flujo de Trabajo – REQ 8: ¿Permite realizar la distribución automática de cargas de trabajo entre los miembros del grupo mediante un balanceador de cargas?\n4.6 – Módulo Flujo de Trabajo – REQ 6: ¿Permite garantizar que los documentos de un flujo queden asociados a un mismo expediente de acuerdo con las TRD?\n4.6 – Módulo Flujo de Trabajo – REQ 49: ¿Permite a usuarios autorizados monitorear y gestionar las colas de trabajo?\n4.6 – Módulo Flujo de Trabajo – REQ 50: ¿Posibilita que los usuarios monitoreen el progreso de los flujos de trabajo en los que participan?\n4.6 – Módulo Flujo de Trabajo – REQ 4: ¿Permite visualizar el estado de cada flujo de trabajo electrónico?\n4.6 – Módulo Flujo de Trabajo – REQ 9: ¿Permite a los usuarios monitorear el progreso de los flujos de trabajo iniciados y en los que participan?\n4.5 – Módulo de Administración – REQ 7: ¿Permite que un solo usuario autorizado modifique metadatos y valores, limitándose a aquellos especificados como variables en el modelo de metadatos?\n4.6 – Módulo Flujo de Trabajo – REQ 53: ¿Permite la priorización de tareas y/o actividades en cola?\n4.6 – Módulo Flujo de Trabajo – REQ 54: ¿Permite que el usuario autorizado defina el número máximo de actividades (pasos) a ejecutar en un intervalo de tiempo según el trámite?\n4.6 – Módulo Flujo de Trabajo – REQ 55: ¿Permite parametrizar el tiempo límite para cada actividad (paso) y para el flujo en general, generando reportes y alertas para usuarios autorizados?\n4.6 – Módulo Flujo de Trabajo – REQ 56: ¿Permite a un usuario autorizado configurar y administrar una lista predeterminada de acciones para una actividad (paso) en un flujo de trabajo?\n4.6 – Módulo Flujo de Trabajo – REQ 57: ¿Permite a usuarios autorizados reasignar tareas y/o acciones a un usuario o grupo diferente?\n4.6 – Módulo Flujo de Trabajo – REQ 58: ¿Permite establecer condicionales en los flujos de trabajo según datos de entrada para determinar la dirección del flujo?\n4.6 – Módulo Flujo de Trabajo – REQ 59: ¿Permite a un usuario autorizado suspender temporalmente un flujo para atender otro trabajo y reanudarlo más tarde, incluso después de cerrar sesión en el sistema?\n4.6 – Módulo Flujo de Trabajo – REQ 61: ¿Permite programar recordatorios para acceder a un archivo o registro en una fecha futura, sin exceder la fecha de vencimiento del flujo de trabajo?\n4.6 – Módulo Flujo de Trabajo – REQ 63: ¿Permite la recepción automática de documentos en carpetas específicas para activar flujos de trabajo, según el tipo documental o metadatos?\n4.6 – Módulo Flujo de Trabajo – REQ 65: ¿Permite generar flujos de trabajo en un formato estándar de modelado de workflow como XPDL y WF-XML?\n4.6 – Módulo Flujo de Trabajo – REQ 66: ¿Permite la exportación de flujos de trabajo o partes constituyentes en formato XML-XPDL?\n4.6 – Módulo Flujo de Trabajo – REQ 67: ¿Permite identificar cada trámite como abierto o cerrado?\n4.6 – Módulo Flujo de Trabajo – REQ 69: ¿Permite el cierre automático del expediente al registrar la finalización del trámite por un usuario autorizado, ya sea individual o en lote?\n4.6 – Módulo Flujo de Trabajo – REQ 70: ¿Permite a un usuario autorizado eliminar un flujo de trabajo que nunca ha sido utilizado?\n4.6 – Módulo Flujo de Trabajo – REQ 71: ¿Permite a un usuario autorizado destruir un flujo de trabajo que no esté vigente?\n4.6 – Módulo Flujo de Trabajo – REQ 72: Permite Modelar campos de contenido, metadatos, flujos de aprobación, cargue de anexos, firma y demás servicios asociados a la producción nativa a través de formularios en el SGDEA de los siguientes documentos:\n\n* Oficio: Comunicaciones oficiales de salida\n* Memorando: Comunicaciones oficiales internas\n* Acta\n* Informe\n* Concepto técnico\n* Concepto jurídico\n* Certificado laboral\n* Paz y Salvo\n* Auto\n* Circular interna: Comunicaciones oficiales internas dirigidas a un grupo de destinatarios agrupados por roles\n4.6 – Módulo Flujo de Trabajo – REQ 73: ¿Permite configurar flujos de distribución interna de documentos (correspondencia y aquellos de creación nativo digital) según las particularidades de cada uno?\n4.6 – Módulo Flujo de Trabajo – REQ 74: ¿Permite configurar flujos de distribución interna de documentos individual o masiva, requiriendo respuesta o netamente informativos?\n4.6 – Módulo Flujo de Trabajo – REQ 75: ¿Permite configurar flujo de revisión y aprobación (o devolución, total o parcial) de transferencia primaria por administración del Archivo Central\n4.9 – Metadatos – REQ 10: ¿Permite operar con todos los metadatos definidos en el esquema correspondiente?\n4.9 – Metadatos – REQ 16: ¿Permite mostrar breves descripciones y ejemplos de uso para cada metadato?", "agrupacion": "4.9 – Metadatos\nREQ 19, 20, 10, 16\n\n4.4 – Radicación\nREQ 32, 2\n\n4.3 – Producción\nREQ 12, 15, 2, 3, 8, 10, 11, 13, 14\n\n4.6 – Módulo Flujo de Trabajo\nREQ 1, 2, 3, 5, 10, 23, 51, 25, 39, 40, 42, 43, 44, 46, 52, 8, 6, 49, 50, 4, 9, 53, 54, 55, 56, 57, 58, 59, 61, 63, 65, 66, 67, 69, 70, 71, 72, 73, 74, 75\n\n4.5 – Módulo de Administración\nREQ 30, 31, 7"}, {"modulo": "09. Correspondencia", "total": 64, "contexto": "La correspondencia cubre la recepción, radicación, gestión, distribución y seguimiento de comunicaciones oficiales en diferentes canales. Desde esta funcionalidad se integran controles para captura de documentos, trazabilidad, gestión de respuestas, metadatos, envíos y administración de comunicaciones durante su ciclo operativo. En esta versión se incluyen 64 requerimiento(s), contemplados para la cobertura integral del módulo sin aplicar filtro por estado.", "incluidos": "4.6 – Módulo Flujo de Trabajo – REQ 7: ¿Permite mostrar semáforos que indiquen el cumplimiento de tiempos en cada una de las actividades de un flujo?\n4.3 – Producción – REQ 17: ¿Permite la producción documental a través de formatos de fichero longevos avalados para adelantar procesos de migración en aplicación de estrategia de preservación digital?\n4.5 – Módulo de Administración – REQ 38: ¿Permite configurar la aplicación de procesos internos en el SGDEA de migración de fichero a formatos longevos al cierre del expediente o por demanda, según lo defina el BAC?\n4.6 – Módulo Flujo de Trabajo – REQ 28: ¿Permite autorizar a un usuario a capturar un documento en formato propietario y guardarlo en múltiples formatos abiertos, asegurando la cadena de custodia del documento?\n4.6 – Módulo Flujo de Trabajo – REQ 41: ¿Permite la parametrización y administración de diferentes tipos de formatos electrónicos definidos por la entidad, alertando al usuario ante intentos de cargar formatos no permitidos?\n4.9 – Metadatos – REQ 21: ¿Permite la captura automática de metadatos de un documento?\n4.1 – Administración de Expedientes – REQ 8: ¿Permite el cargue de información contenida en soportes heterogéneos (discos ópticos, discos duros, etc.)?\n4.4 – Radicación – REQ 3: ¿Permite la asignación de series y subseries desde el formulario de radicación y dispone de opciones parametrizables?\n4.5 – Módulo de Administración – REQ 32: ¿Permite el diseño, configuración e implementación de formularios especializados para publicación de documentos en cumplimiento de notificación por aviso?\n4.12 – Otros – REQ 4: ¿Permite la creación, modificación y la carga masiva e individual de particulares (usuarios externos) y clientes bancarios?\n4.6 – Módulo Flujo de Trabajo – REQ 34: ¿Permite asegurar la vinculación automática del certificado de entrega con el correo electrónico, permitiendo una fácil navegación entre ambos registros?\n4.4 – Radicación – REQ 31: ¿Cuenta con un módulo web para la radicación de PQRSD, comunicando el código, términos legales y permitiendo asignar la comunicación a una dependencia específica?\n4.6 – Módulo Flujo de Trabajo – REQ 33: ¿Permite identificar automáticamente y capturar todos los correos electrónicos relacionados con uno especificado por el usuario en una sola operación, permitiendo la captura como un único documento o como un conjunto, según la preferencia del usuario?\n4.6 – Módulo Flujo de Trabajo – REQ 36: ¿Permite que un usuario autorizado clasifique un correo electrónico dentro del Cuadro de Clasificación Documental en su nivel de expediente?\n4.3 – Producción – REQ 16: ¿Permite la producción documental a través de formatos de fichero avalados para recepción o cargue de documentos al SGDEA por los diferentes servicios?\n4.1 – Administración de Expedientes – REQ 20: ¿Posibilita la incorporación de documentos de archivo, ya sean creados dentro o fuera del sistema, en un expediente abierto, garantizando que estos documentos hereden los metadatos del expediente?\n4.2 – Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación – REQ 2: ¿Permite asociar cada documento a una serie y/o subserie, expediente y un tipo documental desde el proceso de captura?\n4.3 – Producción – REQ 18: ¿Permite generar la versión del documento firmada y \"radicada\" en formato Pdf/a 1b e impedir modificación o alteración del documento principal o sus anexos una vez firmada?\n4.4 – Radicación – REQ 29: ¿Permite la vinculación de comunicaciones oficiales a una serie o subserie documental definida en el cuadro de clasificación documental?\n4.4 – Radicación – REQ 35: ¿Permite establecer relaciones entre dos comunicaciones (solicitud - respuesta)?\n4.4 – Radicación – REQ 37: ¿Permite el diligenciamiento de un formulario breve para generar un código de radicado inmediato, con la opción de continuar el proceso bajo el mismo código?\n4.4 – Radicación – REQ 39: ¿Cuenta e incluye un módulo de digitalización con características configurables como resolución, profundidad de bits, escala, compresión, OCR, ICR y opciones para guardar en varios formatos electrónicos (PDF/A, TIFF, JPG, entre otros)?\n4.4 – Radicación – REQ 42: Permite configurar y parametrizar servicios de producción masiva de comunicaciones oficiales (Oficio - Memorando) para las siguientes condiciones:\n1. El mismo contenido emitido para una lista de destinatarios (combinación de correspondencia), con radicaciones diferentes\n2. Un documento remitido a un destinatario y copiado a múltiples destinos\n3. El mismo contenido dirigido a un grupo de usuarios o destinatarios externos de forma genérica\n4.5 – Módulo de Administración – REQ 28: ¿Permite configurar la radicación automática o por demanda (según disposición del Banco) de radicaciones por correo electrónico, formularios web, registro de contacto presencial y telefónico y, captura de mensaje de datos por redes sociales oficiales?\n4.6 – Módulo Flujo de Trabajo – REQ 14: ¿Tiene la capacidad de transformar los documentos en fase de elaboración en documentos archivados, según sea necesario?\n4.6 – Módulo Flujo de Trabajo – REQ 15: ¿Permite a los usuarios avanzar en la elaboración de documentos sin necesidad de clasificarlos como documentos archivados?\n4.6 – Módulo Flujo de Trabajo – REQ 29: ¿Permite gestionar documentos adjuntos, asegurando la vinculación con su documento principal sin usar formatos de compresión?\n4.4 – Radicación – REQ 1: ¿Permite niveles de parametrización para el formulario de radicación?\n4.4 – Radicación – REQ 6: ¿Permite la impresión de rótulos o radicación, así como la reimpresión por el administrador para casos especiales?\n4.4 – Radicación – REQ 7: ¿Permite la actualización de la metadata asociada a una radicación, dejando el registro de auditoría y ejecutando automáticamente las reglas de negocio y los flujos de trabajo correspondientes?\n4.6 – Módulo Flujo de Trabajo – REQ 18: ¿Permite a un usuario autorizado registrar observaciones sobre cambios en un documento en fase de elaboración antes de archivarlo en el sistema?\n4.6 – Módulo Flujo de Trabajo – REQ 19: ¿Previene la edición de un documento en fase de elaboración cuando un usuario autorizado haya cancelado o detenido la edición previamente?\n4.6 – Módulo Flujo de Trabajo – REQ 22: ¿Permite actualizar automáticamente las versiones de los documentos en fase de elaboración?\n4.6 – Módulo Flujo de Trabajo – REQ 24: ¿Permite que un usuario autorizado mantenga los metadatos del servicio colaborativo al trasladar el documento al servicio de documentos archivados?\n4.6 – Módulo Flujo de Trabajo – REQ 68: ¿Permite registrar en cada documento los datos del usuario que proyectó, revisó y aprobó cuando sea necesario?\n4.5 – Módulo de Administración – REQ 3: ¿Permite la reasignación de trámites pendientes cuando el usuario responsable no está disponible (vacaciones, licencias, retiro, etc.)?\n4.5 – Módulo de Administración – REQ 22: ¿Permite configurar los tipos documentales que consumirán servicios de envío por correo electrónico certificado. P.e Respuestas a Derechos de petición, tutelas, comunicaciones en cumplimiento de asuntos judiciales?\n4.3 – Producción – REQ 9: ¿Permite gestionar los traslados entre áreas?\n4.4 – Radicación – REQ 8: ¿Permite asociar dos o más radicaciones a un mismo asunto, tema, servicio, proceso o trámite?\n4.4 – Radicación – REQ 9: ¿Permite desasociar una radicación?\n4.4 – Radicación – REQ 12: ¿Permite el seguimiento de los tiempos de respuesta de las comunicaciones oficiales y otros asuntos como PQRS?\n4.4 – Radicación – REQ 13: ¿Permite la radicación de comunicaciones anónimas y los mecanismos para emitir o publicar la respuesta?\n4.4 – Radicación – REQ 14: ¿Permite la radicación directamente desde el sistema de comunicaciones recibidas por correo electrónico?\n4.4 – Radicación – REQ 15: ¿Permite radicar o recibir comunicaciones a través de diferentes canales, como Sede Electrónica, Chat, Redes Sociales, Teléfono, etc.?\n4.4 – Radicación – REQ 17: ¿Permite gestionar los traslados por competencia cuando la comunicación es de competencia de otra área y verificar el reporte del flujo de la reasignación entre diferentes áreas?\n4.4 – Radicación – REQ 18: ¿Permite gestionar los traslados por competencia cuando la comunicación es de competencia de otra entidad?\n4.4 – Radicación – REQ 19: ¿Permite la integración con el sistema del proveedor de servicios postales para consultar los reportes de entrega y devolución?\n4.4 – Radicación – REQ 23: ¿Permite la adición de uno o varios destinatarios, así como la generación de copias para múltiples destinatarios en una misma comunicación oficial?\n4.4 – Radicación – REQ 25: ¿Permite la inclusión de anexos en diferentes formatos digitales (texto, audio, imagen, video, etc.) en una comunicación oficial?\n4.4 – Radicación – REQ 26: ¿Permite agregar listas de usuarios como destinatarios o copias en una comunicación oficial?\n4.4 – Radicación – REQ 27: ¿Permite la asignación de una comunicación a un usuario responsable de su gestión?\n4.4 – Radicación – REQ 28: ¿Permite reasignar la gestión de una comunicación a otro usuario responsable?\n4.4 – Radicación – REQ 30: ¿Permite el inicio del trámite de una comunicación oficial con configuración de flujo documental?\n4.4 – Radicación – REQ 34: ¿Se integra con los servicios del operador postal para consultar comprobantes de entrega o devolución?\n4.4 – Radicación – REQ 38: ¿Permite y exige una justificación para aceptar la anulación de una comunicación oficial?\n4.4 – Radicación – REQ 40: ¿Permite a un usuario autorizado deshacer la anulación de una comunicación oficial, requiriendo una justificación, y registrando la acción tanto en el historial de eventos como en los metadatos?\n4.4 – Radicación – REQ 41: ¿Permite el registro de etapas de trámite por agrupación documental?\n4.4 – Radicación – REQ 43: Permite procesos masivos para la captura de documentos digitalizados a través de servicios del SGDEA a nivel de:\n\n* Correspondencia\n* Digitalización por tipo documental\n4.6 – Módulo Flujo de Trabajo – REQ 26: ¿Permite y facilita la producción y captura exclusiva de documentos señalados en la tabla de retención documental?\n4.6 – Módulo Flujo de Trabajo – REQ 30: ¿Se integra al servidor de correo electrónico para permitir a los usuarios capturar correos electrónicos desde la aplicación de correo sin cambiar al SGDEA?\n4.6 – Módulo Flujo de Trabajo – REQ 31: ¿Permite la captura individual o masiva de correos electrónicos recibidos o enviados (incluyendo adjuntos), garantizando su formato electrónico de archivo junto a sus metadatos (fecha/hora de envío, recibo, destinatario, destinatario copia, asunto, remitente, encabezado, entre otros), mediante opciones como: \na. Captura automática, b. Determinación de correos a capturar a partir de reglas de correo, c. Selección del usuario a partir de opciones en el sistema, d. Captura manual del usuario?\n4.6 – Módulo Flujo de Trabajo – REQ 32: ¿Permite capturar los anexos de un correo electrónico de forma individual, manteniendo la conexión con el correo correspondiente y facilitando la navegación bidireccional entre el correo y sus adjuntos?\n4.6 – Módulo Flujo de Trabajo – REQ 35: ¿Permite, en la captura de un correo electrónico como documento de archivo, la inclusión del nombre de usuario del buzón (si está presente) junto con su dirección de correo electrónico como metadato?\n4.6 – Módulo Flujo de Trabajo – REQ 48: ¿Permite garantizar que todos los documentos conserven sus vínculos con el flujo de trabajo correspondiente?", "agrupacion": "4.6 – Módulo Flujo de Trabajo\nREQ 7, 28, 41, 34, 33, 36, 14, 15, 29, 18, 19, 22, 24, 68, 26, 30, 31, 32, 35, 48\n\n4.3 – Producción\nREQ 17, 16, 18, 9\n\n4.5 – Módulo de Administración\nREQ 38, 32, 28, 3, 22\n\n4.9 – Metadatos\nREQ 21\n\n4.1 – Administración de Expedientes\nREQ 8, 20\n\n4.4 – Radicación\nREQ 3, 31, 29, 35, 37, 39, 42, 1, 6, 7, 8, 9, 12, 13, 14, 15, 17, 18, 19, 23, 25, 26, 27, 28, 30, 34, 38, 40, 41, 43\n\n4.12 – Otros\nREQ 4\n\n4.2 – Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación\nREQ 2"}, {"modulo": "10. Firmas", "total": 8, "contexto": "Las capacidades de firma permiten incorporar mecanismos de validación, suscripción y control sobre documentos que requieren formalización electrónica o digital. Con esta cobertura se refuerza la autenticidad, integridad y evidencia de aprobación dentro de los procesos documentales. En esta versión se incluyen 8 requerimiento(s), contemplados para la cobertura integral del módulo sin aplicar filtro por estado.", "incluidos": "4.4 – Radicación – REQ 16: ¿Permite la firma electrónica o digital de las comunicaciones por correo electrónico?\n4.3 – Producción – REQ 5: ¿Permite soportar las firmas digitales de cualquier entidad de certificación digital?\n4.3 – Producción – REQ 6: ¿Permite el firmado por varios usuarios en el caso de firmas digitales?\n4.3 – Producción – REQ 7: ¿Permite el firmado por varios usuarios en el caso de firmas electrónicas?\n4.6 – Módulo Flujo de Trabajo – REQ 38: ¿Permite la integración de un estampado cronológico?\n4.5 – Módulo de Administración – REQ 24: ¿Permite configurar los servicios de consumo de estampas cronológicas para los eventos definidos por el Banco?\n4.12 – Otros – REQ 6: ¿Permite registrar la trazabilidad de producción del documento (ej. Proyectante, editor, revisores, firmantes) capturando a través de los datos del sistema, el usuario que adelantó la acción y la metadata de fecha y hora de cada evento?\n4.6 – Módulo Flujo de Trabajo – REQ 37: ¿Permite la habilitación de una o varias firmas electrónicas y/o digitales para un documento, como Confirmación y Contrafirma?", "agrupacion": "4.4 – Radicación\nREQ 16\n\n4.3 – Producción\nREQ 5, 6, 7\n\n4.6 – Módulo Flujo de Trabajo\nREQ 38, 37\n\n4.5 – Módulo de Administración\nREQ 24\n\n4.12 – Otros\nREQ 6"}, {"modulo": "11. Acto Administrativo", "total": 1, "contexto": "La funcionalidad asociada al acto administrativo permite soportar la gestión de documentos formales que requieren control, trazabilidad y tratamiento dentro del SGDEA. Esta capacidad aporta estructura para administrar el ciclo de elaboración, revisión o disposición del acto según las reglas definidas. En esta versión se incluyen 1 requerimiento(s), contemplados para la cobertura integral del módulo sin aplicar filtro por estado.", "incluidos": "4.4 – Radicación – REQ 10: ¿Permite registrar y controlar la anulación de los radicados de los actos administrativos?", "agrupacion": "4.4 – Radicación\nREQ 10"}, {"modulo": "12. Comunicados Internos", "total": 3, "contexto": "La gestión de comunicados internos facilita la creación, administración y circulación de información institucional dentro de la organización. Esta capacidad contribuye a mantener control sobre la comunicación interna, sus destinatarios y la trazabilidad de los documentos generados. En esta versión se incluyen 3 requerimiento(s), contemplados para la cobertura integral del módulo sin aplicar filtro por estado.", "incluidos": "4.5 – Módulo de Administración – REQ 26: ¿Permite configurar servicios de distribución interna de comunicaciones recibidas?\n4.4 – Radicación – REQ 5: ¿Dispone de un mecanismo que evidencie las comunicaciones oficiales anuladas?\n4.4 – Radicación – REQ 11: ¿Permite registrar y controlar la anulación de los radicados de las comunicaciones oficiales?", "agrupacion": "4.5 – Módulo de Administración\nREQ 26\n\n4.4 – Radicación\nREQ 5, 11"}, {"modulo": "13. Gestión de Borradores", "total": 7, "contexto": "La administración de borradores permite conservar versiones preliminares de documentos antes de su formalización, revisión o radicación. Con esta funcionalidad se apoya el trabajo colaborativo, el control de cambios y la preparación ordenada de contenidos documentales. En esta versión se incluyen 7 requerimiento(s), contemplados para la cobertura integral del módulo sin aplicar filtro por estado.", "incluidos": "4.6 – Módulo Flujo de Trabajo – REQ 11: ¿Permite administrar tanto los documentos en fase de redacción como los documentos archivados utilizando el mismo Cuadro de Clasificación Documental y aplicando los mismos protocolos de control de acceso?\n4.6 – Módulo Flujo de Trabajo – REQ 16: ¿Permite la reutilización de documentos para la creación de nuevos, preservando la integridad del original?\n4.6 – Módulo Flujo de Trabajo – REQ 20: ¿Permite evitar que un documento en fase de elaboración cancelado o detenido sea ingresado al servicio de documentos archivados?\n4.6 – Módulo Flujo de Trabajo – REQ 21: ¿Permite asignar un número de versión a cada documento en fase de elaboración y lo muestra al recuperar o buscar el documento?\n4.6 – Módulo Flujo de Trabajo – REQ 13: ¿Permite a un usuario autorizado, mediante tareas programadas, ejecutar acciones como: a. Seleccionar documentos en borrador y declararlos documentos de archivo? b. Eliminar todos los borradores dejando solo los documentos de archivo? c. Eliminar todos los borradores después de cierto tiempo, predefinido por un usuario autorizado?\n4.6 – Módulo Flujo de Trabajo – REQ 12: ¿Reconoce y organiza, dentro de un Cuadro de Clasificación Documental común, tanto los documentos en proceso de redacción como los documentos archivados?\n4.4 – Radicación – REQ 36: ¿Permite listar las comunicaciones oficiales anuladas en un periodo de tiempo determinado?", "agrupacion": "4.6 – Módulo Flujo de Trabajo\nREQ 11, 16, 20, 21, 13, 12\n\n4.4 – Radicación\nREQ 36"}, {"modulo": "14. Expedientes", "total": 76, "contexto": "La gestión de expedientes concentra la conformación, consulta, foliado, índice electrónico, administración de documentos, cierre y seguimiento del expediente electrónico. Esta cobertura asegura que los documentos asociados se mantengan organizados, íntegros, trazables y disponibles durante el ciclo de vida definido. En esta versión se incluyen 76 requerimiento(s), contemplados para la cobertura integral del módulo sin aplicar filtro por estado.", "incluidos": "4.11 – Búsqueda y Reportes – REQ 4: ¿Permite aplicar diversos filtros, valores y metadatos para llevar a cabo procesos de búsqueda?\n4.11 – Búsqueda y Reportes – REQ 5: ¿Permite establecer criterios de búsqueda en cualquier nivel del Cuadro de Clasificación Documental?\n4.11 – Búsqueda y Reportes – REQ 6: ¿Permite la realización de búsquedas en elementos activos, inactivos o ambos de una entidad?\n4.2 – Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación – REQ 21: ¿El sistema permite a usuarios autorizados examinar e inspeccionar expedientes activos sujetos a disposición, con opciones para ordenar y agrupar según preferencias específicas, como:\n\na. Por agrupación documental de acuerdo con algún nivel del Cuadro de Clasificación Documental\nb. Por versión de TRD o TVD\nc. Por código de acción de disposición\nd. Por fecha de vencimiento de acción de disposición\ne. Por fecha de vencimiento de confirmación de disposición?\n4.1 – Administración de Expedientes – REQ 19: ¿Facilita a un usuario autorizado la exploración e inspección de series, subseries y expedientes junto con sus metadatos, mediante la navegación desde el servicio de clasificación y el servicio de Documentos de Archivo?\n4.10 – Módulo de Manejo Físico de Documentos – REQ 26: ¿Permite asegurar que, al buscar series, subseries y expedientes, se recuperen simultáneamente metadatos de documentos físicos y electrónicos en una sola operación?\n4.5 – Módulo de Administración – REQ 40: ¿Permite configurar los servicios de control de inventarios y digitalización con fines de consulta sobre archivos inactivos?\n4.11 – Búsqueda y Reportes – REQ 8: ¿Permite la exportación de búsquedas en formatos como xlsx, XML, HTML, pdf, etc.?\n4.1 – Administración de Expedientes – REQ 43: ¿Permite configurar los servicios de creación de expediente aplicables de forma genérica para cualquier agrupación documental de acuerdo con la TRD activa?\n4.1 – Administración de Expedientes – REQ 22: ¿El sistema permite la replicación de un tipo documental a otro expediente, asegurando la incorporación adecuada de los metadatos del sistema y contextuales, la lista de control de acceso, y el historial de eventos?\n4.1 – Administración de Expedientes – REQ 18: ¿Permite que un usuario autorizado elimine un expediente vacío que nunca haya sido utilizado?\n4.12 – Otros – REQ 3: ¿Permite el registro de archivos de DDHH/DIH?\n4.1 – Administración de Expedientes – REQ 16: ¿Permite el cierre manual y/o automático de un expediente al agregar el documento que concluye el trámite, según un flujo de trabajo o criterio de cierre específico (por ejemplo, finalización de vigencia)?\n4.1 – Administración de Expedientes – REQ 5: ¿Permite mecanismos electrónicos seguros para generar el cierre de los expedientes, en cumplimiento de las Directrices del AGN y Min Tic?\n4.2 – Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación – REQ 13: ¿Activa el periodo de retención desde el cierre del expediente?\n4.2 – Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación – REQ 28: ¿Permite configurar el control de términos de retención una vez cerrado cada expediente?\n4.1 – Administración de Expedientes – REQ 47: ¿Permite la reapertura de expedientes cerrados, por instrucción de rol administrador previa justificación del área productora?\n4.10 – Módulo de Manejo Físico de Documentos – REQ 9: ¿Permite gestionar documentos físicos de la misma forma que los documentos electrónicos, incluyendo herencia de metadatos?\n4.2 – Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación – REQ 1: ¿Permite garantizar que los documentos electrónicos de archivo que se capturen se asocien a una TRD configurada en el sistema?\n4.1 – Administración de Expedientes – REQ 7: ¿Permite y cuenta con tipos de control para la depuración o intervención de expedientes electrónicos?\n4.2 – Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación – REQ 12: ¿No debería haber restricciones en el número de documentos almacenados en cualquier serie, subserie o expediente?\n4.3 – Producción – REQ 4: ¿Permite y cuenta con el uso de diferentes tipos de formatos para la producción y recepción documental?\n4.3 – Producción – REQ 1: ¿Permite al gestor diferentes tipos de formatos para la conservación y preservación documental?\n4.2 – Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación – REQ 10: ¿Permite la clasificación de documentos y expedientes dentro del cuadro de clasificación documental?\n4.5 – Módulo de Administración – REQ 35: ¿Permite configurar formulario de testigo documental para ser diligenciado y usado en cualquiera de los expedientes del SGDEA?\n4.5 – Módulo de Administración – REQ 43: ¿Permite configurar formulario de descripción archivística con fines históricos para archivos de conservación total?\n4.1 – Administración de Expedientes – REQ 23: ¿El sistema permite al usuario explorar e inspeccionar los documentos de archivo mediante al menos las siguientes modalidades:\n\na. Navegar por los documentos de un expediente en orden de fecha\nb. Navegar desde un documento a su expediente e inspeccionar sus metadatos\nc. Navegar de un documento a su serie o subserie e inspeccionar sus metadatos\nd. Navegar desde un documento a sus componentes e inspeccionar sus metadatos?\n4.1 – Administración de Expedientes – REQ 1: ¿Cuenta con mecanismos implementados para el foliado de los documentos electrónicos, garantizando la integridad y autenticidad del expediente y los documentos que lo conforman?\n4.1 – Administración de Expedientes – REQ 26: ¿Organiza los documentos dentro de un expediente de manera ascendente según la fecha de trámite?\n4.10 – Módulo de Manejo Físico de Documentos – REQ 8: ¿Permite identificar las series, subseries y expedientes para documentos en formatos análogos?\n4.10 – Módulo de Manejo Físico de Documentos – REQ 17: ¿Permite organizar tanto los documentos físicos como los electrónicos según el Cuadro de Clasificación Documental?\n4.1 – Administración de Expedientes – REQ 2: ¿Genera el foliado electrónico para documentos en formatos de archivo diferentes a los procesadores de texto (audiovisuales, imágenes, renders, entre otros)?\n4.10 – Módulo de Manejo Físico de Documentos – REQ 5: ¿Permite que un expediente contenga documentos electrónicos y físicos para conformar expedientes híbridos?\n4.1 – Administración de Expedientes – REQ 15: ¿Permite cambiar la clasificación de un documento dentro del Cuadro de Clasificación Documental?\n4.1 – Administración de Expedientes – REQ 21: ¿Garantiza que todos los documentos clasificados y reclasificados dentro de un expediente hereden los atributos relacionados con tiempos de retención y disposición final de este último?\n4.1 – Administración de Expedientes – REQ 4: ¿Permite estructurar la base del índice electrónico y su nivel de parametrización?\n4.1 – Administración de Expedientes – REQ 30: ¿Está accesible el índice electrónico desde la creación misma del expediente?\n4.1 – Administración de Expedientes – REQ 29: ¿Permite la creación de un índice electrónico en formato XML para cada expediente, generando los metadatos conforme al esquema definido?\n4.5 – Módulo de Administración – REQ 47: Cuando por motivos de obsolescencia tecnológica, seguridad de la información, causal administrativo o judicial, se requiera exportar, transferir o migrar los documentos, la solución informática deberá garantizar la integridad de los expedientes, respecto a:\n·Componentes del expediente (documento electrónico, foliado, índice firmado y metadatos).\n·Estructura de los documentos, preservando las relaciones correctas entre ellos\n4.1 – Administración de Expedientes – REQ 3: ¿Permite identificar o visualizar el índice electrónico?\n4.1 – Administración de Expedientes – REQ 31: ¿Incluye a todos los expedientes un índice electrónico, el cual debe ser firmado electrónicamente al cerrar el expediente?\n4.1 – Administración de Expedientes – REQ 32: ¿Permite la navegación por el expediente a través del índice electrónico?\n4.1 – Administración de Expedientes – REQ 46: ¿Permite configurar la firma de índice electrónico al cierre de expediente (automático o por demanda)?\n4.10 – Módulo de Manejo Físico de Documentos – REQ 6: ¿Permite generar referencias cruzadas tanto para documentos electrónicos como físicos?\n4.2 – Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación – REQ 11: ¿Permite la reclasificación de elementos dentro del cuadro de clasificación documental, asegurando que los elementos reclasificados hereden los atributos y metadatos de sus nuevos elementos superiores?\n4.9 – Metadatos – REQ 18: ¿Permite asegurar la conservación de los metadatos originales durante procesos de intercambio de información y transferencias documentales, incorporando nuevos metadatos según sea necesario?\n4.10 – Módulo de Manejo Físico de Documentos – REQ 15: ¿Permite garantizar que los controles de acceso para series, subseries y expedientes físicos sean idénticos a los electrónicos?\n4.1 – Administración de Expedientes – REQ 37: ¿Permite la inclusión de la etiqueta de clasificación de activos de información (Público, Clasificado, Reservado) correspondiente en el documento?\n4.7 – Tablas De Control De Acceso – REQ 1: ¿Permite realizar la tipificación y parametrización de las categorías en las restricciones en cuanto a los derechos de acceso y seguridad a la información?\n4.5 – Módulo de Administración – REQ 37: ¿Permite configurar el control de términos para el levantamiento de restricciones de acceso para documentos calificados como \"reservados\" de conformidad con los criterios de IICR?\n4.4 – Radicación – REQ 24: ¿Permite etiquetar como reservada una comunicación oficial, con acceso controlado por la lista de control de accesos?\n4.11 – Búsqueda y Reportes – REQ 7: ¿Permite que los procesos de búsqueda realizados por un usuario queden registrados en el Historial de eventos de la entidad de usuario?\n4.1 – Administración de Expedientes – REQ 38: ¿Permite el registro de eventos de creación masiva y/o automática de expedientes?\n4.1 – Administración de Expedientes – REQ 39: ¿Permite el registro de eventos de cierre masiva y/o automática de expedientes?\n4.10 – Módulo de Manejo Físico de Documentos – REQ 16: ¿Permite elegir la ubicación física a partir de opciones predeterminadas, como una lista desplegable?\n4.10 – Módulo de Manejo Físico de Documentos – REQ 19: ¿Permite registrar información sobre la ubicación física de documentos impresos para un control efectivo?\n4.1 – Administración de Expedientes – REQ 36: ¿Permite a un usuario autorizado validar la integridad de un documento mediante la generación y verificación de un código hash, registrando este valor en el índice electrónico?\n4.1 – Administración de Expedientes – REQ 25: ¿Consigna cada acción relacionada con un documento en el \"Historial de eventos\"?\n4.6 – Módulo Flujo de Trabajo – REQ 27: ¿Permite la importación individual o por lotes de documentos archivados no generados dentro del sistema?\n4.5 – Módulo de Administración – REQ 44: ¿Permite configurar servicios de migración (entrada - salida) a nivel de expediente y por lote de expedientes?\n4.1 – Administración de Expedientes – REQ 9: ¿Permite la articulación y cuenta con mecanismos para la migración de información desde otros sistemas y entidades?\n4.1 – Administración de Expedientes – REQ 41: ¿Permite configurar los servicios de cargue masivo de expedientes (datos y documentos) por parte de usuarios internos?\n4.5 – Módulo de Administración – REQ 34: ¿Permite configurar los servicios para cargue de documentos nativos digitales o digitalizados fuera del SGDEA para indexación y cargue en expedientes?\n4.1 – Administración de Expedientes – REQ 40: ¿Permite que los Expedientes en etapa activa se migren al SGDEA (Registro de Expediente y Documentos de acuerdo a la estructura de datos)?\n4.8 – Prestamos – REQ 1: ¿Permite realizar préstamos de la información, ya sea por expediente o por tipologías documentales?\n4.10 – Módulo de Manejo Físico de Documentos – REQ 11: ¿Permite que el usuario autorizado registre el préstamo y especifique la fecha de devolución?\n4.10 – Módulo de Manejo Físico de Documentos – REQ 12: ¿Permite que la fecha de devolución se calcule automáticamente o de acuerdo con la parametrización y sea configurable?\n4.10 – Módulo de Manejo Físico de Documentos – REQ 20: ¿Permite a los usuarios autorizados registrar préstamos y definir la fecha de devolución, calculada automáticamente según parámetros configurables?\n4.10 – Módulo de Manejo Físico de Documentos – REQ 18: ¿Permite a los usuarios autorizados modificar la fecha de vencimiento para la devolución de préstamos individuales o múltiples?\n4.10 – Módulo de Manejo Físico de Documentos – REQ 7: ¿Permite parametrizar, configurar e imprimir plantillas de comprobante de préstamo y formato externo?\n4.10 – Módulo de Manejo Físico de Documentos – REQ 21: ¿Permite parametrizar, configurar e imprimir formatos para los registros de préstamo?\n4.10 – Módulo de Manejo Físico de Documentos – REQ 24: ¿Permite a los usuarios autorizados consultar información sobre un préstamo, incluyendo el titular, fecha de salida y control de acceso?\n4.10 – Módulo de Manejo Físico de Documentos – REQ 28: ¿Permite notificar por correo electrónico al usuario, incluyendo al funcionario de archivo y al titular del préstamo, cuando se acerca la fecha de vencimiento para la devolución y cuando ya ha vencido?\n4.8 – Prestamos – REQ 2: Cuando el expediente es físico, ¿Permite una notificación automática cuando la información se encuentra en préstamo a otros usuarios?\n4.8 – Prestamos – REQ 5: ¿Permite notificar al usuario la fecha cercana del vencimiento del préstamo y parametrizar notificaciones cuando el préstamo está vencido, generando así los reportes de préstamos?\n4.1 – Administración de Expedientes – REQ 10: ¿Cuenta con una capa de interoperabilidad que permite la integración e intercambio de datos con los sistemas y repositorios digitales de la entidad?", "agrupacion": "4.11 – Búsqueda y Reportes\nREQ 4, 5, 6, 8, 7\n\n4.2 – Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación\nREQ 21, 13, 28, 1, 12, 10, 11\n\n4.1 – Administración de Expedientes\nREQ 19, 43, 22, 18, 16, 5, 47, 7, 23, 1, 26, 2, 15, 21, 4, 30, 29, 3, 31, 32, 46, 37, 38, 39, 36, 25, 9, 41, 40, 10\n\n4.10 – Módulo de Manejo Físico de Documentos\nREQ 26, 9, 8, 17, 5, 6, 15, 16, 19, 11, 12, 20, 18, 7, 21, 24, 28\n\n4.5 – Módulo de Administración\nREQ 40, 35, 43, 47, 37, 44, 34\n\n4.12 – Otros\nREQ 3\n\n4.3 – Producción\nREQ 4, 1\n\n4.9 – Metadatos\nREQ 18\n\n4.7 – Tablas De Control De Acceso\nREQ 1\n\n4.4 – Radicación\nREQ 24\n\n4.6 – Módulo Flujo de Trabajo\nREQ 27\n\n4.8 – Prestamos\nREQ 1, 2, 5"}, {"modulo": "15. Archivo Físico", "total": 16, "contexto": "El archivo físico se soporta mediante funciones para administrar unidades, ubicaciones, consultas, préstamos, inventarios y movimientos de documentación en custodia. Esta capacidad conecta la gestión documental electrónica con el control operativo del acervo físico, fortaleciendo la trazabilidad y disponibilidad de los soportes. En esta versión se incluyen 16 requerimiento(s), contemplados para la cobertura integral del módulo sin aplicar filtro por estado.", "incluidos": "4.5 – Módulo de Administración – REQ 39: ¿Permite configurar los servicios de administración de espacios de custodia con la arquitectura de los repositorios o bodegas físicas vigentes?\n4.5 – Módulo de Administración – REQ 41: ¿Permite configurar servicio de asignación de locación en bodega para transferencias de archivos en soporte físico?\n4.10 – Módulo de Manejo Físico de Documentos – REQ 2: ¿Permite localizar un expediente híbrido o físico?\n4.10 – Módulo de Manejo Físico de Documentos – REQ 1: ¿Contiene un módulo para administración de documentos físicos?\n4.10 – Módulo de Manejo Físico de Documentos – REQ 4: ¿Permite capturar y gestionar los metadatos acerca de las cajas, carpetas u otras unidades de conservación y almacenamiento?\n4.10 – Módulo de Manejo Físico de Documentos – REQ 22: ¿Permite a los usuarios autorizados consultar el Inventario Documental, identificando los expedientes actualmente prestados?\n4.10 – Módulo de Manejo Físico de Documentos – REQ 3: ¿Permite ser leído el código de barras por un lector óptico, identificando y ubicando físicamente el documento (dependencia, archivo, estante, entrepaño, caja) y proporcionando toda la información básica (metadata)?\n4.10 – Módulo de Manejo Físico de Documentos – REQ 29: ¿Permite admitir la impresión y reconocimiento de códigos de barras o sistemas de localización alternativos para documentos físicos?\n4.10 – Módulo de Manejo Físico de Documentos – REQ 30: ¿Permite la parametrización, configuración e impresión de la plantilla de rótulo para cajas, carpetas y otras unidades de almacenamiento y conservación?\n4.1 – Administración de Expedientes – REQ 33: ¿Permite la generación del inventario documental (FUID) en diversos formatos (XLSX, PDF, XML, etc.)?\n4.1 – Administración de Expedientes – REQ 34: ¿Permite y asegura la disponibilidad del FUID en cualquier momento?\n4.1 – Administración de Expedientes – REQ 35: ¿Permite exportar e importar un FUID en diversos formatos electrónicos, como XLSX, PDF, XML, etc.?\n4.10 – Módulo de Manejo Físico de Documentos – REQ 25: ¿Permite registrar en el \"Historial de eventos\" todas las entradas y salidas, valores de metadatos, así como las acciones relacionadas con documentos físicos?\n4.10 – Módulo de Manejo Físico de Documentos – REQ 27: ¿Permite respaldar el seguimiento de cajas, carpetas y otras unidades físicas, proporcionando registros de entrada y salida, ubicación, custodia y fecha de registro?\n4.10 – Módulo de Manejo Físico de Documentos – REQ 23: ¿El sistema registra en los metadatos información sobre los movimientos de una unidad física, incluyendo como mínimo el identificador único, la ubicación actual, las ubicaciones anteriores, la fecha en que se trasladó de ubicación, la fecha de recepción en el lugar y el usuario responsable del movimiento para cada caso?\n4.10 – Módulo de Manejo Físico de Documentos – REQ 14: ¿Permite registrar la información sobre los movimientos de una unidad física?", "agrupacion": "4.5 – Módulo de Administración\nREQ 39, 41\n\n4.10 – Módulo de Manejo Físico de Documentos\nREQ 2, 1, 4, 22, 3, 29, 30, 25, 27, 23, 14\n\n4.1 – Administración de Expedientes\nREQ 33, 34, 35"}, {"modulo": "16. Retención y Disposición", "total": 17, "contexto": "La retención y disposición documental permite aplicar reglas asociadas a conservación, transferencias, eliminación, disposición final y administración de tiempos conforme a los instrumentos definidos. Con ello se respalda el cumplimiento del ciclo de vida documental y la ejecución controlada de decisiones archivísticas. En esta versión se incluyen 17 requerimiento(s), contemplados para la cobertura integral del módulo sin aplicar filtro por estado.", "incluidos": "4.1 – Administración de Expedientes – REQ 6: ¿Permite realizar transferencias primarias y secundarias de los expedientes electrónicos?\n4.2 – Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación – REQ 29: ¿Permite configurar los servicios de compilación de expedientes en cumplimiento de términos de retención para transferencia primaria, alerta a productor, conformación de acta de transferencia, y remisión de requerimiento a administración de Archivo Central?\n4.6 – Módulo Flujo de Trabajo – REQ 47: ¿Permite notificar si un expediente dentro de un flujo de trabajo está programado para revisión o disposición?\n4.2 – Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación – REQ 19: ¿Permite a un usuario autorizado cancelar una transferencia primaria de cualquier expediente al concluir los tiempos en la fase del archivo de gestión?\n4.2 – Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación – REQ 20: ¿Permite a los usuarios autorizados confirmar el éxito de la transferencia para expedientes con acción de disposición de transferencia que han alcanzado su fecha de vencimiento, estableciendo la marca de tiempo de la transferencia tras la confirmación?\n4.2 – Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación – REQ 22: ¿Permite a un usuario autorizado aplicar filtros a expedientes y/o documentos para llevar a cabo procesos de selección cuando sea la disposición final?\n4.1 – Administración de Expedientes – REQ 24: ¿Permite la consulta de expedientes según sus tiempos de retención y disposición final?\n4.2 – Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación – REQ 27: ¿Facilita la creación de inventarios documentales considerando la disposición final como base, incluyendo: \na. La referencia en cada expediente al acta con la que se aprobó la disposición final a realizar\nb. La referencia en cada expediente a la disposición final aplicada\nc. La generación de reportes sobre las disposiciones finales aplicadas\nd. La generación de reportes sobre los documentos transferidos?\n4.2 – Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación – REQ 18: ¿Incorpora una herramienta FTP (Protocolo de Transferencia de Archivos) para garantizar la integridad de expedientes, documentos y metadatos?\n4.5 – Módulo de Administración – REQ 45: ¿Permite configurar servicios de transferencia secundaria, proyección de acta de transferencia a través de reporte de SGDEA y evidencia de recibo efectivo?\n4.10 – Módulo de Manejo Físico de Documentos – REQ 13: ¿Permite notificar cuando el periodo de retención se cumple y se debe aplicar la disposición final a los expedientes físicos?\n4.2 – Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación – REQ 25: ¿Implementa un procedimiento de eliminación seguro para evitar la reconstrucción del expediente, aplicable cuando la disposición final de un expediente sea la eliminación?\n4.2 – Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación – REQ 24: ¿Permite que los expedientes eliminados retengan ciertos metadatos detallados en el esquema correspondiente?\n4.2 – Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación – REQ 23: ¿Habilita a un usuario autorizado para revocar la eliminación de cualquier expediente con esta disposición final cuando alcance la fecha de vencimiento de la acción de disposición, siguiendo un mandato legal o administrativo que debe quedar registrado en el historial de eventos y metadatos?\n4.9 – Metadatos – REQ 6: ¿Permite que los metadatos asociados a una entidad u objeto digital se conserven cuando la entidad o el objeto es eliminado?\n4.5 – Módulo de Administración – REQ 48: ¿Permite la parametrización y/o configuración para Exportar la totalidad de los expedientes y sus componentes conforme a la estructura de TRD. Exportar o transferir los documentos correspondientes con las reglas de retención y disposición y sus respectivos controles de acceso (seguridad para consulta) para que puedan seguir aplicándose en el sistema de destino?\n4.5 – Módulo de Administración – REQ 42: ¿Permite configurar los servicios de monitoreo de inventarios de expedientes para transferencia secundaria?", "agrupacion": "4.1 – Administración de Expedientes\nREQ 6, 24\n\n4.2 – Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación\nREQ 29, 19, 20, 22, 27, 18, 25, 24, 23\n\n4.6 – Módulo Flujo de Trabajo\nREQ 47\n\n4.5 – Módulo de Administración\nREQ 45, 48, 42\n\n4.10 – Módulo de Manejo Físico de Documentos\nREQ 13\n\n4.9 – Metadatos\nREQ 6"}, {"modulo": "17. Reportes Dinámicos", "total": 12, "contexto": "Los reportes dinámicos facilitan la generación, consulta y explotación de información operativa e histórica mediante vistas, tablas, exportaciones e indicadores. Esta capacidad aporta soporte para análisis, seguimiento, auditoría y toma de decisiones sobre la información gestionada. En esta versión se incluyen 12 requerimiento(s), contemplados para la cobertura integral del módulo sin aplicar filtro por estado.", "incluidos": "4.11 – Búsqueda y Reportes – REQ 2: ¿Permite facilitar la realización de procesos de búsqueda y generación de informes en todas las entidades del sistema?\n4.5 – Módulo de Administración – REQ 5: ¿Permite generar reportes y parametrizar nuevos reportes?\n4.11 – Búsqueda y Reportes – REQ 11: ¿Permite la generación de información de datos históricos de correspondencia?\n4.1 – Administración de Expedientes – REQ 11: ¿Permite generar reportes de las transferencias documentales realizadas?\n4.11 – Búsqueda y Reportes – REQ 1: ¿Permite asegurar que se cumplen las restricciones establecidas por la tabla de control de acceso y los roles del usuario al realizar búsquedas y generar informes?\n4.11 – Búsqueda y Reportes – REQ 3: ¿Permite organizar los resultados, al menos, según relevancia, fechas y orden alfabético?\n4.11 – Búsqueda y Reportes – REQ 10: ¿Permite y facilita la generación de informes que incluyan elementos gráficos y tablas?\n4.12 – Otros – REQ 1: El sistema permite la compilación, normalización, depuración de data y complemento de los datos asociados a los siguientes casos:\n\n1. Estructuras organizacionales (organigramas) por periodos en los cuales estuvieron vigentes.\n2. Instrumentos de Clasificación Documental en los diferentes periodos de aplicación.\n3. Inventarios documentales a nivel de datos estructurados (AC- AGC - AG).\n4. Estructuras de almacenamiento en bodega física.\n5. Instrumentos de Clasificación y Acceso vigentes (TRD, TCA, IICR, RA).\n4.5 – Módulo de Administración – REQ 1: ¿Permite estructurar el reporte de auditoría que se realiza en los tiempos de retención y disposición, incluyendo la fecha del cambio o eliminación y el usuario que lo registra?\n4.5 – Módulo de Administración – REQ 2: ¿Permite generar datos para el reporte del estado de la transferencia o exportación realizada?\n4.7 – Tablas De Control De Acceso – REQ 3: ¿Permite generar un informe para un usuario autorizado, listando los usuarios que están activos y que pertenecían a un grupo determinado en una fecha y hora específica?\n4.7 – Tablas De Control De Acceso – REQ 5: ¿Permite generar un informe que muestre la lista de funciones que pertenecían a un rol determinado en una fecha y hora específica?", "agrupacion": "4.11 – Búsqueda y Reportes\nREQ 2, 11, 1, 3, 10\n\n4.5 – Módulo de Administración\nREQ 5, 1, 2\n\n4.1 – Administración de Expedientes\nREQ 11\n\n4.12 – Otros\nREQ 1\n\n4.7 – Tablas De Control De Acceso\nREQ 3, 5"}], "modDet": {"01. Login": [["01. Login", "4.5", "Módulo de Administración", "16", "¿Permiten los usuarios del sistema sincronizarse con el directorio activo de la entidad?", "Integración LDAP", "01", null, null, 3], ["01. Login", "4.5", "Módulo de Administración", "19", "¿Permite bloquear el sistema a un usuario tras tres intentos fallidos simultáneos de contraseña?", "Sistema", "02", null, null, 4]], "02. Roles": [["02. Roles", "4.7", "Tablas De Control De Acceso", "9", "¿Permite a un usuario autorizado explorar y examinar los roles y sus metadatos?", "01. Administrar Roles", "01", null, null, 5], ["02. Roles", "4.5", "Módulo de Administración", "12", "¿Permite que solo un usuario autorizado modifique metadatos y valores de grupos de usuarios, limitándose a los especificados en el modelo de metadatos como variables?", "01. Administrar Roles", "02", null, null, 6], ["02. Roles", "4.7", "Tablas De Control De Acceso", "4", "¿Permite crear grupos de roles y perfiles parametrizables a los metadatos de los grupos?", "01. Administrar Roles", "03", null, null, 7], ["02. Roles", "4.6", "Módulo Flujo de Trabajo", "17", "¿Permite a un usuario autorizado configurar roles que tengan acceso a documentos en fase de elaboración, conforme a los controles de acceso?", "01. Administrar Roles", "04", null, null, 8], ["02. Roles", "4.7", "Tablas De Control De Acceso", "12", "¿Permite listar las acciones permitidas a un usuario según su rol y la tabla de control de accesos?", "01. Administrar Roles", "05", null, null, 9], ["02. Roles", "4.7", "Tablas De Control De Acceso", "11", "¿Permite a un usuario autorizado listar las distintas listas de control de acceso, junto con los roles asociados a cada una?", "01. Administrar Roles", "06", null, null, 10], ["02. Roles", "4.6", "Módulo Flujo de Trabajo", "64", "¿Permite garantizar que todos los controles de acceso se mantengan en todo momento?", "01. Administrar Roles", "07", null, null, 11], ["02. Roles", "4.7", "Tablas De Control De Acceso", "6", "¿Permite la creación de nuevos roles, incluyendo la configuración de sus metadatos?", "01. Administrar Roles", "08", null, null, 12], ["02. Roles", "4.7", "Tablas De Control De Acceso", "7", "¿La modificación de metadatos y valores de un rol solo debe llevarse a cabo por un usuario autorizado, limitándose a los metadatos definidos como variables en el modelo correspondiente?", "01. Administrar Roles", "09", null, null, 13], ["02. Roles", "4.7", "Tablas De Control De Acceso", "13", "¿Permite generar permisos para el acceso a la información a los usuarios de la entidad y configurar los niveles de permisos?", "01. Administrar Roles", "10", null, null, 14], ["02. Roles", "4.7", "Tablas De Control De Acceso", "10", "¿Permite la creación y ajuste de listas de control de acceso que especifiquen los roles autorizados para un servicio determinado?", "01. Administrar Roles", "11", null, null, 15], ["02. Roles", "4.8", "Prestamos", "3", "¿Permite asignar los permisos para el préstamo de expedientes o documentos electrónicos?", "01. Administrar Roles", "12", null, null, 16], ["02. Roles", "4.5", "Módulo de Administración", "10", "¿Permite a un usuario autorizado listar los usuarios pertenecientes a un grupo?", "01. Administrar Roles", "13", null, null, 17], ["02. Roles", "4.7", "Tablas De Control De Acceso", "14", "¿Permite generar Tablas de Control de Acceso de cada entidad según los roles y permisos asignados?", "01. Administrar Roles", "14", null, null, 18], ["02. Roles", "4.5", "Módulo de Administración", "11", "¿Permite la adición de metadatos a los grupos de usuarios?", "01. Administrar Roles", "15", null, null, 19], ["02. Roles", "4.5", "Módulo de Administración", "13", "¿Permite la eliminación de grupos, acción que solo puede realizar un usuario autorizado?", "01. Administrar Roles", "16", null, null, 20], ["02. Roles", "4.7", "Tablas De Control De Acceso", "8", "Aunque forme parte de una lista de control de acceso, ¿permite la eliminación de roles?", "01. Administrar Roles", "17", null, null, 21], ["02. Roles", "4.5", "Módulo de Administración", "9", "¿Permite la conformación de grupos de usuarios, registrando esta acción en el historial de eventos?", "02. Trazabilidad", "01", null, null, 22]], "03. Usuarios": [["03. Usuarios", "4.5", "Módulo de Administración", "14", "¿Permite a un usuario autorizado consultar y navegar los usuarios y grupos, junto con sus respectivos metadatos?", "Administrar Usuarios", "01", null, null, 23], ["03. Usuarios", "4.5", "Módulo de Administración", "6", "¿Permite la creación de nuevos usuarios, así como la configuración de sus metadatos?", "Administrar Usuarios", "02", null, null, 24], ["03. Usuarios", "4.5", "Módulo de Administración", "17", "¿Permite a un usuario autorizado inactivar a otros usuarios por motivos de vacaciones, estableciendo fechas de inicio y finalización?", "Administrar Usuarios", "03", null, null, 25], ["03. Usuarios", "4.5", "Módulo de Administración", "18", "¿Permite asignar roles temporales con la etiqueta \"encargo\", configurando fechas de inicio y finalización?", "Administrar Usuarios", "04", null, null, 26], ["03. Usuarios", "4.5", "Módulo de Administración", "8", "¿Permite la eliminación de usuarios que nunca hayan utilizado el sistema?", "Administrar Usuarios", "05", null, null, 27], ["03. Usuarios", "4.11", "Búsqueda y Reportes", "9", "¿Permite que los informes generados por un usuario queden registrados en el Historial de eventos de la entidad de usuario?", "Historial de eventos", "06", null, null, 28], ["03. Usuarios", "4.5", "Módulo de Administración", "4", "¿Permite mantener pistas de auditoría de las acciones realizadas por cada uno de los usuarios que ingresan al sistema?", "Historial de eventos", "07", null, null, 29]], "04. Historial de Eventos": [["04. Historial de Eventos", "4.12", "Otros", "11", "Permite la parametrización y/o configuración en la auditoría, deberá mínimo registrar y presentar los siguientes campos:\n\nFecha/Hora  (hh:mm:ss): Describe día y hora de entrada.\nID Sesión: Número automático interno del ID del inicio de sesión.\nNombre de usuario: Usuario que inicio login en aplicativo.\nUnidad: Nombre de la unidad predeterminada.\nAcción: Modificación, Adición o Eliminación.\nRegistro ID: Nombre de quien realizo la acción.\nTipo de documento: Nombre del documento que se le realizo la acción.\nCampo/Proceso referenciado: Nombre del proceso y el campo afectado.\nValor anterior: Valor del antiguo del campo.\nValor nuevo: Valor nuevo afectado en el tipo de documento.\nObservaciones: nombre de quien ejecutó la acción", "Hisrotial de Eventos", "01", null, null, 30], ["04. Historial de Eventos", "4.12", "Otros", "10", "¿Permite la parametrización y/o configuración al administrador del sistema para consultar las sesiones de usuario. Deberá mínimo registrar y presentar los siguientes campos:\n\nNúmero de sesión.\nFecha/Hora (hh:mm:ss). (Ingreso y Salida)\nID Sesión (identificador inequívoco o único)\nUsuario: Nombre del usuario que inició y finalizó sesión en el aplicativo.", "Hisrotial de Eventos", "02", null, null, 31], ["04. Historial de Eventos", "4.12", "Otros", "12", "¿Permite la parametrización y/o configuración al administrador del sistema consultar la información de la auditoría de uso de la aplicación?", "Hisrotial de Eventos", "03", null, null, 32], ["04. Historial de Eventos", "4.12", "Otros", "9", "¿Permite la parametrización y/o configuración para registrar logs de las interacciones de los usuarios con el sistema de administración, para temas de auditoría?", "Hisrotial de Eventos", "04", null, null, 33], ["04. Historial de Eventos", "4.12", "Otros", "8", "¿Permite configurar la trazabilidad y pista de auditoría interna de documentos (correspondencia y aquellos de creación nativo digital)?", "Hisrotial de Eventos", "05", null, null, 34], ["04. Historial de Eventos", "4.12", "Otros", "7", "¿Permite registrar la trazabilidad de distribución y gestión de cada documento según sus particularidades: p.e. para documentos internos: Enviado, Recibido por dependencia, etc. y para documentos con destino externo: Enviado físico / Enviado electrónico y la data correspondiente?", "Hisrotial de Eventos", "06", null, null, 35], ["04. Historial de Eventos", "4.12", "Otros", "13", "¿Permite ver el detalle del registro de la auditoría seleccionada?", "Hisrotial de Eventos", "07", null, null, 36], ["04. Historial de Eventos", "4.12", "Otros", "18", "¿Permite la parametrización y/o configuración para la consulta de logs de auditoría facilitando establecer criterios de búsqueda basado en los campos de la base de datos?", "Hisrotial de Eventos", "08", null, null, 37], ["04. Historial de Eventos", "4.5", "Módulo de Administración", "46", "¿Permite mantener una historia inalterable de modificaciones (pistas de auditoría) que se realizan en los tiempos de retención y disposición, incluida la fecha del cambio o eliminación y el usuario que lo registra?", "Hisrotial de Eventos", "09", null, null, 38], ["04. Historial de Eventos", "4.9", "Metadatos", "13", "¿Permite mantener los metadatos de objetos digitales eliminados, a menos que el usuario opte por eliminarlos, quedando dicha acción registrada en el historial de eventos?", "Hisrotial de Eventos", "10", null, null, 39], ["04. Historial de Eventos", "4.12", "Otros", "14", "¿Permite la parametrización y/o configuración para consultar la trazabilidad de los documentos electrónicos en el cuadro de clasificación documental mostrando información como mínimo de qué, quién, cuándo y cómo realizó acciones en el mismo?", "Hisrotial de Eventos", "11", null, null, 40], ["04. Historial de Eventos", "4.12", "Otros", "15", "¿Permite registrar en la pista de auditoría, cuando se realice la reubicación de una carpeta (o conjunto de carpetas) o documento?", "Hisrotial de Eventos", "12", null, null, 41], ["04. Historial de Eventos", "4.12", "Otros", "16", "¿Permite generar un log de manera que todas las acciones efectuadas sobre el expediente queden registradas en un historial de eventos que puede ser consultado por usuarios que tengan acceso al expediente electrónico?", "Hisrotial de Eventos", "13", null, null, 42], ["04. Historial de Eventos", "4.12", "Otros", "17", "¿Permite la parametrización y/o configuración para generar un reporte del estado de la transferencia o exportación realizada y guardar datos de la acción realizada en las pistas de auditoría?", "Hisrotial de Eventos", "14", null, null, 43], ["04. Historial de Eventos", "4.6", "Módulo Flujo de Trabajo", "45", "¿Permite registrar toda la creación y cambios en los flujos de trabajo en el Historial de eventos?", "Hisrotial de Eventos", "15", null, null, 44], ["04. Historial de Eventos", "4.12", "Otros", "19", "¿Permite la parametrización y/o configuración para permitir la descarga del log de auditoría facilitando establecer criterios de búsqueda basado en los campos de la base de datos?", "Hisrotial de Eventos", "16", null, null, 45]], "05. Configuración": [["05. Configuración", "4.1", "Administración de Expedientes", "14", "¿Permite que un usuario autorizado realice modificaciones en cualquiera de sus \"Metadatos contextuales\"?", "01. Administración de metadatos", "01", null, null, 46], ["05. Configuración", "4.9", "Metadatos", "5", "¿Permite establecer elementos mínimos requeridos para cada metadato parametrizable y agregar u ocultar elementos?", "01. Administración de metadatos", "02", null, null, 47], ["05. Configuración", "4.9", "Metadatos", "1", "¿Permite configurar el esquema de metadatos propio de la entidad?", "01. Administración de metadatos", "03", null, null, 48], ["05. Configuración", "4.9", "Metadatos", "7", "¿Permite la parametrización de los metadatos y sus elementos, incluyendo la adición de descripciones?", "01. Administración de metadatos", "04", null, null, 49], ["05. Configuración", "4.9", "Metadatos", "11", "¿Permite ofrecer a usuarios autorizados la capacidad de crear nuevos metadatos contextuales según sea necesario?", "01. Administración de metadatos", "05", null, null, 50], ["05. Configuración", "4.9", "Metadatos", "12", "¿Permite la asociación de metadatos a un objeto digital específico?", "01. Administración de metadatos", "06", null, null, 51], ["05. Configuración", "4.9", "Metadatos", "17", "¿Permite garantizar que los metadatos tengan un tipo de dato configurado (numérico, texto, booleano, carácter, etc.), mostrando un mensaje de error orientado al usuario en caso de ingreso de datos inválidos?", "01. Administración de metadatos", "07", null, null, 52], ["05. Configuración", "4.9", "Metadatos", "2", "¿Permite la parametrización de varios niveles de metadatos asociados a una entidad?", "01. Administración de metadatos", "08", null, null, 53], ["05. Configuración", "4.10", "Módulo de Manejo Físico de Documentos", "10", "¿Permite crear, capturar y gestionar metadatos específicos para documentos físicos, como dimensiones de un plano o formato de una cinta de video?", "01. Administración de metadatos", "09", null, null, 54], ["05. Configuración", "4.9", "Metadatos", "15", "¿Permite la desactivación de un metadato contextual, impidiendo su uso en nuevos objetos, pero manteniendo la información en aquellos objetos previamente asociados?", "01. Administración de metadatos", "10", null, null, 55], ["05. Configuración", "4.9", "Metadatos", "14", "¿Permite la eliminación de metadatos contextuales que nunca hayan sido utilizados?", "01. Administración de metadatos", "11", null, null, 56], ["05. Configuración", "4.9", "Metadatos", "4", "¿Cuenta con un diccionario o servicio de metadatos?", "01. Administración de metadatos", "12", null, null, 57], ["05. Configuración", "4.5", "Módulo de Administración", "20", "¿Permite la parametrización y configuración del registro de días festivos por anualidad?", "02. Dias no laborados", "01", null, null, 58], ["05. Configuración", "4.12", "Otros", "5", "¿Permite la creación, modificación, carga masiva e individual de registros DANE de departamentos, municipios y centros poblados", "03. Entidades territoriales", "01", null, null, 59], ["05. Configuración", "4.9", "Metadatos", "8", "¿Permite aplicar manual o automáticamente plantillas activas a las entidades del sistema?", "04. Gestión de plantillas", "01", null, null, 60], ["05. Configuración", "4.4", "Radicación", "22", "¿Permite a un usuario autorizado parametrizar la estructura del código para cada tipo de comunicación?", "05. Números Consecutivos", "01", null, null, 61], ["05. Configuración", "4.4", "Radicación", "4", "¿Permite estructurar el número consecutivo para la radicación de las comunicaciones oficiales (externas e internas)?\n\nNota: El número de radicado debe ser único para cada tipo de comunicación y documento, un consecutivo propio", "05. Números Consecutivos", "02", null, null, 62], ["05. Configuración", "4.4", "Radicación", "21", "¿Permite asignar un código único y consecutivo a cada documento radicado, con la posibilidad de reiniciarse al iniciar una nueva vigencia?", "05. Números Consecutivos", "03", null, null, 63], ["05. Configuración", "4.4", "Radicación", "20", "¿Permite el reinicio automático de los consecutivos cada año nuevo?", "05. Números Consecutivos", "04", null, null, 64], ["05. Configuración", "4.4", "Radicación", "33", "¿Genera alertas vía plataforma y correo electrónico días antes del vencimiento de términos para las comunicaciones en gestión?", "06. Parametrización alertas", "01", null, null, 65], ["05. Configuración", "4.5", "Módulo de Administración", "33", "¿Permite configurar alertas de vencimiento próximo a los roles indicados por el Banco:\n\n* Responsable del trámite\n* jefe inmediato\n* Designado por Atención al cliente, etc.", "06. Parametrización alertas", "02", null, null, 66], ["05. Configuración", "4.5", "Módulo de Administración", "15", "¿Permite a un usuario autorizado configurar los tiempos de espera de inactividad para desconexión (time-out) de los usuarios?", "07. Parametrización del sistema", "01", null, null, 67], ["05. Configuración", "4.5", "Módulo de Administración", "21", "¿Permite la parametrización y configuración de Estados de trámite de comunicaciones oficiales y otros documentos?", "07. Parametrización del sistema", "02", null, null, 68], ["05. Configuración", "4.8", "Prestamos", "4", "¿Permite la configuración de los tiempos de vencimiento, la aceptación, rechazo o renovación de los préstamos y las consultas?", "07. Parametrización del sistema", "03", null, null, 69], ["05. Configuración", "4.1", "Administración de Expedientes", "12", "¿Permite la gestión y administración de los metadatos establecidos en el esquema correspondiente a los documentos de archivo?", "07. Parametrización del sistema", "04", null, null, 70], ["05. Configuración", "4.5", "Módulo de Administración", "27", "¿Permite configurar servicios de gestión prioritaria o diferencial (Derechos de petición, tutelas y los demás indicados por el Banco)?", "07. Parametrización del sistema", "05", null, null, 71], ["05. Configuración", "4.9", "Metadatos", "3", "¿Permite que los metadatos y entidades sean predeterminados por el sistema?", "07. Parametrización del sistema", "06", null, null, 72], ["05. Configuración", "4.5", "Módulo de Administración", "29", "¿Permite la configuración para el cargue de documentos digitales anexos a radicaciones - contemplar grandes tamaños de fichero?", "07. Parametrización del sistema", "07", null, null, 73], ["05. Configuración", "4.1", "Administración de Expedientes", "13", "¿Permite crear tomos por expedientes, utilizando parámetros de tamaño configurados por un usuario autorizado?", "07. Parametrización del sistema", "08", null, null, 74], ["05. Configuración", "4.5", "Módulo de Administración", "23", "¿Permite configurar los servicios de mensajería externa y Courier?", null, null, null, null, 75], ["05. Configuración", "4.5", "Módulo de Administración", "25", "¿Permite configurar servicios de prueba de entrega en correo electrónico certificado?", null, null, null, null, 76]], "06. Alertas": [["06. Alertas", "4.2", "Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación", "17", "¿Genera alertas cuando un expediente esté próximo a cumplir los tiempos de retención?", null, null, null, null, 77], ["06. Alertas", "4.6", "Módulo Flujo de Trabajo", "60", "¿Permite notificar a un usuario participante cuando un archivo o registro ha sido recibido en su bandeja de entrada y está pendiente de atención?", null, null, null, null, 78], ["06. Alertas", "4.6", "Módulo Flujo de Trabajo", "62", null, null, null, null, null, 79]], "07. Clasificación Documental": [["07. Clasificación Documental", "4.12", "Otros", "2", "¿Permite la caracterización de tipos documentales por agrupación?", "01. Cargar CCD", "01", null, null, 80], ["07. Clasificación Documental", "4.2", "Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación", "6", "¿Permite la inclusión de múltiples versiones del cuadro de clasificación documental?", "02. Gestionar Versiones de TRD", "01", null, null, 81], ["07. Clasificación Documental", "4.2", "Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación", "14", "¿Permite a un usuario autorizado explorar las versiones de TRD o TVD en el servicio de retención y disposición, así como examinar sus metadatos?", "02. Gestionar Versiones de TRD", "02", null, null, 82], ["07. Clasificación Documental", "4.2", "Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación", "15", "¿Permite a usuarios autorizados reemplazar una versión de TRD o TVD únicamente para expedientes activos, sin eliminar ni destruir la versión anterior?", "02. Gestionar Versiones de TRD", "03", null, null, 83], ["07. Clasificación Documental", "4.2", "Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación", "16", "¿Verifica cambios en los tiempos de retención y actualiza automáticamente los expedientes y metadatos si es necesario al cargar una nueva versión de la TRD o la TVD?", "02. Gestionar Versiones de TRD", "04", null, null, 84], ["07. Clasificación Documental", "4.9", "Metadatos", "9", "¿Permite asegurar que los datos agregados a una serie, subserie, expediente, documento o cualquier otra entidad del sistema nunca se eliminen mientras la entidad esté activa?", "02. Gestionar Versiones de TRD", "05", null, null, 85], ["07. Clasificación Documental", "4.5", "Módulo de Administración", "36", "¿Permite configurar los formularios de descripción de cada una de las agrupaciones documentales vigentes según TRD, de acuerdo con las características o metadatos descriptivos particulares para cada agrupación. Al generarse la creación de un nuevo expediente de cada agrupación, el SGDEA deberá exponer al usuario que adelanta la creación, el formulario específico para diligenciar los campos aplicables a la misma?", "02. Gestionar Versiones de TRD", "06", null, null, 86], ["07. Clasificación Documental", "4.2", "Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación", "3", "¿Permite realizar la creación, importación, exportación, parametrización, automatización, administración y versionamiento de TRD?", "03. Versión", "01", null, null, 87], ["07. Clasificación Documental", "4.2", "Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación", "8", "¿Permite a un usuario autorizado añadir nuevos niveles a la estructura del cuadro de clasificación documental?", "04. Ver cuadro", "01", null, null, 88], ["07. Clasificación Documental", "4.2", "Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación", "9", "¿Permite a usuarios autorizados eliminar niveles que nunca hayan sido utilizados en la estructura del cuadro de clasificación documental?", "04. Ver cuadro", "02", null, null, 89], ["07. Clasificación Documental", "4.2", "Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación", "5", "¿Permite garantizar la herencia de atributos de clases?", "04. Ver cuadro", "03", null, null, 90], ["07. Clasificación Documental", "4.2", "Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación", "7", "¿Permite la herencia de metadatos y atributos desde elementos padres hacia elementos hijos?", "04. Ver cuadro", "04", null, null, 91], ["07. Clasificación Documental", "4.2", "Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación", "26", "¿Permite a un usuario autorizado modificar la disposición final de una serie y/o subserie?", "04. Ver cuadro", "05", null, null, 92], ["07. Clasificación Documental", "4.2", "Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación", "4", "¿Permite garantizar que los documentos producidos y asociados a una TRD mantendrán los criterios de tiempos y de disposición final de la versión correspondiente?", "04. Ver cuadro", "06", null, null, 93], ["07. Clasificación Documental", "4.1", "Administración de Expedientes", "45", "¿Permite configurar la creación automática de expedientes por anualidad según disposiciones del BAC en aplicación de TRD", "04. Ver cuadro", "07", null, null, 94], ["07. Clasificación Documental", "4.1", "Administración de Expedientes", "42", "¿Permite parametrizar y configurar los servicios de acceso controlado a expediente y documentos en aplicación de las disposiciones definidas en TCA e IICR, así como las excepciones indicadas por el productor de cada expediente / documento?", "04. Ver cuadro", "08", null, null, 95], ["07. Clasificación Documental", "4.7", "Tablas De Control De Acceso", "2", "¿Permite crear automáticamente una “Lista de control de acceso” para cada servicio o conjunto de servicios y para cada entidad?", "04. Ver cuadro", "09", null, null, 96], ["07. Clasificación Documental", "4.1", "Administración de Expedientes", "17", "¿Permite la inactivación de series y/o subseries, siempre y cuando los expedientes asociados estén cerrados?", "05. Series/subseries", "01", null, null, 97], ["07. Clasificación Documental", "4.1", "Administración de Expedientes", "27", "¿Permite a un usuario autorizado personalizar los criterios de ordenación para cada serie documental?", "05. Series/subseries", "02", null, null, 98], ["07. Clasificación Documental", "4.1", "Administración de Expedientes", "28", "¿Organiza los expedientes según el criterio de ordenación establecido para cada serie?", "05. Series/subseries", "03", null, null, 99], ["07. Clasificación Documental", "4.1", "Administración de Expedientes", "44", "¿Permite configurar los servicios de ordenación y paginación automática de documentos al interior de cada expediente según disposición del rol administrador (por fecha de documento, por fecha de indexación en expediente, por foliación manual u otra)?", "05. Series/subseries", "04", null, null, 100]], "08. Flujos de Trabajo": [["08. Flujos de Trabajo", "4.9", "Metadatos", "19", "¿Permite asegurar que los campos de tipo fecha desplieguen un calendario para facilitar y normalizar el ingreso de datos?", "Administración de Formularios", null, null, null, 101], ["08. Flujos de Trabajo", "4.9", "Metadatos", "20", "¿Permite la incorporación de diferentes esquemas de metadatos?", "Administración de Formularios", null, null, null, 102], ["08. Flujos de Trabajo", "4.4", "Radicación", "32", "¿Permite la configuración de calendarios y contadores de tiempos en días hábiles, horas y minutos laborales, así como días calendario, horas y minutos calendario?", "Dias no laborales", null, null, null, 103], ["08. Flujos de Trabajo", "4.3", "Producción", "12", "¿Permite asociar cada formato y formulario a un proceso, procedimiento y/o trámite?", "Editor de flujos", null, null, null, 104], ["08. Flujos de Trabajo", "4.3", "Producción", "15", "¿Permite la configuración de listas de control de acceso para los formatos y formularios en el sistema?", "Editor de flujos", null, null, null, 105], ["08. Flujos de Trabajo", "4.6", "Módulo Flujo de Trabajo", "1", "¿Permite el sistema mecanismos de simulación para analizar los flujos de trabajo modelados?", "Editor de flujos", null, null, null, 106], ["08. Flujos de Trabajo", "4.6", "Módulo Flujo de Trabajo", "2", "¿Permite parametrizar los accesos, la creación, modificación o control total para usuarios o grupos de usuarios en los flujos de trabajo electrónicos?", "Editor de flujos", null, null, null, 107], ["08. Flujos de Trabajo", "4.6", "Módulo Flujo de Trabajo", "3", "¿Permite garantizar que todos los documentos conserven los vínculos con el flujo de trabajo correspondiente?", "Editor de flujos", null, null, null, 108], ["08. Flujos de Trabajo", "4.6", "Módulo Flujo de Trabajo", "5", "¿Permite contener múltiples versiones de un mismo proceso y/o procedimiento, y así seleccionar la última versión?", "Editor de flujos", null, null, null, 109], ["08. Flujos de Trabajo", "4.6", "Módulo Flujo de Trabajo", "10", "¿Permite la asignación automática de tareas entre los integrantes de un equipo?", "Editor de flujos", null, null, null, 110], ["08. Flujos de Trabajo", "4.6", "Módulo Flujo de Trabajo", "23", "¿Permite que el esquema de numeración de versiones se configure durante la instalación?", "Editor de flujos", null, null, null, 111], ["08. Flujos de Trabajo", "4.6", "Módulo Flujo de Trabajo", "51", "¿Permite la inclusión automática de un documento como archivo en una actividad específica dentro del flujo de trabajo?", "Editor de flujos", null, null, null, 112], ["08. Flujos de Trabajo", "4.3", "Producción", "2", "¿Permite modificar o crear plantillas o formularios dependiendo del trámite requerido?", "Editor de formularios", null, null, null, 113], ["08. Flujos de Trabajo", "4.3", "Producción", "3", "¿Permite y cuenta con la autonomía para la actualización de las plantillas o formularios una vez se haya terminado la implementación?", "Editor de formularios", null, null, null, 114], ["08. Flujos de Trabajo", "4.3", "Producción", "8", "¿Permite la asignación de las Series y Subseries por medio de los flujogramas o diagramas de flujo?", "Editor de formularios", null, null, null, 115], ["08. Flujos de Trabajo", "4.3", "Producción", "10", "¿Permite a un usuario autorizado agregar nuevos formatos y formularios, con validaciones de entrada en los campos según sea necesario?", "Editor de formularios", null, null, null, 116], ["08. Flujos de Trabajo", "4.3", "Producción", "11", "¿Permite la edición de formatos y formularios por parte de usuarios autorizados?", "Editor de formularios", null, null, null, 117], ["08. Flujos de Trabajo", "4.3", "Producción", "13", "¿Permite y dispone de la opción de incorporar listas de control de acceso para los formatos y formularios?", "Editor de formularios", null, null, null, 118], ["08. Flujos de Trabajo", "4.3", "Producción", "14", "¿Permite la parametrización de formatos y/o formularios, con validaciones de entrada en los campos según sea necesario?", "Editor de formularios", null, null, null, 119], ["08. Flujos de Trabajo", "4.4", "Radicación", "2", "¿Permite y contiene campos obligatorios en el sistema que se pueden parametrizar?", "Editor de formularios", null, null, null, 120], ["08. Flujos de Trabajo", "4.5", "Módulo de Administración", "30", "¿Permite el diseño, configuración e implementación de formularios especializados para radicación de PQRSD?", "Editor de formularios", null, null, null, 121], ["08. Flujos de Trabajo", "4.5", "Módulo de Administración", "31", "¿Permite el diseño, configuración e implementación de formularios especializados para el seguimiento al trámite de PQRSD?", "Editor de formularios", null, null, null, 122], ["08. Flujos de Trabajo", "4.6", "Módulo Flujo de Trabajo", "25", "¿Permite alertar al usuario ante conflictos de metadatos entre el servicio de documentos archivados y el servicio colaborativo?", "Editor de formularios", null, null, null, 123], ["08. Flujos de Trabajo", "4.6", "Módulo Flujo de Trabajo", "39", "¿Permite la integración de flujos de trabajo predefinidos según funciones institucionales, asignando automáticamente tareas como la derivación de una tutela al área jurídica?", "Editor de formularios", null, null, null, 124], ["08. Flujos de Trabajo", "4.6", "Módulo Flujo de Trabajo", "40", "¿Permite que los roles de usuarios autorizados definan, utilicen y guarden flujos de trabajo nuevos para casos especiales?", "Editor de formularios", null, null, null, 125], ["08. Flujos de Trabajo", "4.6", "Módulo Flujo de Trabajo", "42", "¿Permite restringir la modificación de flujos de trabajo preprogramados a funciones administrativas o usuarios autorizados?", "Editor de formularios", null, null, null, 126], ["08. Flujos de Trabajo", "4.6", "Módulo Flujo de Trabajo", "43", "¿Permite guardar una copia del flujo de trabajo antes de efectuar cambios y asignar automáticamente un nuevo número de versión?", "Editor de formularios", null, null, null, 127], ["08. Flujos de Trabajo", "4.6", "Módulo Flujo de Trabajo", "44", "¿Impone límites al número de flujos de trabajo que puedan ser definidos y almacenados?", "Editor de formularios", null, null, null, 128], ["08. Flujos de Trabajo", "4.6", "Módulo Flujo de Trabajo", "46", "¿Incluye una interfaz gráfica para que los usuarios administren las funciones relacionadas con la definición, mantenimiento y edición de flujos de trabajo?", "Editor de formularios", null, null, null, 129], ["08. Flujos de Trabajo", "4.6", "Módulo Flujo de Trabajo", "52", "¿Limita el número de actividades (pasos) en cada flujo de trabajo?", "Editor de formularios", null, null, null, 130], ["08. Flujos de Trabajo", "4.6", "Módulo Flujo de Trabajo", "8", "¿Permite realizar la distribución automática de cargas de trabajo entre los miembros del grupo mediante un balanceador de cargas?", "Ejecución de instancia", null, null, null, 131], ["08. Flujos de Trabajo", "4.6", "Módulo Flujo de Trabajo", "6", "¿Permite garantizar que los documentos de un flujo queden asociados a un mismo expediente de acuerdo con las TRD?", "Instancias", null, null, null, 132], ["08. Flujos de Trabajo", "4.6", "Módulo Flujo de Trabajo", "49", "¿Permite a usuarios autorizados monitorear y gestionar las colas de trabajo?", "Instancias", null, null, null, 133], ["08. Flujos de Trabajo", "4.6", "Módulo Flujo de Trabajo", "50", "¿Posibilita que los usuarios monitoreen el progreso de los flujos de trabajo en los que participan?", "Instancias", null, null, null, 134], ["08. Flujos de Trabajo", "4.6", "Módulo Flujo de Trabajo", "4", "¿Permite visualizar el estado de cada flujo de trabajo electrónico?", "Ver Instancia", null, null, null, 135], ["08. Flujos de Trabajo", "4.6", "Módulo Flujo de Trabajo", "9", "¿Permite a los usuarios monitorear el progreso de los flujos de trabajo iniciados y en los que participan?", "Ver Instancia", null, null, null, 136], ["08. Flujos de Trabajo", "4.5", "Módulo de Administración", "7", "¿Permite que un solo usuario autorizado modifique metadatos y valores, limitándose a aquellos especificados como variables en el modelo de metadatos?", null, null, null, null, 137], ["08. Flujos de Trabajo", "4.6", "Módulo Flujo de Trabajo", "53", "¿Permite la priorización de tareas y/o actividades en cola?", null, null, null, null, 138], ["08. Flujos de Trabajo", "4.6", "Módulo Flujo de Trabajo", "54", "¿Permite que el usuario autorizado defina el número máximo de actividades (pasos) a ejecutar en un intervalo de tiempo según el trámite?", null, null, null, null, 139], ["08. Flujos de Trabajo", "4.6", "Módulo Flujo de Trabajo", "55", "¿Permite parametrizar el tiempo límite para cada actividad (paso) y para el flujo en general, generando reportes y alertas para usuarios autorizados?", null, null, null, null, 140], ["08. Flujos de Trabajo", "4.6", "Módulo Flujo de Trabajo", "56", "¿Permite a un usuario autorizado configurar y administrar una lista predeterminada de acciones para una actividad (paso) en un flujo de trabajo?", null, null, null, null, 141], ["08. Flujos de Trabajo", "4.6", "Módulo Flujo de Trabajo", "57", "¿Permite a usuarios autorizados reasignar tareas y/o acciones a un usuario o grupo diferente?", null, null, null, null, 142], ["08. Flujos de Trabajo", "4.6", "Módulo Flujo de Trabajo", "58", "¿Permite establecer condicionales en los flujos de trabajo según datos de entrada para determinar la dirección del flujo?", null, null, null, null, 143], ["08. Flujos de Trabajo", "4.6", "Módulo Flujo de Trabajo", "59", "¿Permite a un usuario autorizado suspender temporalmente un flujo para atender otro trabajo y reanudarlo más tarde, incluso después de cerrar sesión en el sistema?", null, null, null, null, 144], ["08. Flujos de Trabajo", "4.6", "Módulo Flujo de Trabajo", "61", "¿Permite programar recordatorios para acceder a un archivo o registro en una fecha futura, sin exceder la fecha de vencimiento del flujo de trabajo?", null, null, null, null, 145], ["08. Flujos de Trabajo", "4.6", "Módulo Flujo de Trabajo", "63", "¿Permite la recepción automática de documentos en carpetas específicas para activar flujos de trabajo, según el tipo documental o metadatos?", null, null, null, null, 146], ["08. Flujos de Trabajo", "4.6", "Módulo Flujo de Trabajo", "65", "¿Permite generar flujos de trabajo en un formato estándar de modelado de workflow como XPDL y WF-XML?", null, null, null, null, 147], ["08. Flujos de Trabajo", "4.6", "Módulo Flujo de Trabajo", "66", "¿Permite la exportación de flujos de trabajo o partes constituyentes en formato XML-XPDL?", null, null, null, null, 148], ["08. Flujos de Trabajo", "4.6", "Módulo Flujo de Trabajo", "67", "¿Permite identificar cada trámite como abierto o cerrado?", null, null, null, null, 149], ["08. Flujos de Trabajo", "4.6", "Módulo Flujo de Trabajo", "69", "¿Permite el cierre automático del expediente al registrar la finalización del trámite por un usuario autorizado, ya sea individual o en lote?", null, null, null, null, 150], ["08. Flujos de Trabajo", "4.6", "Módulo Flujo de Trabajo", "70", "¿Permite a un usuario autorizado eliminar un flujo de trabajo que nunca ha sido utilizado?", null, null, null, null, 151], ["08. Flujos de Trabajo", "4.6", "Módulo Flujo de Trabajo", "71", "¿Permite a un usuario autorizado destruir un flujo de trabajo que no esté vigente?", null, null, null, null, 152], ["08. Flujos de Trabajo", "4.6", "Módulo Flujo de Trabajo", "72", "Permite Modelar campos de contenido, metadatos, flujos de aprobación, cargue de anexos, firma y demás servicios asociados a la producción nativa a través de formularios en el SGDEA de los siguientes documentos:\n\n* Oficio: Comunicaciones oficiales de salida\n* Memorando: Comunicaciones oficiales internas\n* Acta\n* Informe\n* Concepto técnico\n* Concepto jurídico\n* Certificado laboral\n* Paz y Salvo\n* Auto\n* Circular interna: Comunicaciones oficiales internas dirigidas a un grupo de destinatarios agrupados por roles", null, null, null, null, 153], ["08. Flujos de Trabajo", "4.6", "Módulo Flujo de Trabajo", "73", "¿Permite configurar flujos de distribución interna de documentos (correspondencia y aquellos de creación nativo digital) según las particularidades de cada uno?", null, null, null, null, 154], ["08. Flujos de Trabajo", "4.6", "Módulo Flujo de Trabajo", "74", "¿Permite configurar flujos de distribución interna de documentos individual o masiva, requiriendo respuesta o netamente informativos?", null, null, null, null, 155], ["08. Flujos de Trabajo", "4.6", "Módulo Flujo de Trabajo", "75", "¿Permite configurar flujo de revisión y aprobación (o devolución, total o parcial) de transferencia primaria por administración del Archivo Central", null, null, null, null, 156], ["08. Flujos de Trabajo", "4.9", "Metadatos", "10", "¿Permite operar con todos los metadatos definidos en el esquema correspondiente?", null, null, null, null, 157], ["08. Flujos de Trabajo", "4.9", "Metadatos", "16", "¿Permite mostrar breves descripciones y ejemplos de uso para cada metadato?", null, null, null, null, 158]], "09. Correspondencia": [["09. Correspondencia", "4.6", "Módulo Flujo de Trabajo", "7", "¿Permite mostrar semáforos que indiquen el cumplimiento de tiempos en cada una de las actividades de un flujo?", "Bandejas", null, null, null, 159], ["09. Correspondencia", "4.3", "Producción", "17", "¿Permite la producción documental a través de formatos de fichero longevos avalados para adelantar procesos de migración en aplicación de estrategia de preservación digital?", "Carga de documentos", null, null, null, 160], ["09. Correspondencia", "4.5", "Módulo de Administración", "38", "¿Permite configurar la aplicación de procesos internos en el SGDEA de migración de fichero a formatos longevos al cierre del expediente o por demanda, según lo defina el BAC?", "carga de documentos", null, null, null, 161], ["09. Correspondencia", "4.6", "Módulo Flujo de Trabajo", "28", "¿Permite autorizar a un usuario a capturar un documento en formato propietario y guardarlo en múltiples formatos abiertos, asegurando la cadena de custodia del documento?", "Carga de documentos", null, null, null, 162], ["09. Correspondencia", "4.6", "Módulo Flujo de Trabajo", "41", "¿Permite la parametrización y administración de diferentes tipos de formatos electrónicos definidos por la entidad, alertando al usuario ante intentos de cargar formatos no permitidos?", "Carga de documentos", null, null, null, 163], ["09. Correspondencia", "4.9", "Metadatos", "21", "¿Permite la captura automática de metadatos de un documento?", "Carga de documentos", null, null, null, 164], ["09. Correspondencia", "4.1", "Administración de Expedientes", "8", "¿Permite el cargue de información contenida en soportes heterogéneos (discos ópticos, discos duros, etc.)?", "Carga de documentos", null, null, null, 165], ["09. Correspondencia", "4.4", "Radicación", "3", "¿Permite la asignación de series y subseries desde el formulario de radicación y dispone de opciones parametrizables?", "Carga de documentos", null, null, null, 166], ["09. Correspondencia", "4.5", "Módulo de Administración", "32", "¿Permite el diseño, configuración e implementación de formularios especializados para publicación de documentos en cumplimiento de notificación por aviso?", "Contactos", null, null, null, 167], ["09. Correspondencia", "4.12", "Otros", "4", "¿Permite la creación, modificación y la carga masiva e individual de particulares (usuarios externos) y clientes bancarios?", "Directorio de Contactos", null, null, null, 168], ["09. Correspondencia", "4.6", "Módulo Flujo de Trabajo", "34", "¿Permite asegurar la vinculación automática del certificado de entrega con el correo electrónico, permitiendo una fácil navegación entre ambos registros?", "Envio", null, null, null, 169], ["09. Correspondencia", "4.4", "Radicación", "31", "¿Cuenta con un módulo web para la radicación de PQRSD, comunicando el código, términos legales y permitiendo asignar la comunicación a una dependencia específica?", "Portal web", null, null, null, 170], ["09. Correspondencia", "4.6", "Módulo Flujo de Trabajo", "33", "¿Permite identificar automáticamente y capturar todos los correos electrónicos relacionados con uno especificado por el usuario en una sola operación, permitiendo la captura como un único documento o como un conjunto, según la preferencia del usuario?", "Radicación de correos electronicos", null, null, null, 171], ["09. Correspondencia", "4.6", "Módulo Flujo de Trabajo", "36", "¿Permite que un usuario autorizado clasifique un correo electrónico dentro del Cuadro de Clasificación Documental en su nivel de expediente?", "Radicación de correos electronicos", null, null, null, 172], ["09. Correspondencia", "4.3", "Producción", "16", "¿Permite la producción documental a través de formatos de fichero avalados para recepción o cargue de documentos al SGDEA por los diferentes servicios?", "Radicado de entrada", null, null, null, 173], ["09. Correspondencia", "4.1", "Administración de Expedientes", "20", "¿Posibilita la incorporación de documentos de archivo, ya sean creados dentro o fuera del sistema, en un expediente abierto, garantizando que estos documentos hereden los metadatos del expediente?", "Radicado de Salida", null, null, null, 174], ["09. Correspondencia", "4.2", "Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación", "2", "¿Permite asociar cada documento a una serie y/o subserie, expediente y un tipo documental desde el proceso de captura?", "Radicado de Salida", null, null, null, 175], ["09. Correspondencia", "4.3", "Producción", "18", "¿Permite generar la versión del documento firmada y \"radicada\" en formato Pdf/a 1b e impedir modificación o alteración del documento principal o sus anexos una vez firmada?", "Radicado de Salida", null, null, null, 176], ["09. Correspondencia", "4.4", "Radicación", "29", "¿Permite la vinculación de comunicaciones oficiales a una serie o subserie documental definida en el cuadro de clasificación documental?", "Radicado de Salida", null, null, null, 177], ["09. Correspondencia", "4.4", "Radicación", "35", "¿Permite establecer relaciones entre dos comunicaciones (solicitud - respuesta)?", "Radicado de Salida", null, null, null, 178], ["09. Correspondencia", "4.4", "Radicación", "37", "¿Permite el diligenciamiento de un formulario breve para generar un código de radicado inmediato, con la opción de continuar el proceso bajo el mismo código?", "Radicado de Salida", null, null, null, 179], ["09. Correspondencia", "4.4", "Radicación", "39", "¿Cuenta e incluye un módulo de digitalización con características configurables como resolución, profundidad de bits, escala, compresión, OCR, ICR y opciones para guardar en varios formatos electrónicos (PDF/A, TIFF, JPG, entre otros)?", "Radicado de Salida", null, null, null, 180], ["09. Correspondencia", "4.4", "Radicación", "42", "Permite configurar y parametrizar servicios de producción masiva de comunicaciones oficiales (Oficio - Memorando) para las siguientes condiciones:\n1. El mismo contenido emitido para una lista de destinatarios (combinación de correspondencia), con radicaciones diferentes\n2. Un documento remitido a un destinatario y copiado a múltiples destinos\n3. El mismo contenido dirigido a un grupo de usuarios o destinatarios externos de forma genérica", "Radicado de Salida", null, null, null, 181], ["09. Correspondencia", "4.5", "Módulo de Administración", "28", "¿Permite configurar la radicación automática o por demanda (según disposición del Banco) de radicaciones por correo electrónico, formularios web, registro de contacto presencial y telefónico y, captura de mensaje de datos por redes sociales oficiales?", "Radicado de Salida", null, null, null, 182], ["09. Correspondencia", "4.6", "Módulo Flujo de Trabajo", "14", "¿Tiene la capacidad de transformar los documentos en fase de elaboración en documentos archivados, según sea necesario?", "Radicado de Salida", null, null, null, 183], ["09. Correspondencia", "4.6", "Módulo Flujo de Trabajo", "15", "¿Permite a los usuarios avanzar en la elaboración de documentos sin necesidad de clasificarlos como documentos archivados?", "Radicado de Salida", null, null, null, 184], ["09. Correspondencia", "4.6", "Módulo Flujo de Trabajo", "29", "¿Permite gestionar documentos adjuntos, asegurando la vinculación con su documento principal sin usar formatos de compresión?", "Radicado de Salida", null, null, null, 185], ["09. Correspondencia", "4.4", "Radicación", "1", "¿Permite niveles de parametrización para el formulario de radicación?", "Radicado de Salida", null, null, null, 186], ["09. Correspondencia", "4.4", "Radicación", "6", "¿Permite la impresión de rótulos o radicación, así como la reimpresión por el administrador para casos especiales?", "Radicado de Salida", null, null, null, 187], ["09. Correspondencia", "4.4", "Radicación", "7", "¿Permite la actualización de la metadata asociada a una radicación, dejando el registro de auditoría y ejecutando automáticamente las reglas de negocio y los flujos de trabajo correspondientes?", "Radicado de Salida", null, null, null, 188], ["09. Correspondencia", "4.6", "Módulo Flujo de Trabajo", "18", "¿Permite a un usuario autorizado registrar observaciones sobre cambios en un documento en fase de elaboración antes de archivarlo en el sistema?", "Trabajo Colaborativo", null, null, null, 189], ["09. Correspondencia", "4.6", "Módulo Flujo de Trabajo", "19", "¿Previene la edición de un documento en fase de elaboración cuando un usuario autorizado haya cancelado o detenido la edición previamente?", "Trabajo Colaborativo", null, null, null, 190], ["09. Correspondencia", "4.6", "Módulo Flujo de Trabajo", "22", "¿Permite actualizar automáticamente las versiones de los documentos en fase de elaboración?", "Trabajo Colaborativo", null, null, null, 191], ["09. Correspondencia", "4.6", "Módulo Flujo de Trabajo", "24", "¿Permite que un usuario autorizado mantenga los metadatos del servicio colaborativo al trasladar el documento al servicio de documentos archivados?", "Trabajo Colaborativo", null, null, null, 192], ["09. Correspondencia", "4.6", "Módulo Flujo de Trabajo", "68", "¿Permite registrar en cada documento los datos del usuario que proyectó, revisó y aprobó cuando sea necesario?", "Trabajo Colaborativo", null, null, null, 193], ["09. Correspondencia", "4.5", "Módulo de Administración", "3", "¿Permite la reasignación de trámites pendientes cuando el usuario responsable no está disponible (vacaciones, licencias, retiro, etc.)?", null, null, null, null, 194], ["09. Correspondencia", "4.5", "Módulo de Administración", "22", "¿Permite configurar los tipos documentales que consumirán servicios de envío por correo electrónico certificado. P.e Respuestas a Derechos de petición, tutelas, comunicaciones en cumplimiento de asuntos judiciales?", null, null, null, null, 195], ["09. Correspondencia", "4.3", "Producción", "9", "¿Permite gestionar los traslados entre áreas?", null, null, null, null, 196], ["09. Correspondencia", "4.4", "Radicación", "8", "¿Permite asociar dos o más radicaciones a un mismo asunto, tema, servicio, proceso o trámite?", null, null, null, null, 197], ["09. Correspondencia", "4.4", "Radicación", "9", "¿Permite desasociar una radicación?", null, null, null, null, 198], ["09. Correspondencia", "4.4", "Radicación", "12", "¿Permite el seguimiento de los tiempos de respuesta de las comunicaciones oficiales y otros asuntos como PQRS?", null, null, null, null, 199], ["09. Correspondencia", "4.4", "Radicación", "13", "¿Permite la radicación de comunicaciones anónimas y los mecanismos para emitir o publicar la respuesta?", null, null, null, null, 200], ["09. Correspondencia", "4.4", "Radicación", "14", "¿Permite la radicación directamente desde el sistema de comunicaciones recibidas por correo electrónico?", null, null, null, null, 201], ["09. Correspondencia", "4.4", "Radicación", "15", "¿Permite radicar o recibir comunicaciones a través de diferentes canales, como Sede Electrónica, Chat, Redes Sociales, Teléfono, etc.?", null, null, null, null, 202], ["09. Correspondencia", "4.4", "Radicación", "17", "¿Permite gestionar los traslados por competencia cuando la comunicación es de competencia de otra área y verificar el reporte del flujo de la reasignación entre diferentes áreas?", null, null, null, null, 203], ["09. Correspondencia", "4.4", "Radicación", "18", "¿Permite gestionar los traslados por competencia cuando la comunicación es de competencia de otra entidad?", null, null, null, null, 204], ["09. Correspondencia", "4.4", "Radicación", "19", "¿Permite la integración con el sistema del proveedor de servicios postales para consultar los reportes de entrega y devolución?", null, null, null, null, 205], ["09. Correspondencia", "4.4", "Radicación", "23", "¿Permite la adición de uno o varios destinatarios, así como la generación de copias para múltiples destinatarios en una misma comunicación oficial?", null, null, null, null, 206], ["09. Correspondencia", "4.4", "Radicación", "25", "¿Permite la inclusión de anexos en diferentes formatos digitales (texto, audio, imagen, video, etc.) en una comunicación oficial?", null, null, null, null, 207], ["09. Correspondencia", "4.4", "Radicación", "26", "¿Permite agregar listas de usuarios como destinatarios o copias en una comunicación oficial?", null, null, null, null, 208], ["09. Correspondencia", "4.4", "Radicación", "27", "¿Permite la asignación de una comunicación a un usuario responsable de su gestión?", null, null, null, null, 209], ["09. Correspondencia", "4.4", "Radicación", "28", "¿Permite reasignar la gestión de una comunicación a otro usuario responsable?", null, null, null, null, 210], ["09. Correspondencia", "4.4", "Radicación", "30", "¿Permite el inicio del trámite de una comunicación oficial con configuración de flujo documental?", null, null, null, null, 211], ["09. Correspondencia", "4.4", "Radicación", "34", "¿Se integra con los servicios del operador postal para consultar comprobantes de entrega o devolución?", null, null, null, null, 212], ["09. Correspondencia", "4.4", "Radicación", "38", "¿Permite y exige una justificación para aceptar la anulación de una comunicación oficial?", null, null, null, null, 213], ["09. Correspondencia", "4.4", "Radicación", "40", "¿Permite a un usuario autorizado deshacer la anulación de una comunicación oficial, requiriendo una justificación, y registrando la acción tanto en el historial de eventos como en los metadatos?", null, null, null, null, 214], ["09. Correspondencia", "4.4", "Radicación", "41", "¿Permite el registro de etapas de trámite por agrupación documental?", null, null, null, null, 215], ["09. Correspondencia", "4.4", "Radicación", "43", "Permite procesos masivos para la captura de documentos digitalizados a través de servicios del SGDEA a nivel de:\n\n* Correspondencia\n* Digitalización por tipo documental", null, null, null, null, 216], ["09. Correspondencia", "4.6", "Módulo Flujo de Trabajo", "26", "¿Permite y facilita la producción y captura exclusiva de documentos señalados en la tabla de retención documental?", null, null, null, null, 217], ["09. Correspondencia", "4.6", "Módulo Flujo de Trabajo", "30", "¿Se integra al servidor de correo electrónico para permitir a los usuarios capturar correos electrónicos desde la aplicación de correo sin cambiar al SGDEA?", null, null, null, null, 218], ["09. Correspondencia", "4.6", "Módulo Flujo de Trabajo", "31", "¿Permite la captura individual o masiva de correos electrónicos recibidos o enviados (incluyendo adjuntos), garantizando su formato electrónico de archivo junto a sus metadatos (fecha/hora de envío, recibo, destinatario, destinatario copia, asunto, remitente, encabezado, entre otros), mediante opciones como: \na. Captura automática, b. Determinación de correos a capturar a partir de reglas de correo, c. Selección del usuario a partir de opciones en el sistema, d. Captura manual del usuario?", null, null, null, null, 219], ["09. Correspondencia", "4.6", "Módulo Flujo de Trabajo", "32", "¿Permite capturar los anexos de un correo electrónico de forma individual, manteniendo la conexión con el correo correspondiente y facilitando la navegación bidireccional entre el correo y sus adjuntos?", null, null, null, null, 220], ["09. Correspondencia", "4.6", "Módulo Flujo de Trabajo", "35", "¿Permite, en la captura de un correo electrónico como documento de archivo, la inclusión del nombre de usuario del buzón (si está presente) junto con su dirección de correo electrónico como metadato?", null, null, null, null, 221], ["09. Correspondencia", "4.6", "Módulo Flujo de Trabajo", "48", "¿Permite garantizar que todos los documentos conserven sus vínculos con el flujo de trabajo correspondiente?", null, null, null, null, 222]], "10. Firmas": [["10. Firmas", "4.4", "Radicación", "16", "¿Permite la firma electrónica o digital de las comunicaciones por correo electrónico?", "01. Firmar documentos", "01", null, null, 223], ["10. Firmas", "4.3", "Producción", "5", "¿Permite soportar las firmas digitales de cualquier entidad de certificación digital?", "01. Firmar documentos", "02", null, null, 224], ["10. Firmas", "4.3", "Producción", "6", "¿Permite el firmado por varios usuarios en el caso de firmas digitales?", "01. Firmar documentos", "03", null, null, 225], ["10. Firmas", "4.3", "Producción", "7", "¿Permite el firmado por varios usuarios en el caso de firmas electrónicas?", "01. Firmar documentos", "04", null, null, 226], ["10. Firmas", "4.6", "Módulo Flujo de Trabajo", "38", "¿Permite la integración de un estampado cronológico?", "01. Firmar documentos", "05", null, null, 227], ["10. Firmas", "4.5", "Módulo de Administración", "24", "¿Permite configurar los servicios de consumo de estampas cronológicas para los eventos definidos por el Banco?", "01. Firmar documentos", "06", null, null, 228], ["10. Firmas", "4.12", "Otros", "6", "¿Permite registrar la trazabilidad de producción del documento (ej. Proyectante, editor, revisores, firmantes) capturando a través de los datos del sistema, el usuario que adelantó la acción y la metadata de fecha y hora de cada evento?", "02. Documentos enviados a firmar", "01", null, null, 229], ["10. Firmas", "4.6", "Módulo Flujo de Trabajo", "37", "¿Permite la habilitación de una o varias firmas electrónicas y/o digitales para un documento, como Confirmación y Contrafirma?", "02. Documentos enviados a firmar", "02", null, null, 230]], "11. Acto Administrativo": [["11. Acto Administrativo", "4.4", "Radicación", "10", "¿Permite registrar y controlar la anulación de los radicados de los actos administrativos?", "01. Consultar Acto Administrtivo", "01", null, null, 231]], "12. Comunicados Internos": [["12. Comunicados Internos", "4.5", "Módulo de Administración", "26", "¿Permite configurar servicios de distribución interna de comunicaciones recibidas?", "01. Consultar Comunicado Interno", "01", null, null, 232], ["12. Comunicados Internos", "4.4", "Radicación", "5", "¿Dispone de un mecanismo que evidencie las comunicaciones oficiales anuladas?", "01. Consultar Comunicado Interno", "02", null, null, 233], ["12. Comunicados Internos", "4.4", "Radicación", "11", "¿Permite registrar y controlar la anulación de los radicados de las comunicaciones oficiales?", "01. Consultar Comunicado Interno", "03", null, null, 234]], "13. Gestión de Borradores": [["13. Gestión de Borradores", "4.6", "Módulo Flujo de Trabajo", "11", "¿Permite administrar tanto los documentos en fase de redacción como los documentos archivados utilizando el mismo Cuadro de Clasificación Documental y aplicando los mismos protocolos de control de acceso?", "01. Listado de borradores", "01", null, null, 235], ["13. Gestión de Borradores", "4.6", "Módulo Flujo de Trabajo", "16", "¿Permite la reutilización de documentos para la creación de nuevos, preservando la integridad del original?", "01. Listado de borradores", "02", null, null, 236], ["13. Gestión de Borradores", "4.6", "Módulo Flujo de Trabajo", "20", "¿Permite evitar que un documento en fase de elaboración cancelado o detenido sea ingresado al servicio de documentos archivados?", "01. Listado de borradores", "03", null, null, 237], ["13. Gestión de Borradores", "4.6", "Módulo Flujo de Trabajo", "21", "¿Permite asignar un número de versión a cada documento en fase de elaboración y lo muestra al recuperar o buscar el documento?", "01. Listado de borradores", "04", null, null, 238], ["13. Gestión de Borradores", "4.6", "Módulo Flujo de Trabajo", "13", "¿Permite a un usuario autorizado, mediante tareas programadas, ejecutar acciones como: a. Seleccionar documentos en borrador y declararlos documentos de archivo? b. Eliminar todos los borradores dejando solo los documentos de archivo? c. Eliminar todos los borradores después de cierto tiempo, predefinido por un usuario autorizado?", "01. Listado de borradores", "05", null, null, 239], ["13. Gestión de Borradores", "4.6", "Módulo Flujo de Trabajo", "12", "¿Reconoce y organiza, dentro de un Cuadro de Clasificación Documental común, tanto los documentos en proceso de redacción como los documentos archivados?", "01. Listado de borradores", "06", null, null, 240], ["13. Gestión de Borradores", "4.4", "Radicación", "36", "¿Permite listar las comunicaciones oficiales anuladas en un periodo de tiempo determinado?", "01. Listado de borradores", "07", null, null, 241]], "14. Expedientes": [["14. Expedientes", "4.11", "Búsqueda y Reportes", "4", "¿Permite aplicar diversos filtros, valores y metadatos para llevar a cabo procesos de búsqueda?", "01. Consultar Expedientes", "01", null, null, 242], ["14. Expedientes", "4.11", "Búsqueda y Reportes", "5", "¿Permite establecer criterios de búsqueda en cualquier nivel del Cuadro de Clasificación Documental?", "01. Consultar Expedientes", "02", null, null, 243], ["14. Expedientes", "4.11", "Búsqueda y Reportes", "6", "¿Permite la realización de búsquedas en elementos activos, inactivos o ambos de una entidad?", "01. Consultar Expedientes", "03", null, null, 244], ["14. Expedientes", "4.2", "Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación", "21", "¿El sistema permite a usuarios autorizados examinar e inspeccionar expedientes activos sujetos a disposición, con opciones para ordenar y agrupar según preferencias específicas, como:\n\na. Por agrupación documental de acuerdo con algún nivel del Cuadro de Clasificación Documental\nb. Por versión de TRD o TVD\nc. Por código de acción de disposición\nd. Por fecha de vencimiento de acción de disposición\ne. Por fecha de vencimiento de confirmación de disposición?", "01. Consultar Expedientes", "04", null, null, 245], ["14. Expedientes", "4.1", "Administración de Expedientes", "19", "¿Facilita a un usuario autorizado la exploración e inspección de series, subseries y expedientes junto con sus metadatos, mediante la navegación desde el servicio de clasificación y el servicio de Documentos de Archivo?", "01. Consultar Expedientes", "05", null, null, 246], ["14. Expedientes", "4.10", "Módulo de Manejo Físico de Documentos", "26", "¿Permite asegurar que, al buscar series, subseries y expedientes, se recuperen simultáneamente metadatos de documentos físicos y electrónicos en una sola operación?", "01. Consultar Expedientes", "06", null, null, 247], ["14. Expedientes", "4.5", "Módulo de Administración", "40", "¿Permite configurar los servicios de control de inventarios y digitalización con fines de consulta sobre archivos inactivos?", "01. Consultar Expedientes", "07", null, null, 248], ["14. Expedientes", "4.11", "Búsqueda y Reportes", "8", "¿Permite la exportación de búsquedas en formatos como xlsx, XML, HTML, pdf, etc.?", "01. Consultar Expedientes", "08", null, null, 249], ["14. Expedientes", "4.1", "Administración de Expedientes", "43", "¿Permite configurar los servicios de creación de expediente aplicables de forma genérica para cualquier agrupación documental de acuerdo con la TRD activa?", "02. Crear Expediente", "01", null, null, 250], ["14. Expedientes", "4.1", "Administración de Expedientes", "22", "¿El sistema permite la replicación de un tipo documental a otro expediente, asegurando la incorporación adecuada de los metadatos del sistema y contextuales, la lista de control de acceso, y el historial de eventos?", "02. Crear Expediente", "02", null, null, 251], ["14. Expedientes", "4.1", "Administración de Expedientes", "18", "¿Permite que un usuario autorizado elimine un expediente vacío que nunca haya sido utilizado?", "02. Crear Expediente", "03", null, null, 252], ["14. Expedientes", "4.12", "Otros", "3", "¿Permite el registro de archivos de DDHH/DIH?", "03. Información del Expediente", "01", null, null, 253], ["14. Expedientes", "4.1", "Administración de Expedientes", "16", "¿Permite el cierre manual y/o automático de un expediente al agregar el documento que concluye el trámite, según un flujo de trabajo o criterio de cierre específico (por ejemplo, finalización de vigencia)?", "03. Información del Expediente", "02", null, null, 254], ["14. Expedientes", "4.1", "Administración de Expedientes", "5", "¿Permite mecanismos electrónicos seguros para generar el cierre de los expedientes, en cumplimiento de las Directrices del AGN y Min Tic?", "03. Información del Expediente", "03", null, null, 255], ["14. Expedientes", "4.2", "Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación", "13", "¿Activa el periodo de retención desde el cierre del expediente?", "03. Información del Expediente", "04", null, null, 256], ["14. Expedientes", "4.2", "Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación", "28", "¿Permite configurar el control de términos de retención una vez cerrado cada expediente?", "03. Información del Expediente", "05", null, null, 257], ["14. Expedientes", "4.1", "Administración de Expedientes", "47", "¿Permite la reapertura de expedientes cerrados, por instrucción de rol administrador previa justificación del área productora?", "03. Información del Expediente", "06", null, null, 258], ["14. Expedientes", "4.10", "Módulo de Manejo Físico de Documentos", "9", "¿Permite gestionar documentos físicos de la misma forma que los documentos electrónicos, incluyendo herencia de metadatos?", "04. Documentos del expediente", "01", null, null, 259], ["14. Expedientes", "4.2", "Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación", "1", "¿Permite garantizar que los documentos electrónicos de archivo que se capturen se asocien a una TRD configurada en el sistema?", "04. Documentos del expediente", "02", null, null, 260], ["14. Expedientes", "4.1", "Administración de Expedientes", "7", "¿Permite y cuenta con tipos de control para la depuración o intervención de expedientes electrónicos?", "04. Documentos del expediente", "03", null, null, 261], ["14. Expedientes", "4.2", "Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación", "12", "¿No debería haber restricciones en el número de documentos almacenados en cualquier serie, subserie o expediente?", "04. Documentos del expediente", "04", null, null, 262], ["14. Expedientes", "4.3", "Producción", "4", "¿Permite y cuenta con el uso de diferentes tipos de formatos para la producción y recepción documental?", "04. Documentos del expediente", "05", null, null, 263], ["14. Expedientes", "4.3", "Producción", "1", "¿Permite al gestor diferentes tipos de formatos para la conservación y preservación documental?", "04. Documentos del expediente", "06", null, null, 264], ["14. Expedientes", "4.2", "Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación", "10", "¿Permite la clasificación de documentos y expedientes dentro del cuadro de clasificación documental?", "04. Documentos del expediente", "07", null, null, 265], ["14. Expedientes", "4.5", "Módulo de Administración", "35", "¿Permite configurar formulario de testigo documental para ser diligenciado y usado en cualquiera de los expedientes del SGDEA?", "04. Documentos del expediente", "08", null, null, 266], ["14. Expedientes", "4.5", "Módulo de Administración", "43", "¿Permite configurar formulario de descripción archivística con fines históricos para archivos de conservación total?", "04. Documentos del expediente", "09", null, null, 267], ["14. Expedientes", "4.1", "Administración de Expedientes", "23", "¿El sistema permite al usuario explorar e inspeccionar los documentos de archivo mediante al menos las siguientes modalidades:\n\na. Navegar por los documentos de un expediente en orden de fecha\nb. Navegar desde un documento a su expediente e inspeccionar sus metadatos\nc. Navegar de un documento a su serie o subserie e inspeccionar sus metadatos\nd. Navegar desde un documento a sus componentes e inspeccionar sus metadatos?", "05. Índice electrónico", "01", null, null, 268], ["14. Expedientes", "4.1", "Administración de Expedientes", "1", "¿Cuenta con mecanismos implementados para el foliado de los documentos electrónicos, garantizando la integridad y autenticidad del expediente y los documentos que lo conforman?", "05. Índice electrónico", "02", null, null, 269], ["14. Expedientes", "4.1", "Administración de Expedientes", "26", "¿Organiza los documentos dentro de un expediente de manera ascendente según la fecha de trámite?", "05. Índice electrónico", "03", null, null, 270], ["14. Expedientes", "4.10", "Módulo de Manejo Físico de Documentos", "8", "¿Permite identificar las series, subseries y expedientes para documentos en formatos análogos?", "05. Índice electrónico", "04", null, null, 271], ["14. Expedientes", "4.10", "Módulo de Manejo Físico de Documentos", "17", "¿Permite organizar tanto los documentos físicos como los electrónicos según el Cuadro de Clasificación Documental?", "05. Índice electrónico", "05", null, null, 272], ["14. Expedientes", "4.1", "Administración de Expedientes", "2", "¿Genera el foliado electrónico para documentos en formatos de archivo diferentes a los procesadores de texto (audiovisuales, imágenes, renders, entre otros)?", "05. Índice electrónico", "06", null, null, 273], ["14. Expedientes", "4.10", "Módulo de Manejo Físico de Documentos", "5", "¿Permite que un expediente contenga documentos electrónicos y físicos para conformar expedientes híbridos?", "05. Índice electrónico", "07", null, null, 274], ["14. Expedientes", "4.1", "Administración de Expedientes", "15", "¿Permite cambiar la clasificación de un documento dentro del Cuadro de Clasificación Documental?", "05. Índice electrónico", "08", null, null, 275], ["14. Expedientes", "4.1", "Administración de Expedientes", "21", "¿Garantiza que todos los documentos clasificados y reclasificados dentro de un expediente hereden los atributos relacionados con tiempos de retención y disposición final de este último?", "05. Índice electrónico", "09", null, null, 276], ["14. Expedientes", "4.1", "Administración de Expedientes", "4", "¿Permite estructurar la base del índice electrónico y su nivel de parametrización?", "05. Índice electrónico", "10", null, null, 277], ["14. Expedientes", "4.1", "Administración de Expedientes", "30", "¿Está accesible el índice electrónico desde la creación misma del expediente?", "05. Índice electrónico", "11", null, null, 278], ["14. Expedientes", "4.1", "Administración de Expedientes", "29", "¿Permite la creación de un índice electrónico en formato XML para cada expediente, generando los metadatos conforme al esquema definido?", "05. Índice electrónico", "12", null, null, 279], ["14. Expedientes", "4.5", "Módulo de Administración", "47", "Cuando por motivos de obsolescencia tecnológica, seguridad de la información, causal administrativo o judicial, se requiera exportar, transferir o migrar los documentos, la solución informática deberá garantizar la integridad de los expedientes, respecto a:\n·Componentes del expediente (documento electrónico, foliado, índice firmado y metadatos).\n·Estructura de los documentos, preservando las relaciones correctas entre ellos", "05. Índice electrónico", "13", null, null, 280], ["14. Expedientes", "4.1", "Administración de Expedientes", "3", "¿Permite identificar o visualizar el índice electrónico?", "05. Índice electrónico", "14", null, null, 281], ["14. Expedientes", "4.1", "Administración de Expedientes", "31", "¿Incluye a todos los expedientes un índice electrónico, el cual debe ser firmado electrónicamente al cerrar el expediente?", "05. Índice electrónico", "15", null, null, 282], ["14. Expedientes", "4.1", "Administración de Expedientes", "32", "¿Permite la navegación por el expediente a través del índice electrónico?", "05. Índice electrónico", "16", null, null, 283], ["14. Expedientes", "4.1", "Administración de Expedientes", "46", "¿Permite configurar la firma de índice electrónico al cierre de expediente (automático o por demanda)?", "05. Índice electrónico", "17", null, null, 284], ["14. Expedientes", "4.10", "Módulo de Manejo Físico de Documentos", "6", "¿Permite generar referencias cruzadas tanto para documentos electrónicos como físicos?", "05. Índice electrónico", "18", null, null, 285], ["14. Expedientes", "4.2", "Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación", "11", "¿Permite la reclasificación de elementos dentro del cuadro de clasificación documental, asegurando que los elementos reclasificados hereden los atributos y metadatos de sus nuevos elementos superiores?", "05. Índice electrónico", "19", null, null, 286], ["14. Expedientes", "4.9", "Metadatos", "18", "¿Permite asegurar la conservación de los metadatos originales durante procesos de intercambio de información y transferencias documentales, incorporando nuevos metadatos según sea necesario?", "05. Índice electrónico", "20", null, null, 287], ["14. Expedientes", "4.10", "Módulo de Manejo Físico de Documentos", "15", "¿Permite garantizar que los controles de acceso para series, subseries y expedientes físicos sean idénticos a los electrónicos?", "06. Seguridad", "01", null, null, 288], ["14. Expedientes", "4.1", "Administración de Expedientes", "37", "¿Permite la inclusión de la etiqueta de clasificación de activos de información (Público, Clasificado, Reservado) correspondiente en el documento?", "06. Seguridad", "02", null, null, 289], ["14. Expedientes", "4.7", "Tablas De Control De Acceso", "1", "¿Permite realizar la tipificación y parametrización de las categorías en las restricciones en cuanto a los derechos de acceso y seguridad a la información?", "06. Seguridad", "03", null, null, 290], ["14. Expedientes", "4.5", "Módulo de Administración", "37", "¿Permite configurar el control de términos para el levantamiento de restricciones de acceso para documentos calificados como \"reservados\" de conformidad con los criterios de IICR?", "06. Seguridad", "04", null, null, 291], ["14. Expedientes", "4.4", "Radicación", "24", "¿Permite etiquetar como reservada una comunicación oficial, con acceso controlado por la lista de control de accesos?", "06. Seguridad", "05", null, null, 292], ["14. Expedientes", "4.11", "Búsqueda y Reportes", "7", "¿Permite que los procesos de búsqueda realizados por un usuario queden registrados en el Historial de eventos de la entidad de usuario?", "07. Trazabilidad del Expediente", "01", null, null, 293], ["14. Expedientes", "4.1", "Administración de Expedientes", "38", "¿Permite el registro de eventos de creación masiva y/o automática de expedientes?", "07. Trazabilidad del Expediente", "02", null, null, 294], ["14. Expedientes", "4.1", "Administración de Expedientes", "39", "¿Permite el registro de eventos de cierre masiva y/o automática de expedientes?", "07. Trazabilidad del Expediente", "03", null, null, 295], ["14. Expedientes", "4.10", "Módulo de Manejo Físico de Documentos", "16", "¿Permite elegir la ubicación física a partir de opciones predeterminadas, como una lista desplegable?", "08. Unidades físicas", "01", null, null, 296], ["14. Expedientes", "4.10", "Módulo de Manejo Físico de Documentos", "19", "¿Permite registrar información sobre la ubicación física de documentos impresos para un control efectivo?", "08. Unidades físicas", "02", null, null, 297], ["14. Expedientes", "4.1", "Administración de Expedientes", "36", "¿Permite a un usuario autorizado validar la integridad de un documento mediante la generación y verificación de un código hash, registrando este valor en el índice electrónico?", "09. Información del documento", "01", null, null, 298], ["14. Expedientes", "4.1", "Administración de Expedientes", "25", "¿Consigna cada acción relacionada con un documento en el \"Historial de eventos\"?", "10. trazabilidad del documento", "01", null, null, 299], ["14. Expedientes", "4.6", "Módulo Flujo de Trabajo", "27", "¿Permite la importación individual o por lotes de documentos archivados no generados dentro del sistema?", "11. Carga masiva de expedientes", "01", null, null, 300], ["14. Expedientes", "4.5", "Módulo de Administración", "44", "¿Permite configurar servicios de migración (entrada - salida) a nivel de expediente y por lote de expedientes?", "11. Carga masiva de expedientes", "02", null, null, 301], ["14. Expedientes", "4.1", "Administración de Expedientes", "9", "¿Permite la articulación y cuenta con mecanismos para la migración de información desde otros sistemas y entidades?", "11. Carga masiva de expedientes", "03", null, null, 302], ["14. Expedientes", "4.1", "Administración de Expedientes", "41", "¿Permite configurar los servicios de cargue masivo de expedientes (datos y documentos) por parte de usuarios internos?", "11. Carga masiva de expedientes", "04", null, null, 303], ["14. Expedientes", "4.5", "Módulo de Administración", "34", "¿Permite configurar los servicios para cargue de documentos nativos digitales o digitalizados fuera del SGDEA para indexación y cargue en expedientes?", "11. Carga masiva de expedientes", "05", null, null, 304], ["14. Expedientes", "4.1", "Administración de Expedientes", "40", "¿Permite que los Expedientes en etapa activa se migren al SGDEA (Registro de Expediente y Documentos de acuerdo a la estructura de datos)?", "11. Carga masiva de expedientes", "06", null, null, 305], ["14. Expedientes", "4.8", "Prestamos", "1", "¿Permite realizar préstamos de la información, ya sea por expediente o por tipologías documentales?", "12. Prestamos", "01", null, null, 306], ["14. Expedientes", "4.10", "Módulo de Manejo Físico de Documentos", "11", "¿Permite que el usuario autorizado registre el préstamo y especifique la fecha de devolución?", "12. Prestamos", "02", null, null, 307], ["14. Expedientes", "4.10", "Módulo de Manejo Físico de Documentos", "12", "¿Permite que la fecha de devolución se calcule automáticamente o de acuerdo con la parametrización y sea configurable?", "12. Prestamos", "03", null, null, 308], ["14. Expedientes", "4.10", "Módulo de Manejo Físico de Documentos", "20", "¿Permite a los usuarios autorizados registrar préstamos y definir la fecha de devolución, calculada automáticamente según parámetros configurables?", "12. Prestamos", "04", null, null, 309], ["14. Expedientes", "4.10", "Módulo de Manejo Físico de Documentos", "18", "¿Permite a los usuarios autorizados modificar la fecha de vencimiento para la devolución de préstamos individuales o múltiples?", "12. Prestamos", "05", null, null, 310], ["14. Expedientes", "4.10", "Módulo de Manejo Físico de Documentos", "7", "¿Permite parametrizar, configurar e imprimir plantillas de comprobante de préstamo y formato externo?", "12. Prestamos", "06", null, null, 311], ["14. Expedientes", "4.10", "Módulo de Manejo Físico de Documentos", "21", "¿Permite parametrizar, configurar e imprimir formatos para los registros de préstamo?", "12. Prestamos", "07", null, null, 312], ["14. Expedientes", "4.10", "Módulo de Manejo Físico de Documentos", "24", "¿Permite a los usuarios autorizados consultar información sobre un préstamo, incluyendo el titular, fecha de salida y control de acceso?", "12. Prestamos", "08", null, null, 313], ["14. Expedientes", "4.10", "Módulo de Manejo Físico de Documentos", "28", "¿Permite notificar por correo electrónico al usuario, incluyendo al funcionario de archivo y al titular del préstamo, cuando se acerca la fecha de vencimiento para la devolución y cuando ya ha vencido?", "12. Prestamos", "09", null, null, 314], ["14. Expedientes", "4.8", "Prestamos", "2", "Cuando el expediente es físico, ¿Permite una notificación automática cuando la información se encuentra en préstamo a otros usuarios?", "12. Prestamos", "10", null, null, 315], ["14. Expedientes", "4.8", "Prestamos", "5", "¿Permite notificar al usuario la fecha cercana del vencimiento del préstamo y parametrizar notificaciones cuando el préstamo está vencido, generando así los reportes de préstamos?", "12. Prestamos", "11", null, null, 316], ["14. Expedientes", "4.1", "Administración de Expedientes", "10", "¿Cuenta con una capa de interoperabilidad que permite la integración e intercambio de datos con los sistemas y repositorios digitales de la entidad?", "13. Microservicios", "01", null, null, 317]], "15. Archivo Físico": [["15. Archivo Físico", "4.5", "Módulo de Administración", "39", "¿Permite configurar los servicios de administración de espacios de custodia con la arquitectura de los repositorios o bodegas físicas vigentes?", "01. Consultar bodegas", "01", null, null, 318], ["15. Archivo Físico", "4.5", "Módulo de Administración", "41", "¿Permite configurar servicio de asignación de locación en bodega para transferencias de archivos en soporte físico?", "01. Consultar bodegas", "02", null, null, 319], ["15. Archivo Físico", "4.10", "Módulo de Manejo Físico de Documentos", "2", "¿Permite localizar un expediente híbrido o físico?", "01. Consultar bodegas", "03", null, null, 320], ["15. Archivo Físico", "4.10", "Módulo de Manejo Físico de Documentos", "1", "¿Contiene un módulo para administración de documentos físicos?", "02. Detalle del edificio", "01", null, null, 321], ["15. Archivo Físico", "4.10", "Módulo de Manejo Físico de Documentos", "4", "¿Permite capturar y gestionar los metadatos acerca de las cajas, carpetas u otras unidades de conservación y almacenamiento?", "02. Detalle del edificio", "02", null, null, 322], ["15. Archivo Físico", "4.10", "Módulo de Manejo Físico de Documentos", "22", "¿Permite a los usuarios autorizados consultar el Inventario Documental, identificando los expedientes actualmente prestados?", "02. Detalle del edificio", "03", null, null, 323], ["15. Archivo Físico", "4.10", "Módulo de Manejo Físico de Documentos", "3", "¿Permite ser leído el código de barras por un lector óptico, identificando y ubicando físicamente el documento (dependencia, archivo, estante, entrepaño, caja) y proporcionando toda la información básica (metadata)?", "02. Detalle del edificio", "04", null, null, 324], ["15. Archivo Físico", "4.10", "Módulo de Manejo Físico de Documentos", "29", "¿Permite admitir la impresión y reconocimiento de códigos de barras o sistemas de localización alternativos para documentos físicos?", "02. Detalle del edificio", "05", null, null, 325], ["15. Archivo Físico", "4.10", "Módulo de Manejo Físico de Documentos", "30", "¿Permite la parametrización, configuración e impresión de la plantilla de rótulo para cajas, carpetas y otras unidades de almacenamiento y conservación?", "02. Detalle del edificio", "06", null, null, 326], ["15. Archivo Físico", "4.1", "Administración de Expedientes", "33", "¿Permite la generación del inventario documental (FUID) en diversos formatos (XLSX, PDF, XML, etc.)?", "02. Detalle del edificio", "07", null, null, 327], ["15. Archivo Físico", "4.1", "Administración de Expedientes", "34", "¿Permite y asegura la disponibilidad del FUID en cualquier momento?", "02. Detalle del edificio", "08", null, null, 328], ["15. Archivo Físico", "4.1", "Administración de Expedientes", "35", "¿Permite exportar e importar un FUID en diversos formatos electrónicos, como XLSX, PDF, XML, etc.?", "02. Detalle del edificio", "09", null, null, 329], ["15. Archivo Físico", "4.10", "Módulo de Manejo Físico de Documentos", "25", "¿Permite registrar en el \"Historial de eventos\" todas las entradas y salidas, valores de metadatos, así como las acciones relacionadas con documentos físicos?", "03. Trazabilidad", "01", null, null, 330], ["15. Archivo Físico", "4.10", "Módulo de Manejo Físico de Documentos", "27", "¿Permite respaldar el seguimiento de cajas, carpetas y otras unidades físicas, proporcionando registros de entrada y salida, ubicación, custodia y fecha de registro?", "03. Trazabilidad", "02", null, null, 331], ["15. Archivo Físico", "4.10", "Módulo de Manejo Físico de Documentos", "23", "¿El sistema registra en los metadatos información sobre los movimientos de una unidad física, incluyendo como mínimo el identificador único, la ubicación actual, las ubicaciones anteriores, la fecha en que se trasladó de ubicación, la fecha de recepción en el lugar y el usuario responsable del movimiento para cada caso?", "03. Trazabilidad", "03", null, null, 332], ["15. Archivo Físico", "4.10", "Módulo de Manejo Físico de Documentos", "14", "¿Permite registrar la información sobre los movimientos de una unidad física?", "03. Trazabilidad", "04", null, null, 333]], "16. Retención y Disposición": [["16. Retención y Disposición", "4.1", "Administración de Expedientes", "6", "¿Permite realizar transferencias primarias y secundarias de los expedientes electrónicos?", "1. Transferencia Primaria", "01", null, null, 334], ["16. Retención y Disposición", "4.2", "Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación", "29", "¿Permite configurar los servicios de compilación de expedientes en cumplimiento de términos de retención para transferencia primaria, alerta a productor, conformación de acta de transferencia, y remisión de requerimiento a administración de Archivo Central?", "1. Transferencia Primaria", "02", null, null, 335], ["16. Retención y Disposición", "4.6", "Módulo Flujo de Trabajo", "47", "¿Permite notificar si un expediente dentro de un flujo de trabajo está programado para revisión o disposición?", "1. Transferencia Primaria", "03", null, null, 336], ["16. Retención y Disposición", "4.2", "Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación", "19", "¿Permite a un usuario autorizado cancelar una transferencia primaria de cualquier expediente al concluir los tiempos en la fase del archivo de gestión?", "2. Solicitudes de Transferencia Primaria", "01", null, null, 337], ["16. Retención y Disposición", "4.2", "Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación", "20", "¿Permite a los usuarios autorizados confirmar el éxito de la transferencia para expedientes con acción de disposición de transferencia que han alcanzado su fecha de vencimiento, estableciendo la marca de tiempo de la transferencia tras la confirmación?", "2. Solicitudes de Transferencia Primaria", "02", null, null, 338], ["16. Retención y Disposición", "4.2", "Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación", "22", "¿Permite a un usuario autorizado aplicar filtros a expedientes y/o documentos para llevar a cabo procesos de selección cuando sea la disposición final?", "3. Expedientes para selección", "01", null, null, 339], ["16. Retención y Disposición", "4.1", "Administración de Expedientes", "24", "¿Permite la consulta de expedientes según sus tiempos de retención y disposición final?", "3. Expedientes para selección", "02", null, null, 340], ["16. Retención y Disposición", "4.2", "Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación", "27", "¿Facilita la creación de inventarios documentales considerando la disposición final como base, incluyendo: \na. La referencia en cada expediente al acta con la que se aprobó la disposición final a realizar\nb. La referencia en cada expediente a la disposición final aplicada\nc. La generación de reportes sobre las disposiciones finales aplicadas\nd. La generación de reportes sobre los documentos transferidos?", "4. Transferencia Secundaria", "01", null, null, 341], ["16. Retención y Disposición", "4.2", "Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación", "18", "¿Incorpora una herramienta FTP (Protocolo de Transferencia de Archivos) para garantizar la integridad de expedientes, documentos y metadatos?", "4. Transferencia Secundaria", "02", null, null, 342], ["16. Retención y Disposición", "4.5", "Módulo de Administración", "45", "¿Permite configurar servicios de transferencia secundaria, proyección de acta de transferencia a través de reporte de SGDEA y evidencia de recibo efectivo?", "4. Transferencia Secundaria", "03", null, null, 343], ["16. Retención y Disposición", "4.10", "Módulo de Manejo Físico de Documentos", "13", "¿Permite notificar cuando el periodo de retención se cumple y se debe aplicar la disposición final a los expedientes físicos?", "4. Transferencia Secundaria", "04", null, null, 344], ["16. Retención y Disposición", "4.2", "Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación", "25", "¿Implementa un procedimiento de eliminación seguro para evitar la reconstrucción del expediente, aplicable cuando la disposición final de un expediente sea la eliminación?", "4. Transferencia Secundaria", "05", null, null, 345], ["16. Retención y Disposición", "4.2", "Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación", "24", "¿Permite que los expedientes eliminados retengan ciertos metadatos detallados en el esquema correspondiente?", "4. Transferencia Secundaria", "06", null, null, 346], ["16. Retención y Disposición", "4.2", "Módulo TRD (Tabla de Retención Documental) y Servicio de Clasificación", "23", "¿Habilita a un usuario autorizado para revocar la eliminación de cualquier expediente con esta disposición final cuando alcance la fecha de vencimiento de la acción de disposición, siguiendo un mandato legal o administrativo que debe quedar registrado en el historial de eventos y metadatos?", "4. Transferencia Secundaria", "07", null, null, 347], ["16. Retención y Disposición", "4.9", "Metadatos", "6", "¿Permite que los metadatos asociados a una entidad u objeto digital se conserven cuando la entidad o el objeto es eliminado?", "4. Transferencia Secundaria", "08", null, null, 348], ["16. Retención y Disposición", "4.5", "Módulo de Administración", "48", "¿Permite la parametrización y/o configuración para Exportar la totalidad de los expedientes y sus componentes conforme a la estructura de TRD. Exportar o transferir los documentos correspondientes con las reglas de retención y disposición y sus respectivos controles de acceso (seguridad para consulta) para que puedan seguir aplicándose en el sistema de destino?", "4. Transferencia Secundaria", "09", null, null, 349], ["16. Retención y Disposición", "4.5", "Módulo de Administración", "42", "¿Permite configurar los servicios de monitoreo de inventarios de expedientes para transferencia secundaria?", "4. Transferencia Secundaria", "10", null, null, 350]], "17. Reportes Dinámicos": [["17. Reportes Dinámicos", "4.11", "Búsqueda y Reportes", "2", "¿Permite facilitar la realización de procesos de búsqueda y generación de informes en todas las entidades del sistema?", "Configuración reportes dinámicos", null, null, null, 351], ["17. Reportes Dinámicos", "4.5", "Módulo de Administración", "5", "¿Permite generar reportes y parametrizar nuevos reportes?", "Configuración reportes dinámicos", null, null, null, 352], ["17. Reportes Dinámicos", "4.11", "Búsqueda y Reportes", "11", "¿Permite la generación de información de datos históricos de correspondencia?", "Consulta Histórico", null, null, null, 353], ["17. Reportes Dinámicos", "4.1", "Administración de Expedientes", "11", "¿Permite generar reportes de las transferencias documentales realizadas?", null, null, null, null, 354], ["17. Reportes Dinámicos", "4.11", "Búsqueda y Reportes", "1", "¿Permite asegurar que se cumplen las restricciones establecidas por la tabla de control de acceso y los roles del usuario al realizar búsquedas y generar informes?", null, null, null, null, 355], ["17. Reportes Dinámicos", "4.11", "Búsqueda y Reportes", "3", "¿Permite organizar los resultados, al menos, según relevancia, fechas y orden alfabético?", null, null, null, null, 356], ["17. Reportes Dinámicos", "4.11", "Búsqueda y Reportes", "10", "¿Permite y facilita la generación de informes que incluyan elementos gráficos y tablas?", null, null, null, null, 357], ["17. Reportes Dinámicos", "4.12", "Otros", "1", "El sistema permite la compilación, normalización, depuración de data y complemento de los datos asociados a los siguientes casos:\n\n1. Estructuras organizacionales (organigramas) por periodos en los cuales estuvieron vigentes.\n2. Instrumentos de Clasificación Documental en los diferentes periodos de aplicación.\n3. Inventarios documentales a nivel de datos estructurados (AC- AGC - AG).\n4. Estructuras de almacenamiento en bodega física.\n5. Instrumentos de Clasificación y Acceso vigentes (TRD, TCA, IICR, RA).", null, null, null, null, 358], ["17. Reportes Dinámicos", "4.5", "Módulo de Administración", "1", "¿Permite estructurar el reporte de auditoría que se realiza en los tiempos de retención y disposición, incluyendo la fecha del cambio o eliminación y el usuario que lo registra?", null, null, null, null, 359], ["17. Reportes Dinámicos", "4.5", "Módulo de Administración", "2", "¿Permite generar datos para el reporte del estado de la transferencia o exportación realizada?", null, null, null, null, 360], ["17. Reportes Dinámicos", "4.7", "Tablas De Control De Acceso", "3", "¿Permite generar un informe para un usuario autorizado, listando los usuarios que están activos y que pertenecían a un grupo determinado en una fecha y hora específica?", null, null, null, null, 361], ["17. Reportes Dinámicos", "4.7", "Tablas De Control De Acceso", "5", "¿Permite generar un informe que muestre la lista de funciones que pertenecían a un rol determinado en una fecha y hora específica?", null, null, null, null, 362]]}, "headers": ["Módulo", "Referencia", "Elemento", "REQ", "Requerimiento", "Submódulo/Pantalla", "Orden", null, null, "Fila origen"], "metrics": {"total": 360, "cumple": 352, "nocumple": 8, "modulos": 17}};
const COLORS = ['#5b8cff','#22d3ee','#7c5bff','#34d399','#fbbf24','#fb7185','#a78bfa','#38bdf8'];
const esc = s => (s==null?'':String(s)).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
const escA = s => esc(s).replace(/"/g,'&quot;');
const nl2br = s => esc(s).replace(/\n/g,'<br>');

const slides = [];
const sinMod = DATA.resumen.find(r=>r.modulo.startsWith('Sin'));
const sinCount = sinMod? sinMod.total : 0;

/* 1. Cover + Panorama general (unificadas) */
const m=DATA.metrics;
const MOD_ICONS={'01':'🔐','02':'🛡️','03':'👥','04':'🕘','05':'⚙️','06':'🔔','07':'🗂️','08':'🔀',
  '09':'✉️','10':'✍️','11':'🏛️','12':'📢','13':'📝','14':'🗃️','15':'🗄️','16':'♻️','17':'📊'};
const MOD_SVG={'01':'login.svg','02':'roles.svg','03':'usuarios.svg','04':'historial de eventos.svg',
  '05':'configuracion.svg','06':'alertas.svg','07':'clasificacion documental.svg','08':'flujos de trabajo.svg',
  '09':'correspondencia.svg','10':'firmas.svg','11':'acto administrativo.svg','12':'comunicados internos.svg',
  '13':'gestion de borradores.svg','14':'expedientes.svg','15':'archivos fisicos.svg',
  '16':'retencion y disposicion.svg','17':'reportes dinamicos.svg'};
const iconFor=mod=>{
  const k=(mod.split('.')[0]||'').trim();
  const svg=MOD_SVG[k];
  if(svg) return `<img class="mod-svg" src="iconos/${encodeURIComponent(svg)}" alt="" draggable="false">`;
  return MOD_ICONS[k]||'📄';
};
slides.push({type:'cover', html:`
  <div class="cover-inner">
    <div class="cover-logos">
      <img class="cover-logo tlogo" src="Logo%20Banco%20Agrario%20blanco.png" data-dark="Logo%20Banco%20Agrario%20blanco.png" data-light="Logo%20Banco%20Agrario-horizontal.svg" alt="Banco Agrario de Colombia">
      <span class="logo-sep"></span>
      <img class="cover-logo linktic tlogo" src="linktic.svg" data-dark="linktic.svg" data-light="logolinktic.svg" alt="LinkTIC">
    </div>
    <div class="kicker"><span class="dot"></span> Sistema de Gestión Documental Electrónico de Archivo</div>
    <h1>Contextualización de <span class="grad">Requisitos por Módulo</span></h1>
    <p class="sub">Cobertura integral de los requerimientos funcionales del SGDEA, organizados por módulo, con su contextualización funcional y el detalle de cada requisito asociado.</p>
    <div class="meta">
      <div><div class="n">${m.modulos}</div><div class="l">Módulos funcionales</div></div>
      <div><div class="n">${m.total}</div><div class="l">Requerimientos</div></div>
    </div>
  </div>`});

/* 3. Module map */
let tiles='';
DATA.resumen.forEach((mod,i)=>{
  const c=COLORS[i%COLORS.length];
  const num = mod.modulo.startsWith('Sin')? '—' : mod.modulo.split('.')[0];
  const name = mod.modulo.replace(/^\d+\.\s*/,'');
  tiles+=`<div class="modtile" data-go="${i+2}" data-mod="${i}" style="--mc:${c};--idx:${i}">
    <span class="mt-bar"></span>
    <div class="mt-head">
      <span class="mt-badge">${esc(num.padStart? num.padStart(2,'0'):num)}</span>
      <span class="mt-ic">${iconFor(mod.modulo)}</span>
      <span class="mt-count"><b>${mod.total}</b> reqs</span>
    </div>
    <h3>${esc(name)}</h3>
    <div class="mt-track"><i id="mtrack-${i}" style="width:0%"></i></div>
    <div class="mt-foot"><span class="mt-prog" id="mprog-${i}">0 / ${mod.total} revisados</span><span class="mt-arrow">→</span></div>
  </div>`;
});
slides.push({type:'plain', html:`
  <div class="shead"><div><div class="kicker"><span class="dot"></span> Mapa de módulos</div><h2>${DATA.resumen.length} agrupaciones cubiertas</h2></div>
  <div class="rt"><b>${m.total} requerimientos</b>Distribuidos por módulo</div></div>
  <div class="gprog">
    <div class="gprog-top"><span class="gprog-label">Avance global de revisión</span>
      <span class="gprog-count"><b id="gprog-count">0</b> / ${m.total} requisitos · <b id="gprog-pct">0%</b></span></div>
    <div class="gprog-track"><i id="gprog-bar"></i></div>
  </div>
  <div class="modgrid">${tiles}</div>`});

/* 4..N module detail slides */
DATA.resumen.forEach((mod,i)=>{
  const c=COLORS[i%COLORS.length];
  const name = mod.modulo.replace(/^\d+\.\s*/,'');
  const rows = DATA.modDet[mod.modulo]||[];
  const conSub = rows.filter(r=>r[5]).length;
  // Agrupar por Submódulo/Pantalla, en el orden establecido (módulo · submódulo · orden)
  const groups=[]; const gmap={};
  rows.forEach((r,ri)=>{
    const key=(r[5]||'__nosub__');
    if(!gmap[key]){gmap[key]={sub:r[5]||'',items:[]};gmap[key]._i=groups.length;groups.push(gmap[key]);}
    gmap[key].items.push({r,ri});
  });
  let gi=0;
  const tr = groups.map(g=>{
    const title = g.sub || 'Sin submódulo / pantalla';
    const btns = g.items.map(({r,ri})=>{
      const code=(r[1]?r[1]:'')+(r[3]?(' · REQ '+r[3]):'');
      const itemPart=r[1]?('Ítem '+r[1]):'';
      const reqPart=r[3]?('REQ '+r[3]):('#'+(ri+1));
      const label=(itemPart?(itemPart+' · '):'')+reqPart;
      return `<button class="reqtab" data-mi="${i}" data-ri="${ri}" data-code="${escA(code)}" data-desc="${escA(r[4])}" data-elem="${escA(r[2]||'')}" data-sub="${escA(r[5]||'')}"><span class="reqcheck"></span><span class="reqtab-l">${esc(label)}</span></button>`;
    }).join('');
    return `<div class="reqgroup"><div class="reqgroup-h"><span class="rg-n">${++gi}</span>${esc(title)} <span class="rg-c">${g.items.length}</span></div><div class="reqgroup-b">${btns}</div></div>`;
  }).join('');
  const fr = rows[0]||[];
  const first = {
    code: (fr[1]?fr[1]:'')+(fr[3]?(' · REQ '+fr[3]):''),
    desc: fr[4]||'Sin descripción registrada.',
    meta: (fr[2]?`<div class="row"><span class="k">Elemento</span><span class="v">${esc(fr[2])}</span></div>`:'')
        + (fr[5]?`<div class="row"><span class="k">Submódulo / Pantalla</span><span class="v">${esc(fr[5])}</span></div>`:'')
  };
  slides.push({type:'module', html:`
    <button class="backbtn" data-go="1"><span class="bb-arrow">←</span> Volver a las ${DATA.resumen.length} agrupaciones</button>
    <div class="shead">
      <div class="shead-l">
        <span class="mod-icon" style="--mc:${c}">${iconFor(mod.modulo)}</span>
        <div><div class="kicker"><span class="dot" style="background:${c};box-shadow:0 0 14px ${c}"></span> Módulo ${esc(mod.modulo.startsWith('Sin')?'':mod.modulo.split('.')[0])}</div>
        <h2>${esc(name)}</h2></div>
      </div>
      <div class="rt"><b>${mod.total} requerimientos</b>${i+1} de ${DATA.resumen.length} módulos</div>
    </div>
    <div class="mod-body">
      <div class="mod-side">
        <div class="ctx">
          <div class="lbl">Contextualización funcional</div>
          <p>${nl2br(mod.contexto.replace(/\s*En esta versión se[\s\S]*$/,''))}</p>
        </div>
        <div class="reqcard">
          <div class="reqcard-empty">
            <div class="ce-ic">👉</div>
            <p>Selecciona un <b>REQ</b> en el panel de la derecha para ver aquí la información del requerimiento.</p>
          </div>
          <div class="reqcard-body" style="display:none">
            <div class="rc-tag">Requerimiento seleccionado</div>
            <div class="rc-code"></div>
            <p class="rc-desc"></p>
            <div class="rc-meta"></div>
          </div>
        </div>
      </div>
      <div class="reqpanel">
        <div class="reqpanel-h">
          <div class="rp-title">Requerimientos por item <span style="color:var(--faint);text-transform:none;letter-spacing:0;font-weight:400">· selecciona uno</span></div>
          <div class="rp-prog">
            <div class="rp-prog-lbl"><span>Progreso de revisión</span><span id="rpcount-${i}">0 / ${mod.total}</span></div>
            <div class="rp-track"><i id="rptrack-${i}" style="width:0%"></i></div>
          </div>
        </div>
        <div class="reqtabs">${tr}</div>
      </div>
    </div>`});
});

// Render
const deck=document.getElementById('deck');
slides.forEach((s,i)=>{
  const el=document.createElement('section');
  el.className='slide '+(s.type==='cover'?'cover':s.type==='close'?'close':'');
  if(s.type==='module'||s.type==='plain') el.classList.add('scroll');
  el.innerHTML=s.html;
  el.dataset.idx=i;
  deck.appendChild(el);
});

const dotsEl=document.getElementById('dots');
slides.forEach((s,i)=>{const b=document.createElement('button');b.title=(i+1);b.onclick=()=>go(i);dotsEl.appendChild(b);});

let cur=0;
const els=[...document.querySelectorAll('.slide')];
function go(n){
  cur=Math.max(0,Math.min(slides.length-1,n));
  els.forEach((e,i)=>e.classList.toggle('active',i===cur));
  [...dotsEl.children].forEach((d,i)=>d.classList.toggle('on',i===cur));
  document.getElementById('count').textContent=(cur+1)+' / '+slides.length;
  document.getElementById('progress').style.width=((cur+1)/slides.length*100)+'%';
  const sc=els[cur]; if(sc) sc.scrollTop=0;
}
document.getElementById('next').onclick=()=>go(cur+1);
document.getElementById('prev').onclick=()=>go(cur-1);
const STORE_KEY='sgdea-progreso-v1';
function saveProgress(){
  const data={};
  document.querySelectorAll('.reqtab.viewed').forEach(t=>{
    const mi=t.dataset.mi; (data[mi]=data[mi]||[]).push(t.dataset.ri);
  });
  try{localStorage.setItem(STORE_KEY,JSON.stringify(data));}catch(e){}
}
function restoreProgress(){
  let data; try{data=JSON.parse(localStorage.getItem(STORE_KEY)||'{}');}catch(e){data={};}
  Object.keys(data).forEach(mi=>{
    (data[mi]||[]).forEach(ri=>{
      const t=document.querySelector('.reqtab[data-mi="'+mi+'"][data-ri="'+ri+'"]');
      if(t) t.classList.add('viewed');
    });
  });
  // Actualizar todas las barras de cada módulo
  document.querySelectorAll('.mod-body').forEach(body=>{
    const any=body.querySelector('.reqtab'); if(any) updateProgress(any.dataset.mi, body);
  });
  updateGlobalProgress();
}
function updateProgress(mi, body){
  const total = DATA.resumen[+mi].total;
  const viewed = body.querySelectorAll('.reqtab.viewed').length;
  const p = total? Math.round(viewed/total*100) : 0;
  const rt=document.getElementById('rptrack-'+mi); if(rt) rt.style.width=p+'%';
  const rc=document.getElementById('rpcount-'+mi); if(rc) rc.textContent=viewed+' / '+total;
  const mt=document.getElementById('mtrack-'+mi); if(mt) mt.style.width=p+'%';
  const mp=document.getElementById('mprog-'+mi); if(mp) mp.textContent=viewed+' / '+total+' revisados';
  const card=document.querySelector('.modtile[data-mod="'+mi+'"]'); if(card) card.classList.toggle('done', viewed>=total);
  const panel=body.querySelector('.reqpanel'); if(panel) panel.classList.toggle('done', viewed>=total);
  updateGlobalProgress();
}
function updateGlobalProgress(){
  const total=DATA.metrics.total;
  const viewed=document.querySelectorAll('.reqtab.viewed').length;
  const p=total?Math.round(viewed/total*100):0;
  const bar=document.getElementById('gprog-bar'); if(bar) bar.style.width=p+'%';
  const c=document.getElementById('gprog-count'); if(c) c.textContent=viewed;
  const pc=document.getElementById('gprog-pct'); if(pc) pc.textContent=p+'%';
}
deck.addEventListener('click',e=>{
  const cb=e.target.closest('.reqcheck');
  if(cb){
    const chip=cb.closest('.reqtab');
    chip.classList.toggle('viewed');
    updateProgress(chip.dataset.mi, chip.closest('.mod-body'));
    saveProgress();
    return;
  }
  const chip=e.target.closest('.reqtab');
  if(chip){
    const body=chip.closest('.mod-body');
    body.querySelectorAll('.reqtab').forEach(x=>x.classList.remove('active'));
    chip.classList.add('active');
    chip.classList.add('viewed');
    const empty=body.querySelector('.reqcard-empty'); if(empty) empty.style.display='none';
    const b=body.querySelector('.reqcard-body');
    b.style.display='flex';
    b.querySelector('.rc-code').textContent=chip.dataset.code;
    b.querySelector('.rc-desc').textContent=chip.dataset.desc;
    let meta='';
    if(chip.dataset.elem) meta+=`<div class="row"><span class="k">Elemento</span><span class="v">${esc(chip.dataset.elem)}</span></div>`;
    if(chip.dataset.sub) meta+=`<div class="row"><span class="k">Submódulo / Pantalla</span><span class="v">${esc(chip.dataset.sub)}</span></div>`;
    b.querySelector('.rc-meta').innerHTML=meta;
    updateProgress(chip.dataset.mi, body);
    saveProgress();
    return;
  }
  const t=e.target.closest('[data-go]');if(t)go(+t.dataset.go);
});
setTimeout(()=>document.getElementById('hint').classList.add('hide'),4500);
document.addEventListener('keydown',e=>{
  if(e.key==='ArrowRight'||e.key==='PageDown'||e.key===' '){e.preventDefault();go(cur+1);}
  else if(e.key==='ArrowLeft'||e.key==='PageUp'){e.preventDefault();go(cur-1);}
  else if(e.key==='Home')go(0);
  else if(e.key==='End')go(slides.length-1);
  else if(e.key.toLowerCase()==='f'){if(!document.fullscreenElement)document.documentElement.requestFullscreen();else document.exitFullscreen();}
});
let tx=0;
deck.addEventListener('touchstart',e=>tx=e.changedTouches[0].clientX,{passive:true});
deck.addEventListener('touchend',e=>{const dx=e.changedTouches[0].clientX-tx;if(Math.abs(dx)>60)go(cur+(dx<0?1:-1));},{passive:true});
restoreProgress();
// Ajusta el título y subtítulo de la portada para que siempre llenen el ancho
function fitCover(){
  const slide=document.querySelector('.slide.cover');
  if(!slide) return;
  const inner=slide.querySelector('.cover-inner');
  if(!inner) return;
  const avail=inner.clientWidth;
  if(!avail) return;
  slide.querySelectorAll('h1, p.sub').forEach(el=>{
    el.style.fontSize='';
    const w=el.scrollWidth;
    if(w>0){
      const cur=parseFloat(getComputedStyle(el).fontSize);
      el.style.fontSize=(cur*avail/w)+'px';
    }
  });
}
window.addEventListener('resize',fitCover);
if(document.fonts&&document.fonts.ready)document.fonts.ready.then(fitCover);
go(0);
requestAnimationFrame(fitCover);

/* ---- Conmutador de tema claro / oscuro ---- */
(function(){
  const btn=document.getElementById('theme');
  const root=document.documentElement;
  function apply(theme){
    const light=theme==='light';
    if(light){root.setAttribute('data-theme','light');btn.textContent='☀️';}
    else{root.removeAttribute('data-theme');btn.textContent='🌙';}
    document.querySelectorAll('.tlogo').forEach(img=>{
      const src=light?img.dataset.light:img.dataset.dark;
      if(src&&img.getAttribute('src')!==src)img.setAttribute('src',src);
    });
  }
  let saved;
  try{saved=localStorage.getItem('sgdea-theme');}catch(e){}
  apply(saved||'dark');
  btn.addEventListener('click',()=>{
    const isLight=root.getAttribute('data-theme')==='light';
    const next=isLight?'dark':'light';
    apply(next);
    try{localStorage.setItem('sgdea-theme',next);}catch(e){}
    if(typeof fitCover==='function')requestAnimationFrame(fitCover);
  });
})();
</script>
</body>
</html>